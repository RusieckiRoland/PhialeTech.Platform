<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PhialeGis.Library.WinUi.Controls"
    xmlns:primitives="using:Microsoft.UI.Xaml.Controls.Primitives"
    xmlns:skia="using:SkiaSharp.Views.Windows">

    <!--  ===== existing: PhialeDrawBoxWinUI (unchanged) =====  -->
    <Style TargetType="local:PhialeDrawBoxWinUI">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:PhialeDrawBoxWinUI">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                        </Grid.RowDefinitions>

                        <skia:SKXamlCanvas
                            x:Name="SkiaCanvas"
                            Grid.Row="0"
                            Grid.Column="0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch" />

                        <Border
                            Grid.Row="1"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Padding="8,4"
                            Background="#F5F7FA"
                            BorderBrush="#D7DEE7"
                            BorderThickness="0,1,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel
                                    Grid.Column="0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Spacing="12">
                                    <TextBlock x:Name="PART_StatusPrimaryText" Foreground="#1E2A3A" />
                                    <TextBlock x:Name="PART_StatusCoordinateText" Foreground="#475467" />
                                    <TextBlock x:Name="PART_StatusSnapText" Foreground="#B54708" />
                                </StackPanel>

                                <StackPanel
                                    Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Spacing="8">
                                    <Button x:Name="PART_TakeoverButton" MinWidth="44" Padding="10,4" Visibility="Collapsed" />
                                    <Button x:Name="PART_UndoButton" MinWidth="44" Padding="10,4" Visibility="Collapsed" />
                                    <Button x:Name="PART_FinishButton" MinWidth="44" Padding="10,4" Visibility="Collapsed" />
                                    <Button x:Name="PART_CancelButton" MinWidth="44" Padding="10,4" Visibility="Collapsed" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <primitives:ScrollBar
                            x:Name="ScrollBarHorizontal"
                            Grid.Row="2"
                            Grid.Column="0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Background="{TemplateBinding Background}"
                            IndicatorMode="MouseIndicator"
                            Orientation="Horizontal"
                            Visibility="{TemplateBinding HorizontalScrollBarVisible}" />

                        <primitives:ScrollBar
                            x:Name="ScrollBarVertical"
                            Grid.Row="0"
                            Grid.Column="1"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Background="{TemplateBinding Background}"
                            IndicatorMode="MouseIndicator"
                            Orientation="Vertical"
                            Visibility="{TemplateBinding VerticalScrollBarVisible}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ===== added: PhialeDslEditor (WebView2 host) =====  -->
    <Style TargetType="local:PhialeDslEditor">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:PhialeDslEditor">
                    <Grid Background="{TemplateBinding Background}">
                        <Grid
                            x:Name="WebHost"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch">
                            <!--  WinUI 3: WebView2 is in Microsoft.UI.Xaml.Controls  -->
                            <WebView2
                                x:Name="PART_WebView2"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch" />
                        </Grid>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
