<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PhialeTech.ComponentHost.Wpf.Controls"
    xmlns:presentation="clr-namespace:PhialeTech.ComponentHost.Abstractions.Presentation;assembly=PhialeTech.ComponentHost.Abstractions"
    xmlns:styles="clr-namespace:PhialeTech.Styles.Wpf;assembly=PhialeTech.Styles.Wpf">

    <Style TargetType="{x:Type controls:PhialeModalLayerHost}">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:PhialeModalLayerHost}">
                    <ControlTemplate.Resources>
                        <Storyboard x:Key="CompactModalMaterializeStoryboard" FillBehavior="HoldEnd">
                            <DoubleAnimation Storyboard.TargetName="OverlayRoot"
                                             Storyboard.TargetProperty="Opacity"
                                             From="0"
                                             To="1"
                                             Duration="0:0:0.14" />
                            <DoubleAnimation Storyboard.TargetName="DialogRoot"
                                             Storyboard.TargetProperty="Opacity"
                                             From="0"
                                             To="1"
                                             Duration="0:0:0.18">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetName="DialogScaleTransform"
                                             Storyboard.TargetProperty="ScaleX"
                                             From="0.97"
                                             To="1"
                                             Duration="0:0:0.18">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetName="DialogScaleTransform"
                                             Storyboard.TargetProperty="ScaleY"
                                             From="0.97"
                                             To="1"
                                             Duration="0:0:0.18">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                        <Storyboard x:Key="CompactModalDirectionalStoryboard" FillBehavior="HoldEnd">
                            <DoubleAnimation Storyboard.TargetName="OverlayRoot"
                                             Storyboard.TargetProperty="Opacity"
                                             From="0"
                                             To="1"
                                             Duration="0:0:0.12" />
                            <DoubleAnimation Storyboard.TargetName="DialogRoot"
                                             Storyboard.TargetProperty="Opacity"
                                             From="0"
                                             To="1"
                                             Duration="0:0:0.24">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetName="DialogScaleTransform"
                                             Storyboard.TargetProperty="ScaleX"
                                             From="0.95"
                                             To="1"
                                             Duration="0:0:0.24">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetName="DialogScaleTransform"
                                             Storyboard.TargetProperty="ScaleY"
                                             From="0.95"
                                             To="1"
                                             Duration="0:0:0.24">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetName="DialogTranslateTransform"
                                             Storyboard.TargetProperty="X"
                                             From="96"
                                             To="0"
                                             Duration="0:0:0.24">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </ControlTemplate.Resources>
                    <Grid x:Name="Root"
                          Background="Transparent"
                          IsHitTestVisible="False"
                          Panel.ZIndex="1000">
                        <controls:PhialeGlassScrimSkiaPresenter x:Name="OverlayRoot"
                                                                 Opacity="0"
                                                                 TintBrush="{DynamicResource Brush.ComponentHost.Overlay.Scrim}"
                                                                 HighlightBrush="{DynamicResource Brush.ComponentHost.Overlay.Highlight}" />

                        <Border x:Name="DialogRoot"
                                Margin="{TemplateBinding SurfaceMargin}"
                                Width="{TemplateBinding SurfaceWidth}"
                                MaxWidth="{TemplateBinding SurfaceMaxWidth}"
                                HorizontalAlignment="{TemplateBinding SurfaceHorizontalAlignment}"
                                VerticalAlignment="{TemplateBinding SurfaceVerticalAlignment}"
                                Background="Transparent"
                                Opacity="0"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="DialogScaleTransform" ScaleX="0.97" ScaleY="0.97" />
                                    <TranslateTransform x:Name="DialogTranslateTransform" />
                                </TransformGroup>
                            </Border.RenderTransform>
                            <Grid x:Name="PART_SurfaceHost"
                                  KeyboardNavigation.TabNavigation="Cycle"
                                  KeyboardNavigation.ControlTabNavigation="Cycle">
                                <controls:PhialeModalChromeSkiaPresenter BackgroundBrush="{DynamicResource Brush.ComponentHost.Sheet.Background}"
                                                                         BorderBrush="{DynamicResource Brush.ComponentHost.Sheet.Border}"
                                                                         ShadowBrush="{DynamicResource Brush.ComponentHost.Sheet.Shadow}"
                                                                         CornerRadius="18" />
                                <Border Margin="8"
                                        Background="Transparent"
                                        CornerRadius="12"
                                        styles:RoundedChildClipBehavior.ClipChildToBorder="True">
                                    <ContentPresenter Content="{TemplateBinding HostedContent}" />
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSessionOpen" Value="True">
                            <Setter TargetName="Root" Property="IsHitTestVisible" Value="True" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSessionOpen" Value="True" />
                                <Condition Property="IsAnimatedOpen" Value="True" />
                                <Condition Property="PresentationMode" Value="{x:Static presentation:HostedPresentationMode.CompactModal}" />
                                <Condition Property="EntranceStyle" Value="{x:Static presentation:HostedEntranceStyle.Materialize}" />
                            </MultiTrigger.Conditions>
                            <MultiTrigger.EnterActions>
                                <BeginStoryboard x:Name="CompactModalMaterializeEnterStoryboard"
                                                 Storyboard="{StaticResource CompactModalMaterializeStoryboard}" />
                            </MultiTrigger.EnterActions>
                            <MultiTrigger.ExitActions>
                                <RemoveStoryboard BeginStoryboardName="CompactModalMaterializeEnterStoryboard" />
                            </MultiTrigger.ExitActions>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSessionOpen" Value="True" />
                                <Condition Property="IsAnimatedOpen" Value="True" />
                                <Condition Property="PresentationMode" Value="{x:Static presentation:HostedPresentationMode.CompactModal}" />
                                <Condition Property="EntranceStyle" Value="{x:Static presentation:HostedEntranceStyle.Directional}" />
                            </MultiTrigger.Conditions>
                            <MultiTrigger.EnterActions>
                                <BeginStoryboard x:Name="CompactModalEnterStoryboard"
                                                 Storyboard="{StaticResource CompactModalDirectionalStoryboard}" />
                            </MultiTrigger.EnterActions>
                            <MultiTrigger.ExitActions>
                                <RemoveStoryboard BeginStoryboardName="CompactModalEnterStoryboard" />
                            </MultiTrigger.ExitActions>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSessionOpen" Value="True" />
                                <Condition Property="IsAnimatedOpen" Value="True" />
                                <Condition Property="PresentationMode" Value="{x:Static presentation:HostedPresentationMode.OverlaySheet}" />
                                <Condition Property="SheetPlacement" Value="{x:Static presentation:HostedSheetPlacement.Right}" />
                                <Condition Property="EntranceStyle" Value="{x:Static presentation:HostedEntranceStyle.Directional}" />
                            </MultiTrigger.Conditions>
                            <MultiTrigger.EnterActions>
                                <BeginStoryboard x:Name="OverlaySheetRightEnterStoryboard">
                                    <Storyboard FillBehavior="HoldEnd">
                                        <DoubleAnimation Storyboard.TargetName="OverlayRoot"
                                                         Storyboard.TargetProperty="Opacity"
                                                         From="0"
                                                         To="1"
                                                         Duration="0:0:0.32" />
                                        <DoubleAnimation Storyboard.TargetName="DialogRoot"
                                                         Storyboard.TargetProperty="Opacity"
                                                         From="0"
                                                         To="1"
                                                         Duration="0:0:0.32">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="DialogScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         From="0.985"
                                                         To="1"
                                                         Duration="0:0:0.32">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="DialogScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         From="0.985"
                                                         To="1"
                                                         Duration="0:0:0.32">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="DialogTranslateTransform"
                                                         Storyboard.TargetProperty="X"
                                                         From="120"
                                                         To="0"
                                                         Duration="0:0:0.32">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiTrigger.EnterActions>
                            <MultiTrigger.ExitActions>
                                <RemoveStoryboard BeginStoryboardName="OverlaySheetRightEnterStoryboard" />
                            </MultiTrigger.ExitActions>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSessionOpen" Value="True" />
                                <Condition Property="IsAnimatedOpen" Value="True" />
                                <Condition Property="PresentationMode" Value="{x:Static presentation:HostedPresentationMode.OverlaySheet}" />
                                <Condition Property="SheetPlacement" Value="{x:Static presentation:HostedSheetPlacement.Center}" />
                                <Condition Property="EntranceStyle" Value="{x:Static presentation:HostedEntranceStyle.Directional}" />
                            </MultiTrigger.Conditions>
                            <MultiTrigger.EnterActions>
                                <BeginStoryboard x:Name="OverlaySheetEnterStoryboard">
                                    <Storyboard FillBehavior="HoldEnd">
                                        <DoubleAnimation Storyboard.TargetName="OverlayRoot"
                                                         Storyboard.TargetProperty="Opacity"
                                                         From="0"
                                                         To="1"
                                                         Duration="0:0:0.32" />
                                        <DoubleAnimation Storyboard.TargetName="DialogRoot"
                                                         Storyboard.TargetProperty="Opacity"
                                                         From="0"
                                                         To="1"
                                                         Duration="0:0:0.32">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="DialogScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         From="0.982"
                                                         To="1"
                                                         Duration="0:0:0.32">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="DialogScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         From="0.982"
                                                         To="1"
                                                         Duration="0:0:0.32">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="DialogTranslateTransform"
                                                         Storyboard.TargetProperty="Y"
                                                         From="56"
                                                         To="0"
                                                         Duration="0:0:0.32">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiTrigger.EnterActions>
                            <MultiTrigger.ExitActions>
                                <RemoveStoryboard BeginStoryboardName="OverlaySheetEnterStoryboard" />
                            </MultiTrigger.ExitActions>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSessionOpen" Value="True" />
                                <Condition Property="IsAnimatedOpen" Value="True" />
                                <Condition Property="PresentationMode" Value="{x:Static presentation:HostedPresentationMode.OverlaySheet}" />
                                <Condition Property="SheetPlacement" Value="{x:Static presentation:HostedSheetPlacement.FullWorkspace}" />
                                <Condition Property="EntranceStyle" Value="{x:Static presentation:HostedEntranceStyle.Directional}" />
                            </MultiTrigger.Conditions>
                            <MultiTrigger.EnterActions>
                                <BeginStoryboard x:Name="OverlaySheetFullWorkspaceEnterStoryboard">
                                    <Storyboard FillBehavior="HoldEnd">
                                        <DoubleAnimation Storyboard.TargetName="OverlayRoot"
                                                         Storyboard.TargetProperty="Opacity"
                                                         From="0"
                                                         To="1"
                                                         Duration="0:0:0.28" />
                                        <DoubleAnimation Storyboard.TargetName="DialogRoot"
                                                         Storyboard.TargetProperty="Opacity"
                                                         From="0"
                                                         To="1"
                                                         Duration="0:0:0.28">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="DialogScaleTransform"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         From="0.988"
                                                         To="1"
                                                         Duration="0:0:0.28">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="DialogScaleTransform"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         From="0.988"
                                                         To="1"
                                                         Duration="0:0:0.28">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="DialogTranslateTransform"
                                                         Storyboard.TargetProperty="Y"
                                                         From="28"
                                                         To="0"
                                                         Duration="0:0:0.28">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiTrigger.EnterActions>
                            <MultiTrigger.ExitActions>
                                <RemoveStoryboard BeginStoryboardName="OverlaySheetFullWorkspaceEnterStoryboard" />
                            </MultiTrigger.ExitActions>
                        </MultiTrigger>
                        <Trigger Property="IsSessionOpen" Value="False">
                            <Setter TargetName="Root" Property="IsHitTestVisible" Value="False" />
                            <Setter TargetName="OverlayRoot" Property="Opacity" Value="0" />
                            <Setter TargetName="DialogRoot" Property="Opacity" Value="0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
