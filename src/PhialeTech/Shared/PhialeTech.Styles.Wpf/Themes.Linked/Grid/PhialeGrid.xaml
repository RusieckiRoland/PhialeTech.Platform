                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Style="{StaticResource PgGridRegionHeaderChromeBorderStyle}">
                                <DockPanel
                                    LastChildFill="False"
                                    LostMouseCapture="HandleRegionDragLostMouseCapture"
                                    PreviewMouseLeftButtonDown="HandleRegionDragMouseLeftButtonDown"
                                    PreviewMouseLeftButtonUp="HandleRegionDragMouseLeftButtonUp"
                                    PreviewMouseMove="HandleRegionDragMouseMove"
                                    Style="{StaticResource PgGridRegionHeaderDockPanelStyle}"
                                    Tag="SummaryDesignerRegion">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock
                                            Margin="0,0,8,0"
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            FontWeight="Bold"
                                            Foreground="{DynamicResource PgMutedTextBrush}"
                                            Text="⋮⋮" />
                                        <Button
                                            Click="HandleRegionToggleButtonClick"
                                            Content="{Binding ElementName=Root, Path=SummaryDesignerRegionToggleText}"
                                            Style="{StaticResource PgRegionExpanderButtonStyle}"
                                            Tag="SummaryDesignerRegion"
                                            Visibility="{Binding ElementName=Root, Path=CanCollapseSummaryDesignerRegion, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource PgPanelTextBrush}"
                                            Text="{Binding ElementName=Root, Path=SummaryDesignerTitleText}" />
                                    </StackPanel>
                                    <Button
                                        Click="HandleRegionCloseButtonClick"
                                        DockPanel.Dock="Right"
                                        Style="{StaticResource PgRegionCloseButtonStyle}"
                                        Tag="SummaryDesignerRegion"
                                        Visibility="{Binding ElementName=Root, Path=CanCloseSummaryDesignerRegion, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                </DockPanel>
                            </Border>

                            <ScrollViewer
                                x:Name="SummaryDesignerContentScrollViewer"
                                Grid.Row="1"
                                Margin="0,12,0,0"
                                Background="{DynamicResource PgGridRegionSurfaceBackgroundBrush}"
                                VerticalScrollBarVisibility="Auto">
                                <ContentPresenter x:Name="SummaryDesignerContentPresenter" Content="{Binding ElementName=Root, Path=SummaryDesignerContent}" />
                            </ScrollViewer>
                        </Grid>
                    </Border>
                    <StackPanel
                        x:Name="SummaryDesignerExpandedTabStrip"
                        Panel.ZIndex="1"
                        Margin="{DynamicResource PgWorkspacePanelExpandedRightExternalTabStripMargin}"
                        SizeChanged="HandleWorkspacePanelTabOverflowLayoutChanged"
                        Style="{StaticResource PgWorkspacePanelExpandedTabStripStyle}"
                        Visibility="{Binding ElementName=SummaryDesignerExpandedShell, Path=Visibility}">
                        <Button
                            x:Name="SummaryDesignerPanelToolsTabButton"
                            Click="HandleOpenWorkspacePanelTabClick"
                            Content="{Binding ElementName=Root, Path=ToolsRegionTitleText}"
                            Style="{StaticResource PgWorkspacePanelExpandedTabButtonStyle}"
                            Tag="SideToolRegion"
                            Visibility="{Binding ElementName=Root, Path=SummaryDesignerPanelToolsTabVisibility}" />
                        <Button
                            x:Name="SummaryDesignerPanelChangesTabButton"
                            Click="HandleOpenWorkspacePanelTabClick"
                            Content="{Binding ElementName=Root, Path=ChangePanelTitleText}"
                            Style="{StaticResource PgWorkspacePanelExpandedTabButtonStyle}"
                            Tag="ChangePanelRegion"
                            Visibility="{Binding ElementName=Root, Path=SummaryDesignerPanelChangesTabVisibility}" />
                        <Button
                            x:Name="SummaryDesignerPanelValidationTabButton"
                            Click="HandleOpenWorkspacePanelTabClick"
                            Content="{Binding ElementName=Root, Path=ValidationPanelTitleText}"
                            Style="{StaticResource PgWorkspacePanelExpandedTabButtonStyle}"
                            Tag="ValidationPanelRegion"
                            Visibility="{Binding ElementName=Root, Path=SummaryDesignerPanelValidationTabVisibility}" />
                        <Button
                            x:Name="SummaryDesignerPanelSummaryDesignerTabButton"
                            Click="HandleOpenWorkspacePanelTabClick"
                            Content="{Binding ElementName=Root, Path=SummaryDesignerTitleText}"
                            Style="{StaticResource PgWorkspacePanelExpandedActiveTabButtonStyle}"
                            Tag="SummaryDesignerRegion"
                            Visibility="{Binding ElementName=Root, Path=SummaryDesignerPanelSummaryDesignerTabVisibility}" />
                        <Button
                            x:Name="SummaryDesignerPanelOverflowTabButton"
                            Click="HandleWorkspacePanelTabOverflowClick"
                            Content="..."
                            Style="{StaticResource PgWorkspacePanelExpandedTabButtonStyle}"
                            Visibility="Collapsed" />
                    </StackPanel>
                </controls:PhialeWorkspacePanel>
            </Grid>

            <Grid
                x:Name="RegionDockPreviewOverlay"
                Grid.Row="2"
                Grid.RowSpan="5"
                Grid.ColumnSpan="5"
                IsHitTestVisible="False"
                Visibility="Collapsed">
                <Border
                    x:Name="RegionDockPreviewLeft"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Stretch"
                    Style="{StaticResource PgGridRegionDockPreviewZoneStyle}"
                    Visibility="Collapsed">
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="26"
                        FontWeight="Bold"
                        Foreground="{DynamicResource PgAccentBrush}"
                        Text="←" />
                </Border>
                <Border
                    x:Name="RegionDockPreviewRight"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    Style="{StaticResource PgGridRegionDockPreviewZoneStyle}"
                    Visibility="Collapsed">
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="26"
                        FontWeight="Bold"
                        Foreground="{DynamicResource PgAccentBrush}"
                        Text="→" />
                </Border>
            </Grid>

            <Grid
                x:Name="WorkspaceBandDockPreviewOverlay"
                Grid.RowSpan="8"
                Grid.Column="2"
                IsHitTestVisible="False"
                Visibility="Collapsed">
                <Border
                    x:Name="RegionDockPreviewTop"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top"
                    Style="{StaticResource PgGridRegionDockPreviewBandZoneStyle}"
                    Visibility="Collapsed">
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="24"
                        FontWeight="Bold"
                        Foreground="{DynamicResource PgAccentBrush}"
                        Text="↑" />
                </Border>
                <Border
                    x:Name="RegionDockPreviewBottom"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Bottom"
                    Style="{StaticResource PgGridRegionDockPreviewBandZoneStyle}"
                    Visibility="Collapsed">
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="24"
                        FontWeight="Bold"
                        Foreground="{DynamicResource PgAccentBrush}"
                        Text="↓" />
                </Border>
            </Grid>

            <GridSplitter
                x:Name="SummaryBottomRegionSplitter"
                Grid.Row="5"
                Grid.Column="2"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                DragCompleted="HandleRegionSplitterDragCompleted"
                ResizeBehavior="PreviousAndNext"
                ResizeDirection="Rows"
                ShowsPreview="True"
                Style="{StaticResource PgRegionSplitterHorizontalStyle}"
                Tag="SummaryBottomRegion" />

            <StackPanel
                x:Name="BottomWorkspaceBandHost"
                Grid.Row="6"
                Grid.Column="2"
                Orientation="Vertical">
                <controls:PhialeWorkspaceBand
                    x:Name="SummaryBottomRegionHost"
                    BandBackground="{DynamicResource PgPanelBackgroundBrush}"
                    BandBorderBrush="{DynamicResource PgPanelBorderBrush}"
                    BandBorderThickness="0,1,0,0"
                    BandPadding="{DynamicResource PgSummaryBottomRegionShellPadding}"
                    IsCloseVisible="{Binding ElementName=Root, Path=CanCloseSummaryBottomRegion}"
                    IsToggleVisible="{Binding ElementName=Root, Path=CanCollapseSummaryBottomRegion}"
                    Tag="SummaryBottomRegion"
                    ToggleText="{Binding ElementName=Root, Path=SummaryBottomRegionToggleText}">
                    <controls:PhialeWorkspacePlayground
                        x:Name="SummaryBottomRegionContentScrollViewer"
                        MinHeight="{DynamicResource PgWorkspacePlaygroundMinHeight}"
                        DataContext="{Binding ElementName=Root}">
                        <controls:PhialeWorkspacePlayground.PlaygroundContent>
                            <ItemsControl ItemsSource="{Binding SummaryItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{DynamicResource PgSummaryResultChipBorderStyle}">
                                        <StackPanel>
                                            <TextBlock
                                                Style="{DynamicResource PgSummaryResultChipTypeTextStyle}"
                                                Text="{Binding TypeLabel}" />
                                            <StackPanel
                                                HorizontalAlignment="Center"
                                                Orientation="Horizontal">
                                                <TextBlock
                                                    Style="{DynamicResource PgSummaryResultChipLabelTextStyle}"
                                                    Text="{Binding ColumnLabel}" />
                                                <TextBlock Style="{DynamicResource PgSummaryResultChipSeparatorTextStyle}" />
                                                <TextBlock
                                                    Style="{DynamicResource PgSummaryResultChipValueTextStyle}"
                                                    Text="{Binding ValueText}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </controls:PhialeWorkspacePlayground.PlaygroundContent>
                    </controls:PhialeWorkspacePlayground>
                </controls:PhialeWorkspaceBand>
            </StackPanel>

            <Border
                x:Name="BottomStatusStripHost"
                Grid.Row="7"
                Grid.Column="2"
                Padding="10,8,10,0"
                Background="Transparent"
                BorderBrush="{DynamicResource PgGridLineBrush}"
                BorderThickness="0,1,0,0">
                <WrapPanel>
                    <TextBlock
                        Margin="0,0,12,8"
                        FontSize="12"
                        Foreground="{DynamicResource PgStatusTextBrush}"
                        Text="{Binding ElementName=Root, Path=SelectionStatusText}" />
                    <TextBlock
                        Margin="0,0,12,8"
                        FontSize="12"
                        Foreground="{DynamicResource PgStatusTextBrush}"
                        Text="{Binding ElementName=Root, Path=CurrentCellText}" />
                    <TextBlock
                        Margin="0,0,12,8"
                        FontSize="12"
                        Foreground="{DynamicResource PgStatusTextBrush}"
                        Text="{Binding ElementName=Root, Path=EditStatusText}" />
                    <TextBlock
                        Margin="0,0,0,8"
                        FontSize="12"
                        Foreground="{DynamicResource PgStatusTextBrush}"
                        Text="{Binding ElementName=Root, Path=PagingStatusText}" />
                </WrapPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
