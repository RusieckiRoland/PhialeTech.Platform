<UserControl
    x:Class="PhialeTech.PhialeGrid.Wpf.Controls.PhialeGrid"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PhialeTech.PhialeGrid.Wpf.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:styles="clr-namespace:PhialeTech.Styles.Wpf;assembly=PhialeTech.Styles.Wpf"
    xmlns:surface="clr-namespace:PhialeTech.PhialeGrid.Wpf.Surface"
    x:Name="Root"
    d:DesignHeight="520"
    d:DesignWidth="980"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PhialeTech.Styles.Wpf;component/Themes/ThemeTokens.Day.xaml" />
                <ResourceDictionary Source="pack://application:,,,/PhialeTech.Styles.Wpf;component/Themes/Controls.Core.xaml" />
                <ResourceDictionary Source="pack://application:,,,/PhialeTech.Styles.Wpf;component/Themes/PhialeGrid.Shared.xaml" />
                <ResourceDictionary Source="pack://application:,,,/PhialeTech.Styles.Wpf;component/Themes/PhialeGrid.Controls.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <Style
                x:Key="PgRegionHeaderActionButtonStyle"
                BasedOn="{StaticResource PgActionButtonStyle}"
                TargetType="Button">
                <Setter Property="MinWidth" Value="28" />
                <Setter Property="Height" Value="28" />
                <Setter Property="Padding" Value="6,2" />
                <Setter Property="Margin" Value="{DynamicResource PgRegionHeaderActionButtonMargin}" />
                <Setter Property="Cursor" Value="Hand" />
            </Style>
            <Style
                x:Key="PgRegionCloseButtonStyle"
                BasedOn="{StaticResource PgRegionHeaderActionButtonStyle}"
                TargetType="Button">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Content" Value="×" />
            </Style>
            <Style
                x:Key="PgRegionExpanderButtonStyle"
                BasedOn="{StaticResource PgRegionHeaderActionButtonStyle}"
                TargetType="Button">
                <Setter Property="Width" Value="22" />
                <Setter Property="MinWidth" Value="22" />
                <Setter Property="Height" Value="22" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="0,0,8,0" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                Background="{DynamicResource PgSurfaceBrush}"
                                BorderBrush="{DynamicResource PgPanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="11">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="PgGridRegionSurfaceGridStyle" TargetType="Grid">
                <Setter Property="Background" Value="{DynamicResource PgGridRegionSurfaceBackgroundBrush}" />
            </Style>
            <Style x:Key="PgGridRegionSurfaceBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource PgGridRegionSurfaceBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource PgPanelBorderBrush}" />
                <Setter Property="CornerRadius" Value="{DynamicResource CornerRadius.Grid.RegionSurface}" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="styles:RoundedChildClipBehavior.ClipChildToBorder" Value="True" />
            </Style>
            <Style
                x:Key="PgWorkspacePanelExpandedShellBorderStyle"
                BasedOn="{StaticResource PgGridRegionSurfaceBorderStyle}"
                TargetType="Border">
                <Setter Property="styles:RoundedChildClipBehavior.ClipChildToBorder" Value="False" />
            </Style>
            <Style
                x:Key="PgGridOuterFrameBorderStyle"
                BasedOn="{StaticResource PgGridRegionSurfaceBorderStyle}"
                TargetType="Border">
                <Setter Property="BorderThickness" Value="1" />
            </Style>
            <Style x:Key="PgGridRegionHeaderChromeBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource PgGridRegionHeaderBackgroundBrush}" />
                <Setter Property="CornerRadius" Value="{DynamicResource CornerRadius.Grid.RegionHeader}" />
                <Setter Property="Padding" Value="8,0,8,0" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
            </Style>
            <Style x:Key="PgGridRegionHeaderDockPanelStyle" TargetType="DockPanel">
                <Setter Property="MinHeight" Value="34" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Cursor" Value="SizeAll" />
                <Setter Property="ToolTip" Value="Drag region" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
            </Style>
            <Style x:Key="PgGridRegionDockPreviewZoneStyle" TargetType="Border">
                <Setter Property="Width" Value="148" />
                <Setter Property="Margin" Value="14" />
                <Setter Property="Background" Value="{DynamicResource PgSelectionBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource PgAccentBrush}" />
                <Setter Property="BorderThickness" Value="2" />
                <Setter Property="CornerRadius" Value="{DynamicResource CornerRadius.Grid.RegionSurface}" />
                <Setter Property="Opacity" Value="0.24" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
            </Style>
            <Style x:Key="PgGridRegionDockPreviewBandZoneStyle" TargetType="Border">
                <Setter Property="Height" Value="42" />
                <Setter Property="Margin" Value="14" />
                <Setter Property="Background" Value="{DynamicResource PgSelectionBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource PgAccentBrush}" />
                <Setter Property="BorderThickness" Value="2" />
                <Setter Property="CornerRadius" Value="{DynamicResource CornerRadius.Grid.RegionSurface}" />
                <Setter Property="Opacity" Value="0.24" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
            </Style>
            <Style x:Key="PgGridWorkspaceBandDragGripStyle" TargetType="Border">
                <Setter Property="Width" Value="20" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Margin" Value="0,0,8,0" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Cursor" Value="SizeAll" />
            </Style>
            <Style TargetType="{x:Type controls:PhialeWorkspaceBand}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type controls:PhialeWorkspaceBand}">
                            <Border
                                x:Name="WorkspaceBandShell"
                                Padding="{TemplateBinding BandPadding}"
                                Background="{TemplateBinding BandBackground}"
                                BorderBrush="{TemplateBinding BandBorderBrush}"
                                BorderThickness="{TemplateBinding BandBorderThickness}"
                                CornerRadius="{TemplateBinding BandCornerRadius}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Border
                                        x:Name="WorkspaceBandDragGrip"
                                        Grid.Column="0"
                                        LostMouseCapture="HandleRegionDragLostMouseCapture"
                                        PreviewMouseLeftButtonDown="HandleRegionDragMouseLeftButtonDown"
                                        PreviewMouseLeftButtonUp="HandleRegionDragMouseLeftButtonUp"
                                        PreviewMouseMove="HandleRegionDragMouseMove"
                                        Style="{StaticResource PgGridWorkspaceBandDragGripStyle}"
                                        Tag="{TemplateBinding Tag}">
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            FontWeight="Bold"
                                            Foreground="{DynamicResource PgMutedTextBrush}"
                                            Text="⋮⋮" />
                                    </Border>

                                    <ContentPresenter
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Content="{TemplateBinding Content}"
                                        ContentStringFormat="{TemplateBinding ContentStringFormat}"
                                        ContentTemplate="{TemplateBinding ContentTemplate}" />

                                    <StackPanel
                                        Grid.Column="2"
                                        Margin="{DynamicResource PgWorkspaceBandActionGroupMargin}"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">
                                        <Button
                                            x:Name="WorkspaceBandToggleButton"
                                            Click="HandleRegionToggleButtonClick"
                                            Content="{TemplateBinding ToggleText}"
                                            Style="{StaticResource PgRegionExpanderButtonStyle}"
                                            Tag="{TemplateBinding Tag}">
                                            <Button.Visibility>
                                                <Binding
                                                    Converter="{StaticResource BooleanToVisibilityConverter}"
                                                    Path="IsToggleVisible"
                                                    RelativeSource="{RelativeSource TemplatedParent}" />
                                            </Button.Visibility>
                                        </Button>
                                        <Button
                                            x:Name="WorkspaceBandCloseButton"
                                            Click="HandleRegionCloseButtonClick"
                                            Style="{StaticResource PgRegionCloseButtonStyle}"
                                            Tag="{TemplateBinding Tag}">
                                            <Button.Visibility>
                                                <Binding
                                                    Converter="{StaticResource BooleanToVisibilityConverter}"
                                                    Path="IsCloseVisible"
                                                    RelativeSource="{RelativeSource TemplatedParent}" />
                                            </Button.Visibility>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="PgRegionSplitterHorizontalStyle" TargetType="GridSplitter">
                <Setter Property="Height" Value="12" />
                <Setter Property="Background" Value="{DynamicResource PgGridRegionSurfaceBackgroundBrush}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="GridSplitter">
                            <Grid Background="{TemplateBinding Background}">
                                <Border
                                    Height="2"
                                    Margin="12,0"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource PgPanelBorderBrush}"
                                    Opacity="1" />
                                <Border
                                    Width="28"
                                    Height="12"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource PgSurfaceBrush}"
                                    BorderBrush="{DynamicResource PgPanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">
                                        <Border
                                            Width="2"
                                            Height="7"
                                            Margin="0,0,3,0"
                                            Background="{DynamicResource PgMutedTextBrush}"
                                            CornerRadius="1" />
                                        <Border
                                            Width="2"
                                            Height="7"
                                            Background="{DynamicResource PgMutedTextBrush}"
                                            CornerRadius="1" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="PgRegionSplitterVerticalStyle" TargetType="GridSplitter">
                <Setter Property="Width" Value="12" />
                <Setter Property="Background" Value="{DynamicResource PgGridRegionSurfaceBackgroundBrush}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="GridSplitter">
                            <Grid Background="{TemplateBinding Background}">
                                <Border
                                    Width="1"
                                    Margin="0,16"
                                    HorizontalAlignment="Center"
                                    Background="{DynamicResource PgPanelBorderBrush}"
                                    Opacity="0.85" />
                                <Border
                                    Width="10"
                                    Height="28"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource PgSurfaceBrush}"
                                    BorderBrush="{DynamicResource PgPanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="5">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Border
                                            Width="6"
                                            Height="2"
                                            Margin="0,0,0,3"
                                            Background="{DynamicResource PgMutedTextBrush}"
                                            CornerRadius="1" />
                                        <Border
                                            Width="6"
                                            Height="2"
                                            Background="{DynamicResource PgMutedTextBrush}"
                                            CornerRadius="1" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border x:Name="GridOuterFrame" Style="{StaticResource PgGridOuterFrameBorderStyle}">
        <Grid x:Name="GridRootFrame" Style="{StaticResource PgGridRegionSurfaceGridStyle}">
            <Grid.RowDefinitions>
                <RowDefinition Height="0" />
                <RowDefinition Height="0" />
                <RowDefinition x:Name="GroupingRegionRow" Height="Auto" />
                <RowDefinition x:Name="GroupingBandUtilityRow" Height="0" />
                <RowDefinition Height="*" />
                <RowDefinition x:Name="SummaryBottomRegionSplitterRow" Height="12" />
                <RowDefinition x:Name="SummaryBottomRegionRow" Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftWorkspacePanelColumn" Width="0" />
                <ColumnDefinition x:Name="LeftWorkspacePanelSplitterColumn" Width="0" />
                <ColumnDefinition x:Name="RegionSurfaceColumn" Width="*" />
                <ColumnDefinition x:Name="SideToolRegionSplitterColumn" Width="0" />
                <ColumnDefinition x:Name="SideToolRegionColumn" Width="0" />
            </Grid.ColumnDefinitions>

            <StackPanel
                x:Name="TopWorkspaceBandHost"
                Grid.Row="2"
                Grid.Column="2"
                Orientation="Vertical">
                <controls:PhialeWorkspaceBand
                    x:Name="GroupingRegionHost"
                    BandBackground="{DynamicResource PgPanelBackgroundBrush}"
                    BandBorderBrush="{DynamicResource PgPanelBorderBrush}"
                    BandBorderThickness="0,0,0,1"
                    BandPadding="{DynamicResource PgWorkspaceBandShellPadding}"
                    IsCloseVisible="{Binding ElementName=Root, Path=CanCloseGroupingRegion}"
                    IsToggleVisible="{Binding ElementName=Root, Path=CanCollapseGroupingRegion}"
                    Tag="GroupingRegion"
                    ToggleText="{Binding ElementName=Root, Path=GroupingRegionToggleText}">
                    <controls:PhialeGroupingBand
                        x:Name="GroupingBandContentHost"
                        AllowsGroupingDrag="{Binding ElementName=Root, Path=AllowsGroupingDrag}"
                        BandLabelText="{Binding ElementName=Root, Path=GroupingBandLabelText}"
                        CollapseAllGroupsRequested="HandleCollapseAllGroupsClick"
                        CollapseAllText="{Binding ElementName=Root, Path=GroupingCollapseAllText}"
                        ColumnDropped="HandleGroupingBandColumnDropped"
                        DragDataFormat="{Binding ElementName=Root, Path=GroupingDragDataFormat}"
                        DropText="{Binding ElementName=Root, Path=GroupingDropText}"
                        ExpandAllGroupsRequested="HandleExpandAllGroupsClick"
                        ExpandAllText="{Binding ElementName=Root, Path=GroupingExpandAllText}"
                        GroupChips="{Binding ElementName=Root, Path=GroupChips}"
                        HasGroups="{Binding ElementName=Root, Path=HasGroups}"
                        HasNoGroups="{Binding ElementName=Root, Path=HasNoGroups}"
                        RemoveGroupRequested="HandleGroupingBandRemoveGroupRequested"
                        ToggleDirectionRequested="HandleGroupingBandToggleDirectionRequested" />
                </controls:PhialeWorkspaceBand>
            </StackPanel>

            <Grid
                x:Name="RegionLayoutFrame"
                Grid.Row="4"
                Grid.Column="2"
                Style="{StaticResource PgGridRegionSurfaceGridStyle}">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="TopCommandStripRow" Height="0" />
                    <RowDefinition x:Name="TopCommandStripUtilityRow" Height="0" />
                    <RowDefinition Height="{Binding ElementName=Root, Path=SurfaceTopChromeHeight}" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <controls:PhialeWorkspaceBand
                    x:Name="TopCommandBand"
                    Grid.Row="0"
                    Grid.Column="0"
                    BandBackground="{DynamicResource PgGridRegionSurfaceBackgroundBrush}"
                    BandBorderBrush="{DynamicResource PgPanelBorderBrush}"
                    BandBorderThickness="0,0,0,1"
                    BandCornerRadius="{DynamicResource CornerRadius.Grid.RegionSurface}"
                    BandPadding="{DynamicResource PgWorkspaceBandShellPadding}"
                    IsCloseVisible="{Binding ElementName=Root, Path=CanCloseTopCommandStrip}"
                    IsToggleVisible="{Binding ElementName=Root, Path=CanToggleTopCommandStrip}"
                    Tag="TopCommandRegion"
                    ToggleText="{Binding ElementName=Root, Path=TopCommandStripToggleText}">
                    <ScrollViewer
                        x:Name="TopCommandStripContentHost"
                        VerticalAlignment="Center"
                        HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Disabled">
                        <ContentPresenter x:Name="TopCommandStripContentPresenter" Content="{Binding ElementName=Root, Path=TopCommandContent}" />
                    </ScrollViewer>
                </controls:PhialeWorkspaceBand>

                <Grid
                    x:Name="SurfaceTopViewportHost"
                    Grid.Row="2"
                    Grid.RowSpan="2"
                    Grid.Column="0"
                    Style="{StaticResource PgGridRegionSurfaceGridStyle}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{Binding ElementName=Root, Path=ResolvedRowHeaderWidth}" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="{Binding ElementName=Root, Path=SurfaceVerticalScrollBarGutterWidth}" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition x:Name="SurfaceHeaderBandRow" Height="{Binding ElementName=Root, Path=SurfaceColumnHeaderHeight}" />
                        <RowDefinition x:Name="SurfaceFilterRow" Height="{Binding ElementName=Root, Path=SurfaceFilterRowHeight}" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <surface:GridSurfaceHost
                        x:Name="SurfaceHost"
                        Grid.Row="2"
                        Grid.ColumnSpan="3" />

                    <Grid
                        x:Name="SurfaceTopChromeHost"
                        Grid.RowSpan="2"
                        Grid.ColumnSpan="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="{Binding ElementName=Root, Path=ResolvedRowHeaderWidth}" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="{Binding ElementName=Root, Path=SurfaceVerticalScrollBarGutterWidth}" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="{Binding ElementName=Root, Path=SurfaceColumnHeaderHeight}" />
                            <RowDefinition Height="{Binding ElementName=Root, Path=SurfaceFilterRowHeight}" />
                        </Grid.RowDefinitions>

                        <Border
                            x:Name="SurfaceHeaderBandHost"
                            Grid.Row="0"
                            Grid.Column="1"
                            Background="{x:Null}"
                            IsHitTestVisible="False" />
                        <surface:GridSurfaceColumnHeaderBand
                            x:Name="SurfaceColumnHeaderBand"
                            Grid.Row="0"
                            Grid.Column="1" />

                        <Border
                            x:Name="SurfaceHeaderCornerHost"
                            Grid.Row="0"
                            Grid.Column="0"
                            Background="{DynamicResource PgHeaderBackgroundBrush}"
                            BorderBrush="{DynamicResource PgHeaderBorderBrush}"
                            BorderThickness="{DynamicResource PgGridRowHeaderBorderThickness}"
                            IsHitTestVisible="True">
                            <Button
                                x:Name="SurfaceHeaderCornerButton"
                                Width="{Binding ElementName=Root, Path=ResolvedRowHeaderWidth}"
                                Height="{Binding ElementName=Root, Path=SurfaceColumnHeaderHeight}"
                                Padding="0"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                AutomationProperties.AutomationId="surface.grid-options-button"
                                Click="HandleGridOptionsButtonClick"
                                Style="{StaticResource PgGridCornerOptionsButtonStyle}">
                                <Path
                                    Width="14"
                                    Height="10"
                                    Data="M 1 1 L 13 1 M 1 5 L 13 5 M 1 9 L 13 9"
                                    Stretch="None"
                                    Stroke="{DynamicResource PgHeaderTextBrush}"
                                    StrokeEndLineCap="Round"
                                    StrokeStartLineCap="Round"
                                    StrokeThickness="1.6" />
                            </Button>
                        </Border>

                        <Border
                            x:Name="SurfaceHeaderRightInset"
                            Grid.Row="0"
                            Grid.Column="2"
                            Background="{DynamicResource PgHeaderBackgroundBrush}"
                            BorderBrush="{DynamicResource PgHeaderBorderBrush}"
                            BorderThickness="0,0,0,2"
                            IsHitTestVisible="False" />

                        <Grid
                            x:Name="SurfaceFilterRowHost"
                            Grid.Row="1"
                            Grid.ColumnSpan="3"
                            Style="{StaticResource PgFilterPanelVisibilityStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{Binding ElementName=Root, Path=ResolvedRowHeaderWidth}" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="{Binding ElementName=Root, Path=SurfaceVerticalScrollBarGutterWidth}" />
                            </Grid.ColumnDefinitions>

                            <Border
                                x:Name="FilterRowHeaderSpacer"
                                Grid.Column="0"
                                Background="{DynamicResource PgFilterRowBackgroundBrush}"
                                BorderBrush="{DynamicResource PgFilterRowBorderBrush}"
                                BorderThickness="{DynamicResource PgGridRowHeaderBorderThickness}">
                                <Path Data="F1 M 0 1 L 12 1 L 7.2 6.2 L 7.2 10.6 L 4.8 9.2 L 4.8 6.2 Z" Style="{StaticResource PgGridFilterIconPathStyle}" />
                            </Border>

                            <ScrollViewer
                                x:Name="FilterScrollViewer"
                                Grid.Column="1"
                                Grid.ColumnSpan="2"
                                Background="{DynamicResource PgFilterRowBackgroundBrush}"
                                CanContentScroll="False"
                                HorizontalScrollBarVisibility="Hidden"
                                VerticalScrollBarVisibility="Disabled">
                                <ItemsControl x:Name="FilterItemsControl" ItemsSource="{Binding ElementName=Root, Path=VisibleColumns}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border
                                                Width="{Binding Width}"
                                                Background="{DynamicResource PgFilterRowBackgroundBrush}"
                                                BorderBrush="{DynamicResource PgFilterRowBorderBrush}"
                                                BorderThickness="0,0,1,2">
                                                <Grid>
                                                    <TextBox
                                                        AutomationProperties.HelpText="{Binding ElementName=Root, Path=FilterLabelText}"
                                                        Style="{StaticResource PgGridFilterTextBoxStyle}"
                                                        Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" />
                                                    <Button
                                                        Width="{DynamicResource PgGridFilterClearButtonSize}"
                                                        Height="{DynamicResource PgGridFilterClearButtonSize}"
                                                        Margin="0,0,4,0"
                                                        Padding="0"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        Click="HandleClearFilterColumnClick"
                                                        Content="×"
                                                        FontSize="12"
                                                        FontWeight="Bold"
                                                        Foreground="{DynamicResource PgMutedTextBrush}"
                                                        Style="{StaticResource Button.Tertiary}"
                                                        Visibility="{Binding HasFilterText, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <Border
                                x:Name="SurfaceFilterRightInset"
                                Grid.Column="2"
                                BorderBrush="{DynamicResource PgFilterRowBorderBrush}"
                                BorderThickness="0,0,1,2"
                                IsHitTestVisible="False" />
                        </Grid>
                    </Grid>

                    <Border
                        Grid.Row="2"
                        Grid.ColumnSpan="3"
                        Background="{DynamicResource PgEmptyBackgroundBrush}"
                        BorderBrush="{DynamicResource PgEmptyBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Style="{StaticResource PgEmptyRowsBorderStyle}">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Foreground="{DynamicResource PgMutedTextBrush}"
                            Text="{Binding ElementName=Root, Path=EmptyNoRowsText}" />
                    </Border>
                </Grid>
            </Grid>

            <GridSplitter
                x:Name="SideToolRegionSplitter"
                Grid.Row="2"
                Grid.RowSpan="5"
                Grid.Column="3"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                DragCompleted="HandleRegionSplitterDragCompleted"
                ResizeBehavior="PreviousAndNext"
                ResizeDirection="Columns"
                ShowsPreview="True"
                Style="{StaticResource PgRegionSplitterVerticalStyle}"
                Tag="SideToolRegion" />

            <Grid
                x:Name="SideToolRegionHost"
                Grid.Row="2"
                Grid.RowSpan="5"
                Grid.Column="4"
                Style="{StaticResource PgGridRegionSurfaceGridStyle}">
                <controls:PhialeWorkspacePanel x:Name="ToolsPanel" Style="{StaticResource PgGridRegionSurfaceGridStyle}">
                    <Border
                        x:Name="SideToolRegionCollapsedRail"
                        Margin="8,0,0,0"
                        Style="{StaticResource PgWorkspacePanelCollapsedRailBorderStyle}"
                        Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Button
                                Margin="0,10,0,0"
                                HorizontalAlignment="Center"
                                Click="HandleRegionToggleButtonClick"
                                Content="{Binding ElementName=Root, Path=SideToolRegionToggleText}"
                                Style="{StaticResource PgRegionExpanderButtonStyle}"
                                Tag="SideToolRegion" />
                            <StackPanel Grid.Row="1" Style="{StaticResource PgWorkspacePanelCollapsedRailTabStackStyle}">
                                <Button
                                    x:Name="ToolsRailToolsTabButton"
                                    Click="HandleOpenWorkspacePanelTabClick"
                                    Style="{StaticResource PgWorkspacePanelCollapsedRailActiveTabButtonStyle}"
                                    Tag="SideToolRegion"
                                    Visibility="{Binding ElementName=Root, Path=ToolsPanelToolsTabVisibility}">
                                    <TextBlock Text="{Binding ElementName=Root, Path=ToolsRegionTitleText}">
                                        <TextBlock.LayoutTransform>
                                            <RotateTransform Angle="90" />
                                        </TextBlock.LayoutTransform>
                                    </TextBlock>
                                </Button>
                                <Button
                                    x:Name="ToolsRailChangesTabButton"
                                    Click="HandleOpenWorkspacePanelTabClick"
                                    Style="{StaticResource PgWorkspacePanelCollapsedRailTabButtonStyle}"
                                    Tag="ChangePanelRegion"
                                    Visibility="{Binding ElementName=Root, Path=ToolsPanelChangesTabVisibility}">
                                    <TextBlock Text="{Binding ElementName=Root, Path=ChangePanelTitleText}">
                                        <TextBlock.LayoutTransform>
                                            <RotateTransform Angle="90" />
                                        </TextBlock.LayoutTransform>
                                    </TextBlock>
                                </Button>
                                <Button
                                    x:Name="ToolsRailValidationTabButton"
                                    Click="HandleOpenWorkspacePanelTabClick"
                                    Style="{StaticResource PgWorkspacePanelCollapsedRailTabButtonStyle}"
                                    Tag="ValidationPanelRegion"
                                    Visibility="{Binding ElementName=Root, Path=ToolsPanelValidationTabVisibility}">
                                    <TextBlock Text="{Binding ElementName=Root, Path=ValidationPanelTitleText}">
                                        <TextBlock.LayoutTransform>
                                            <RotateTransform Angle="90" />
                                        </TextBlock.LayoutTransform>
                                    </TextBlock>
                                </Button>
                                <Button
                                    x:Name="ToolsRailSummaryDesignerTabButton"
                                    Click="HandleOpenWorkspacePanelTabClick"
                                    Style="{StaticResource PgWorkspacePanelCollapsedRailTabButtonStyle}"
                                    Tag="SummaryDesignerRegion"
                                    Visibility="{Binding ElementName=Root, Path=ToolsPanelSummaryDesignerTabVisibility}">
                                    <TextBlock Text="{Binding ElementName=Root, Path=SummaryDesignerTitleText}">
