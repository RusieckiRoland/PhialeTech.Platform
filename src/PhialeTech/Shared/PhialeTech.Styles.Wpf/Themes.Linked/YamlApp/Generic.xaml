<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:abstractions="clr-namespace:PhialeTech.YamlApp.Abstractions.Enums;assembly=PhialeTech.YamlApp.Abstractions"
    xmlns:document="clr-namespace:PhialeTech.YamlApp.Wpf.Document"
    xmlns:actions="clr-namespace:PhialeTech.YamlApp.Wpf.Controls.Actions"
    xmlns:badges="clr-namespace:PhialeTech.YamlApp.Wpf.Controls.Badges"
    xmlns:buttons="clr-namespace:PhialeTech.YamlApp.Wpf.Controls.Buttons"
    xmlns:local="clr-namespace:PhialeTech.YamlApp.Wpf.Controls.TextBox"
    xmlns:localInteger="clr-namespace:PhialeTech.YamlApp.Wpf.Controls.IntegerBox">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/PhialeTech.Styles.Wpf;component/Themes/Controls.Core.xaml" />
        <ResourceDictionary Source="pack://application:,,,/PhialeTech.Styles.Wpf;component/Themes/YamlApp.Styles.xaml" />
        <ResourceDictionary Source="pack://application:,,,/PhialeTech.YamlApp.Wpf;component/Themes/YamlApp.ControlStyles.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <local:FieldWidthTokenDefinition x:Key="FieldWidth.Short"
                                     MinWidth="80"
                                     PreferredWidth="120"
                                     MaxWidth="160"
                                     Stretch="False" />
    <local:FieldWidthTokenDefinition x:Key="FieldWidth.Medium"
                                     MinWidth="140"
                                     PreferredWidth="220"
                                     MaxWidth="320"
                                     Stretch="False" />
    <local:FieldWidthTokenDefinition x:Key="FieldWidth.Long"
                                     MinWidth="220"
                                     PreferredWidth="360"
                                     MaxWidth="520"
                                     Stretch="False" />
    <local:FieldWidthTokenDefinition x:Key="FieldWidth.Fill"
                                     MinWidth="220"
                                     PreferredWidth="360"
                                     Stretch="True" />

    <Style TargetType="{x:Type document:YamlDocumentHost}" BasedOn="{StaticResource {x:Type ContentControl}}">
        <Setter Property="Background" Value="{DynamicResource Brush.FormShell.ContentBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
    </Style>

    <Style TargetType="{x:Type badges:YamlBadge}">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Badge.Text}" />
        <Setter Property="Background" Value="{DynamicResource Brush.Badge.Fill}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Badge.Border}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type badges:YamlBadge}">
                    <Grid MinHeight="{TemplateBinding ChromeMinHeight}"
                          SnapsToDevicePixels="True"
                          UseLayoutRounding="True">
                        <badges:YamlBadgeSkiaChromePresenter x:Name="PART_ChromePresenter"
                                                             BackgroundBrush="{TemplateBinding Background}"
                                                             BorderBrush="{TemplateBinding BorderBrush}"
                                                             CornerRadius="{TemplateBinding ChromeCornerRadius}" />
                        <DockPanel Margin="{TemplateBinding ChromePadding}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   LastChildFill="False">
                            <TextBlock x:Name="BadgeLeadingIcon"
                                       Margin="{TemplateBinding ChromeIconMargin}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding ChromeIconSize}"
                                       Style="{StaticResource YamlBadge.IconStyle}"
                                       Text="{TemplateBinding IconGlyph}" />
                            <TextBlock x:Name="BadgeText"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding ChromeFontSize}"
                                       Style="{StaticResource YamlBadge.TextStyle}"
                                       Text="{TemplateBinding Text}" />
                        </DockPanel>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IconPlacement" Value="{x:Static abstractions:IconPlacement.Trailing}">
                            <Setter TargetName="BadgeLeadingIcon" Property="DockPanel.Dock" Value="Right" />
                        </Trigger>
                        <Trigger Property="Tone" Value="{x:Static abstractions:BadgeTone.Accent}">
                            <Setter Property="Background" Value="{DynamicResource Brush.Badge.Accent.Fill}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Badge.Accent.Border}" />
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Badge.Accent.Text}" />
                        </Trigger>
                        <Trigger Property="Tone" Value="{x:Static abstractions:BadgeTone.Warning}">
                            <Setter Property="Background" Value="{DynamicResource Brush.Badge.Warning.Fill}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Badge.Warning.Border}" />
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Badge.Warning.Text}" />
                        </Trigger>
                        <Trigger Property="Tone" Value="{x:Static abstractions:BadgeTone.Danger}">
                            <Setter Property="Background" Value="{DynamicResource Brush.Badge.Danger.Fill}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Badge.Danger.Border}" />
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Badge.Danger.Text}" />
                        </Trigger>
                        <Trigger Property="Variant" Value="{x:Static abstractions:BadgeVariant.Outline}">
                            <Setter Property="Background" Value="{DynamicResource Brush.Badge.Outline.Fill}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Badge.Outline.Border}" />
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Badge.Outline.Text}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Variant" Value="{x:Static abstractions:BadgeVariant.Outline}" />
                                <Condition Property="Tone" Value="{x:Static abstractions:BadgeTone.Accent}" />
                            </MultiTrigger.Conditions>
                            <Setter Property="Background" Value="{DynamicResource Brush.Badge.Accent.Outline.Fill}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Badge.Accent.Outline.Border}" />
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Badge.Accent.Outline.Text}" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Variant" Value="{x:Static abstractions:BadgeVariant.Outline}" />
                                <Condition Property="Tone" Value="{x:Static abstractions:BadgeTone.Warning}" />
                            </MultiTrigger.Conditions>
                            <Setter Property="Background" Value="{DynamicResource Brush.Badge.Warning.Outline.Fill}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Badge.Warning.Outline.Border}" />
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Badge.Warning.Outline.Text}" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Variant" Value="{x:Static abstractions:BadgeVariant.Outline}" />
                                <Condition Property="Tone" Value="{x:Static abstractions:BadgeTone.Danger}" />
                            </MultiTrigger.Conditions>
                            <Setter Property="Background" Value="{DynamicResource Brush.Badge.Danger.Outline.Fill}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Badge.Danger.Outline.Border}" />
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Badge.Danger.Outline.Text}" />
                        </MultiTrigger>
                        <Trigger Property="IconGlyph" Value="">
                            <Setter TargetName="BadgeLeadingIcon" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.72" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type buttons:YamlButton}" BasedOn="{StaticResource YamlButton.DefaultStyle}" />

    <Style TargetType="{x:Type actions:YamlDocumentActionAreaHost}">
        <Setter Property="Margin" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type actions:YamlDocumentActionAreaHost}">
                    <Grid x:Name="ActionAreaRoot"
                          MinHeight="62"
                          SnapsToDevicePixels="True"
                          UseLayoutRounding="True">
                        <actions:YamlDocumentActionAreaSkiaChromePresenter x:Name="ActionAreaChrome"
                                                                           BackgroundBrush="{DynamicResource Brush.FormShell.ContentBackground}"
                                                                           BorderBrush="{DynamicResource Brush.FormShell.RegionBorder}"
                                                                           CornerRadius="14" />
                        <ContentPresenter x:Name="ActionAreaContent"
                                          Margin="12"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Placement" Value="{x:Static abstractions:ActionPlacement.Top}">
                            <Setter TargetName="ActionAreaChrome" Property="BackgroundBrush" Value="{DynamicResource Brush.FormShell.TopActionBackground}" />
                            <Setter TargetName="ActionAreaChrome" Property="BorderBrush" Value="{DynamicResource Brush.FormShell.RegionBorder}" />
                        </Trigger>
                        <Trigger Property="Placement" Value="{x:Static abstractions:ActionPlacement.Bottom}">
                            <Setter TargetName="ActionAreaChrome" Property="BackgroundBrush" Value="{DynamicResource Brush.FormShell.BottomActionBackground}" />
                            <Setter TargetName="ActionAreaChrome" Property="BorderBrush" Value="{DynamicResource Brush.FormShell.RegionBorder}" />
                        </Trigger>
                        <Trigger Property="ChromeMode" Value="{x:Static abstractions:ActionAreaChromeMode.Blended}">
                            <Setter TargetName="ActionAreaChrome" Property="BackgroundBrush" Value="Transparent" />
                            <Setter TargetName="ActionAreaChrome" Property="BorderBrush" Value="Transparent" />
                            <Setter TargetName="ActionAreaChrome" Property="CornerRadius" Value="10" />
                            <Setter TargetName="ActionAreaContent" Property="Margin" Value="0" />
                            <Setter TargetName="ActionAreaRoot" Property="MinHeight" Value="44" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSticky" Value="True" />
                                <Condition Property="Placement" Value="{x:Static abstractions:ActionPlacement.Top}" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="ActionAreaChrome" Property="CornerRadius" Value="14,14,0,0" />
                            <Setter TargetName="ActionAreaContent" Property="Margin" Value="12,12,12,16" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSticky" Value="True" />
                                <Condition Property="Placement" Value="{x:Static abstractions:ActionPlacement.Bottom}" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="ActionAreaChrome" Property="CornerRadius" Value="0,0,14,14" />
                            <Setter TargetName="ActionAreaContent" Property="Margin" Value="12,16,12,12" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="ChromeMode" Value="{x:Static abstractions:ActionAreaChromeMode.Blended}" />
                                <Condition Property="IsSticky" Value="True" />
                                <Condition Property="Placement" Value="{x:Static abstractions:ActionPlacement.Top}" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="ActionAreaChrome" Property="CornerRadius" Value="10" />
                            <Setter TargetName="ActionAreaContent" Property="Margin" Value="0,0,0,4" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="ChromeMode" Value="{x:Static abstractions:ActionAreaChromeMode.Blended}" />
                                <Condition Property="IsSticky" Value="True" />
                                <Condition Property="Placement" Value="{x:Static abstractions:ActionPlacement.Bottom}" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="ActionAreaChrome" Property="CornerRadius" Value="10" />
                            <Setter TargetName="ActionAreaContent" Property="Margin" Value="0" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type actions:YamlDocumentActionButton}" BasedOn="{StaticResource YamlButton.DefaultStyle}">
        <Setter Property="Margin" Value="0" />
        <Setter Property="Variant" Value="{x:Static abstractions:ButtonVariant.ActionStrip}" />
    </Style>

    <Style x:Key="YamlTextBox.ClearButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="TrailingActionButtonHost"
                            Background="Transparent"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}"
                            SnapsToDevicePixels="True">
                        <Border x:Name="TrailingActionButtonChrome"
                                Width="15"
                                Height="15"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="4"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                SnapsToDevicePixels="True"
                                UseLayoutRounding="True">
                            <Path x:Name="ClearGlyph"
                                  Width="9"
                                  Height="9"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Stroke="{TemplateBinding Foreground}"
                                  StrokeThickness="1.2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Stretch="Uniform"
                                  SnapsToDevicePixels="True"
                                  Data="M 1 1 L 8 8 M 8 1 L 1 8" />
                        </Border>
                    </Border>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsKeyboardFocusWithin, RelativeSource={RelativeSource AncestorType={x:Type local:YamlTextBox}}}" Value="True">
                            <Setter TargetName="ClearGlyph" Property="Stroke" Value="{DynamicResource Brush.Focus.Ring}" />
                            <Setter TargetName="ClearGlyph" Property="StrokeThickness" Value="1.35" />
                        </DataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                <Condition Binding="{Binding InteractionMode, RelativeSource={RelativeSource AncestorType={x:Type local:YamlTextBox}}}" Value="{x:Static abstractions:InteractionMode.Classic}" />
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="TrailingActionButtonChrome" Property="Background" Value="{DynamicResource Brush.Hover.Fill}" />
                            <Setter TargetName="TrailingActionButtonChrome" Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
                            <Setter TargetName="ClearGlyph" Property="Stroke" Value="{DynamicResource Brush.Text.Primary}" />
                            <Setter TargetName="ClearGlyph" Property="StrokeThickness" Value="1.3" />
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsKeyboardFocusWithin, RelativeSource={RelativeSource AncestorType={x:Type local:YamlTextBox}}}" Value="True" />
                                <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                <Condition Binding="{Binding InteractionMode, RelativeSource={RelativeSource AncestorType={x:Type local:YamlTextBox}}}" Value="{x:Static abstractions:InteractionMode.Classic}" />
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="TrailingActionButtonChrome" Property="Background" Value="{DynamicResource Brush.Hover.Fill}" />
                            <Setter TargetName="TrailingActionButtonChrome" Property="BorderBrush" Value="{DynamicResource Brush.Focus.Ring}" />
                            <Setter TargetName="ClearGlyph" Property="Stroke" Value="{DynamicResource Brush.Focus.Ring}" />
                            <Setter TargetName="ClearGlyph" Property="StrokeThickness" Value="1.45" />
                        </MultiDataTrigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="TrailingActionButtonChrome" Property="Background" Value="{DynamicResource Brush.Hover.Fill}" />
                            <Setter TargetName="TrailingActionButtonChrome" Property="BorderBrush" Value="{DynamicResource Brush.Focus.Ring}" />
                            <Setter TargetName="ClearGlyph" Property="Stroke" Value="{DynamicResource Brush.Focus.Ring}" />
                            <Setter TargetName="ClearGlyph" Property="StrokeThickness" Value="1.45" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="TrailingActionButtonHost" Property="Opacity" Value="0.6" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="YamlTextBox.RestoreButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource YamlTextBox.ClearButtonStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="TrailingActionButtonHost"
                            Background="Transparent"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}"
                            SnapsToDevicePixels="True">
                        <Border x:Name="TrailingActionButtonChrome"
                                Width="15"
                                Height="15"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="4"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                SnapsToDevicePixels="True"
                                UseLayoutRounding="True">
                            <Path x:Name="RestoreGlyph"
                                  Width="10"
                                  Height="10"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Stroke="{TemplateBinding Foreground}"
                                  StrokeThickness="1.35"
                                  StrokeLineJoin="Round"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Stretch="Uniform"
                                  SnapsToDevicePixels="True"
                                  Data="M 3.7 1.6 L 1.6 3.7 L 3.7 5.8 M 1.6 3.7 H 5.6 C 7.0 3.7 8.1 4.8 8.1 6.2 C 8.1 7.3 7.2 8.2 6.1 8.2 H 4.8" />
                        </Border>
                    </Border>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsKeyboardFocusWithin, RelativeSource={RelativeSource AncestorType={x:Type local:YamlTextBox}}}" Value="True">
                            <Setter TargetName="RestoreGlyph" Property="Stroke" Value="{DynamicResource Brush.Focus.Ring}" />
                            <Setter TargetName="RestoreGlyph" Property="StrokeThickness" Value="1.35" />
                        </DataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                <Condition Binding="{Binding InteractionMode, RelativeSource={RelativeSource AncestorType={x:Type local:YamlTextBox}}}" Value="{x:Static abstractions:InteractionMode.Classic}" />
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="TrailingActionButtonChrome" Property="Background" Value="{DynamicResource Brush.Hover.Fill}" />
                            <Setter TargetName="TrailingActionButtonChrome" Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
                            <Setter TargetName="RestoreGlyph" Property="Stroke" Value="{DynamicResource Brush.Text.Primary}" />
                            <Setter TargetName="RestoreGlyph" Property="StrokeThickness" Value="1.3" />
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsKeyboardFocusWithin, RelativeSource={RelativeSource AncestorType={x:Type local:YamlTextBox}}}" Value="True" />
                                <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                <Condition Binding="{Binding InteractionMode, RelativeSource={RelativeSource AncestorType={x:Type local:YamlTextBox}}}" Value="{x:Static abstractions:InteractionMode.Classic}" />
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="TrailingActionButtonChrome" Property="Background" Value="{DynamicResource Brush.Hover.Fill}" />
                            <Setter TargetName="TrailingActionButtonChrome" Property="BorderBrush" Value="{DynamicResource Brush.Focus.Ring}" />
                            <Setter TargetName="RestoreGlyph" Property="Stroke" Value="{DynamicResource Brush.Focus.Ring}" />
                            <Setter TargetName="RestoreGlyph" Property="StrokeThickness" Value="1.45" />
                        </MultiDataTrigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="TrailingActionButtonChrome" Property="Background" Value="{DynamicResource Brush.Hover.Fill}" />
                            <Setter TargetName="TrailingActionButtonChrome" Property="BorderBrush" Value="{DynamicResource Brush.Focus.Ring}" />
                            <Setter TargetName="RestoreGlyph" Property="Stroke" Value="{DynamicResource Brush.Focus.Ring}" />
                            <Setter TargetName="RestoreGlyph" Property="StrokeThickness" Value="1.45" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="TrailingActionButtonHost" Property="Opacity" Value="0.6" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:YamlTextBox}">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        <Setter Property="Background" Value="{DynamicResource Brush.Surface1}" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        <Setter Property="TextOptions.TextRenderingMode" Value="Auto" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:YamlTextBox}">
                    <Grid MinHeight="{TemplateBinding MinHeight}"
                          SnapsToDevicePixels="True"
                          UseLayoutRounding="True">
                        <local:YamlTextBoxSkiaChromePresenter x:Name="PART_ChromePresenter"
                                                              SurfaceBrush="{DynamicResource Brush.Surface1}"
                                                              BackgroundBrush="{DynamicResource Brush.Surface0}"
                                                              BorderBrush="{DynamicResource Brush.Border.Default}"
                                                              FocusBrush="{DynamicResource Brush.Focus.Ring}"
                                                              DangerFillBrush="{DynamicResource Brush.Danger.Fill}"
                                                              DangerBorderBrush="{DynamicResource Brush.Danger.Border}"
                                                              CaptionBrush="{DynamicResource Brush.Text.Primary}"
                                                              SupportBrush="{DynamicResource Brush.Text.Secondary}"
                                                              DangerTextBrush="{DynamicResource Brush.Danger.Text}"
                                                              PlaceholderBrush="{DynamicResource Brush.Text.Muted}"
                                                              CaptionFontFamily="{DynamicResource YamlTextBox.Caption.FontFamily}"
                                                              CaptionFontSize="{DynamicResource YamlTextBox.Caption.FontSize}"
                                                              SupportFontFamily="{DynamicResource YamlTextBox.Support.FontFamily}"
                                                              SupportFontSize="{DynamicResource YamlTextBox.Support.FontSize}"
                                                              EditorFontFamily="{DynamicResource YamlTextBox.Editor.FontFamily}"
                                                              EditorFontSize="{DynamicResource YamlTextBox.Framed.Editor.FontSize}"
                                                              CardCornerRadius="{DynamicResource YamlTextBox.Card.CornerRadius}"
                                                              InputCornerRadius="{DynamicResource YamlTextBox.Input.CornerRadius}" />

                        <Grid Margin="{TemplateBinding EditorMargin}"
                              SnapsToDevicePixels="True"
                              UseLayoutRounding="True">
                            <TextBox x:Name="PART_Editor"
                                     MinHeight="24"
                                     VerticalAlignment="Stretch"
                                     HorizontalAlignment="Stretch"
                                     Template="{DynamicResource ChromeHostedTextBoxTemplate}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="{TemplateBinding EditorPadding}"
                                     FocusVisualStyle="{x:Null}"
                                     VerticalContentAlignment="Center"
                                     SnapsToDevicePixels="True"
                                     UseLayoutRounding="True"
                                     TextOptions.TextFormattingMode="Display"
                                     TextOptions.TextRenderingMode="Auto"
                                     CaretBrush="{DynamicResource Brush.Text.Primary}"
                                     Foreground="{TemplateBinding Foreground}"
                                     FontFamily="{DynamicResource YamlTextBox.Editor.FontFamily}"
                                     FontSize="{DynamicResource YamlTextBox.Framed.Editor.FontSize}"
                                     IsEnabled="{TemplateBinding IsEnabled}"
                                     IsReadOnly="{TemplateBinding IsReadOnly}" />

                            <Button x:Name="PART_ClearButton"
                                    Width="{TemplateBinding ClearButtonWidth}"
                                    Height="{TemplateBinding ClearButtonHeight}"
                                    Margin="{TemplateBinding ClearButtonMargin}"
                                    IsTabStop="False"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    SnapsToDevicePixels="True"
                                    UseLayoutRounding="True"
                                    Visibility="{TemplateBinding ClearButtonVisibility}"
                                    Style="{StaticResource YamlTextBox.ClearButtonStyle}" />

                            <Button x:Name="PART_RestoreButton"
                                    Width="{TemplateBinding ClearButtonWidth}"
                                    Height="{TemplateBinding ClearButtonHeight}"
                                    Margin="{TemplateBinding ClearButtonMargin}"
                                    IsTabStop="False"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    SnapsToDevicePixels="True"
                                    UseLayoutRounding="True"
                                    Visibility="{TemplateBinding RestoreButtonVisibility}"
                                    Style="{StaticResource YamlTextBox.RestoreButtonStyle}" />
                        </Grid>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="PART_Editor" Property="Foreground" Value="{DynamicResource Brush.Text.Muted}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type localInteger:YamlIntegerBox}"
           BasedOn="{StaticResource {x:Type local:YamlTextBox}}" />
</ResourceDictionary>
