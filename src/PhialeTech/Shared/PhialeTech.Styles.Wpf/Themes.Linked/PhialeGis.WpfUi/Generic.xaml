<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:PhialeGis.Library.WpfUi.Controls"
    xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf">

    <!--  PhialeDrawBox (jak masz)  -->
    <Style TargetType="{x:Type local:PhialeDrawBox}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:PhialeDrawBox}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!--  Background  -->
                        <Border
                            Grid.RowSpan="3"
                            Grid.ColumnSpan="2"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}" />

                        <!--  Skia surface  -->
                        <skia:SKElement
                            x:Name="SkiaCanvas"
                            Grid.Row="0"
                            Grid.Column="0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch" />

                        <!--  Scrollbars  -->
                        <ScrollBar
                            x:Name="ScrollBarVertical"
                            Grid.Row="0"
                            Grid.Column="1"
                            Maximum="100"
                            Minimum="0"
                            Orientation="Vertical"
                            ViewportSize="10"
                            Visibility="{TemplateBinding VerticalScrollBarVisible}" />

                        <Border
                            Grid.Row="1"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Padding="8,4"
                            Background="#F5F7FA"
                            BorderBrush="#D7DEE7"
                            BorderThickness="0,1,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel
                                    Grid.Column="0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                                    <TextBlock
                                        x:Name="PART_StatusPrimaryText"
                                        Margin="0,0,12,0"
                                        Foreground="#1E2A3A" />
                                    <TextBlock
                                        x:Name="PART_StatusCoordinateText"
                                        Margin="0,0,12,0"
                                        Foreground="#475467" />
                                    <TextBlock
                                        x:Name="PART_StatusSnapText"
                                        Foreground="#B54708" />
                                </StackPanel>
                                <StackPanel
                                    Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                                    <Button
                                        x:Name="PART_TakeoverButton"
                                        Margin="0,0,8,0"
                                        MinWidth="44"
                                        Padding="10,4"
                                        Visibility="Collapsed" />
                                    <Button
                                        x:Name="PART_UndoButton"
                                        Margin="0,0,8,0"
                                        MinWidth="44"
                                        Padding="10,4"
                                        Visibility="Collapsed" />
                                    <Button
                                        x:Name="PART_FinishButton"
                                        Margin="0,0,8,0"
                                        MinWidth="44"
                                        Padding="10,4"
                                        Visibility="Collapsed" />
                                    <Button
                                        x:Name="PART_CancelButton"
                                        MinWidth="44"
                                        Padding="10,4"
                                        Visibility="Collapsed" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <ScrollBar
                            x:Name="ScrollBarHorizontal"
                            Grid.Row="2"
                            Grid.Column="0"
                            Maximum="100"
                            Minimum="0"
                            Orientation="Horizontal"
                            ViewportSize="10"
                            Visibility="{TemplateBinding HorizontalScrollBarVisible}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  === PhialeDslEditor (WebView2 WPF) ===  -->
    <Style TargetType="{x:Type local:PhialeDslEditor}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:PhialeDslEditor}">
                    <Grid Background="{TemplateBinding Background}">
                        <Grid
                            x:Name="WebHost"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch">
                            <wv2:WebView2
                                x:Name="PART_WebView2"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch" />
                        </Grid>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
