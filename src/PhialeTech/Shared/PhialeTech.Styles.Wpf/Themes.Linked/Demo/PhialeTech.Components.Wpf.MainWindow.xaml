                                                                       TextWrapping="Wrap" />
                                                            <WrapPanel>
                                                                <yamlButton:YamlButton Margin="0,0,8,8"
                                                                                       Content="View compact modal"
                                                                                       IconKey="document"
                                                                                       Variant="ActionStrip"
                                                                                       CommandId="demo.modal.view.compact"
                                                                                       ToolTip="Open a hosted WPF view inside a compact modal"
                                                                                       Invoked="HandleHostedModalButtonInvoked" />
                                                                <yamlButton:YamlButton Margin="0,0,8,8"
                                                                                       Content="View overlay sheet"
                                                                                       IconKey="history"
                                                                                       Variant="ActionStrip"
                                                                                       CommandId="demo.modal.view.sheet"
                                                                                       ToolTip="Open a hosted WPF view inside an overlay sheet"
                                                                                       Invoked="HandleHostedModalButtonInvoked" />
                                                                <yamlButton:YamlButton Margin="0,0,8,8"
                                                                                       Content="Yaml compact modal"
                                                                                       IconKey="draft"
                                                                                       Variant="ActionStrip"
