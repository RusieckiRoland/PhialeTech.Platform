                                            <Border Style="{StaticResource FoundationsSectionBorderStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding ApplicationStateManagerIntroTitle}"
                                                               Style="{StaticResource SectionHeadlineStyle}" />
                                                    <TextBlock Text="{Binding ApplicationStateManagerIntroDescription}"
                                                               FontSize="14"
                                                               Foreground="{DynamicResource DemoSecondaryTextBrush}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>

                                            <Grid Margin="0,16,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="0.98*" />
                                                    <ColumnDefinition Width="1.02*" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0"
                                                            Margin="0,0,16,0">
                                                    <Border Style="{StaticResource FoundationsSectionBorderStyle}">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding ApplicationStateManagerResponsibilitiesTitle}"
                                                                       Style="{StaticResource SectionHeadlineStyle}" />
                                                            <ItemsControl Margin="0,14,0,0"
                                                                          ItemsSource="{Binding ApplicationStateManagerResponsibilities}"
                                                                          ItemTemplate="{StaticResource DefinitionManagerBulletTemplate}" />
                                                            <TextBlock Margin="0,10,0,0"
                                                                       Text="{Binding ApplicationStateManagerOutOfScopeTitle}"
                                                                       FontSize="13"
                                                                       FontFamily="Bahnschrift SemiBold"
                                                                       Foreground="{DynamicResource DemoHeaderTextBrush}" />
                                                            <ItemsControl Margin="0,10,0,0"
                                                                          ItemsSource="{Binding ApplicationStateManagerOutOfScope}"
                                                                          ItemTemplate="{StaticResource DefinitionManagerBulletTemplate}" />
                                                            <Border Margin="0,12,0,0"
                                                                    Padding="14"
                                                                    Background="{DynamicResource DemoTokenBackgroundBrush}"
                                                                    BorderBrush="{DynamicResource DemoTokenBorderBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="10">
                                                                <StackPanel>
                                                                    <Grid Margin="0,0,0,8">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="132" />
                                                                            <ColumnDefinition Width="*" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Text="{Binding ApplicationStateManagerFieldSharedManager}"
                                                                                   FontSize="11"
                                                                                   FontFamily="Bahnschrift SemiBold"
                                                                                   Foreground="{DynamicResource DemoHeaderTextBrush}" />
                                                                        <TextBlock Grid.Column="1"
                                                                                   Margin="12,0,0,0"
                                                                                   Text="{Binding ApplicationStateManagerSharedManagerValue}"
                                                                                   FontSize="12"
                                                                                   Foreground="{DynamicResource DemoPrimaryTextBrush}"
                                                                                   TextWrapping="Wrap" />
                                                                    </Grid>
                                                                    <Grid Margin="0,0,0,8">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="132" />
                                                                            <ColumnDefinition Width="*" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Text="{Binding ApplicationStateManagerFieldStateKey}"
                                                                                   FontSize="11"
                                                                                   FontFamily="Bahnschrift SemiBold"
                                                                                   Foreground="{DynamicResource DemoHeaderTextBrush}" />
                                                                        <TextBlock Grid.Column="1"
                                                                                   Margin="12,0,0,0"
                                                                                   Text="{Binding ApplicationStateManagerStateKey}"
                                                                                   FontSize="12"
                                                                                   Foreground="{DynamicResource DemoPrimaryTextBrush}"
                                                                                   TextWrapping="Wrap" />
                                                                    </Grid>
                                                                    <Grid Margin="0,0,0,8">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="132" />
                                                                            <ColumnDefinition Width="*" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Text="{Binding ApplicationStateManagerFieldRestoreBehavior}"
                                                                                   FontSize="11"
                                                                                   FontFamily="Bahnschrift SemiBold"
                                                                                   Foreground="{DynamicResource DemoHeaderTextBrush}" />
                                                                        <TextBlock Grid.Column="1"
                                                                                   Margin="12,0,0,0"
                                                                                   Text="{Binding ApplicationStateManagerRestoreBehaviorValue}"
                                                                                   FontSize="12"
                                                                                   Foreground="{DynamicResource DemoPrimaryTextBrush}"
                                                                                   TextWrapping="Wrap" />
                                                                    </Grid>
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="132" />
                                                                            <ColumnDefinition Width="*" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Text="{Binding ApplicationStateManagerFieldSaveBehavior}"
                                                                                   FontSize="11"
                                                                                   FontFamily="Bahnschrift SemiBold"
                                                                                   Foreground="{DynamicResource DemoHeaderTextBrush}" />
                                                                        <TextBlock Grid.Column="1"
                                                                                   Margin="12,0,0,0"
                                                                                   Text="{Binding ApplicationStateManagerSaveBehaviorValue}"
                                                                                   FontSize="12"
                                                                                   Foreground="{DynamicResource DemoPrimaryTextBrush}"
                                                                                   TextWrapping="Wrap" />
                                                                    </Grid>
                                                                </StackPanel>
                                                            </Border>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1">
                                                    <Border Style="{StaticResource FoundationsSectionBorderStyle}">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding ApplicationStateManagerCooperationTitle}"
                                                                       Style="{StaticResource SectionHeadlineStyle}" />
                                                            <TextBlock Margin="0,0,0,14"
                                                                       Text="{Binding ApplicationStateManagerCooperationDescription}"
                                                                       FontSize="13"
                                                                       Foreground="{DynamicResource DemoSecondaryTextBrush}"
                                                                       TextWrapping="Wrap" />

                                                            <Border Padding="14"
                                                                    Background="{DynamicResource DemoPanelBackgroundBrush}"
                                                                    BorderBrush="{DynamicResource DemoPanelBorderBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="10">
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding ApplicationStateManagerSampleDefinition.Title}"
