                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="*" />
                                                                                <ColumnDefinition Width="Auto" />
                                                                            </Grid.ColumnDefinitions>
                                                                            <TextBlock Text="TopActionBackground"
                                                                                       FontSize="12"
                                                                                       FontWeight="SemiBold"
                                                                                       Foreground="{DynamicResource DemoPrimaryTextBrush}" />
                                                                            <TextBlock Grid.Column="1"
                                                                                       Text="Action tools"
                                                                                       FontSize="11"
                                                                                       Foreground="{DynamicResource DemoSecondaryTextBrush}" />
                                                                        </Grid>
                                                                    </Border>

                                                                    <Border Grid.Row="3"
                                                                            Height="1"
                                                                            Background="{DynamicResource Brush.FormShell.Divider}" />

                                                                    <Border Grid.Row="4"
                                                                            Padding="{DynamicResource Thickness.FormShell.LayoutPadding}"
                                                                            Background="{DynamicResource Brush.FormShell.ContentBackground}">
                                                                        <StackPanel>
                                                                            <TextBlock Text="ContentBackground"
                                                                                       FontSize="12"
                                                                                       FontWeight="SemiBold"
                                                                                       Foreground="{DynamicResource DemoPrimaryTextBrush}" />
                                                                            <Border Margin="0,8,0,0"
                                                                                    Padding="8"
                                                                                    Background="{DynamicResource DemoInputBackgroundBrush}"
                                                                                    BorderBrush="{DynamicResource Brush.FormShell.RegionBorder}"
                                                                                    BorderThickness="1"
                                                                                    CornerRadius="8">
                                                                                <TextBlock Text="RegionBorder around nested layout containers"
                                                                                           FontSize="11"
                                                                                           Foreground="{DynamicResource DemoSecondaryTextBrush}"
                                                                                           TextWrapping="Wrap" />
                                                                            </Border>
                                                                        </StackPanel>
                                                                    </Border>

                                                                    <Border Grid.Row="5"
                                                                            Height="1"
                                                                            Background="{DynamicResource Brush.FormShell.Divider}" />

                                                                    <Border Grid.Row="6"
                                                                            Padding="{DynamicResource Thickness.FormShell.BottomActionPadding}"
                                                                            Background="{DynamicResource Brush.FormShell.BottomActionBackground}">
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="*" />
                                                                                <ColumnDefinition Width="Auto" />
                                                                            </Grid.ColumnDefinitions>
                                                                            <TextBlock Text="BottomActionBackground"
                                                                                       FontSize="12"
                                                                                       FontWeight="SemiBold"
                                                                                       Foreground="{DynamicResource DemoPrimaryTextBrush}" />
                                                                            <TextBlock Grid.Column="1"
                                                                                       Text="Commit strip"
                                                                                       FontSize="11"
                                                                                       Foreground="{DynamicResource DemoSecondaryTextBrush}" />
                                                                        </Grid>
                                                                    </Border>

                                                                    <Border Grid.Row="7"
                                                                            Padding="{DynamicResource Thickness.FormShell.FooterPadding}"
                                                                            Background="{DynamicResource Brush.FormShell.FooterBackground}"
                                                                            BorderBrush="{DynamicResource Brush.FormShell.Divider}"
                                                                            BorderThickness="0,1,0,0">
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="*" />
                                                                                <ColumnDefinition Width="Auto" />
                                                                            </Grid.ColumnDefinitions>
                                                                            <TextBlock Text="FooterBackground"
                                                                                       FontSize="12"
                                                                                       FontWeight="SemiBold"
                                                                                       Foreground="{DynamicResource DemoPrimaryTextBrush}" />
                                                                            <TextBlock Grid.Column="1"
                                                                                       Text="Divider above footer"
                                                                                       FontSize="11"
                                                                                       Foreground="{DynamicResource DemoSecondaryTextBrush}" />
                                                                        </Grid>
                                                                    </Border>
                                                                </Grid>
                                                            </Border>

                                                            <TextBlock Margin="0,8,0,0"
                                                                       Text="{Binding FoundationsAccentColorsTitle}"
                                                                       Style="{StaticResource FoundationsSubsectionTitleStyle}" />
                                                            <ItemsControl ItemsSource="{Binding FoundationsAccentTokens}"
                                                                          ItemTemplate="{StaticResource FoundationsColorTokenTemplate}" />
                                                        </StackPanel>
                                                    </Border>

                                                    <Border Margin="0,16,0,0"
                                                            Style="{StaticResource FoundationsSectionBorderStyle}">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding FoundationsRhythmTitle}"
                                                                       Style="{StaticResource SectionHeadlineStyle}" />
                                                            <TextBlock Margin="0,0,0,14"
                                                                       Text="{Binding FoundationsRhythmDescription}"
                                                                       FontSize="13"
                                                                       Foreground="{DynamicResource DemoSecondaryTextBrush}"
                                                                       TextWrapping="Wrap" />

                                                            <TextBlock Text="{Binding FoundationsShapesTitle}"
                                                                       Style="{StaticResource FoundationsSubsectionTitleStyle}" />
                                                            <ItemsControl ItemsSource="{Binding FoundationsShapeTokens}"
                                                                          ItemTemplate="{StaticResource FoundationsMeasureTokenTemplate}" />

                                                            <TextBlock Margin="0,8,0,0"
                                                                       Text="{Binding FoundationsSpacingTitle}"
                                                                       Style="{StaticResource FoundationsSubsectionTitleStyle}" />
                                                            <ItemsControl ItemsSource="{Binding FoundationsSpacingTokens}"
                                                                          ItemTemplate="{StaticResource FoundationsMeasureTokenTemplate}" />
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                            </Grid>

                                            <Border Margin="0,16,0,0"
                                                    Style="{StaticResource FoundationsSectionBorderStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="Buttons / Actions"
                                                               Style="{StaticResource SectionHeadlineStyle}" />
                                                    <TextBlock Margin="0,0,0,14"
                                                               Text="Buttons should expose a clear action hierarchy, predictable focus treatment and stable sizing before any YAML-specific semantics are applied."
                                                               FontSize="13"
                                                               Foreground="{DynamicResource DemoSecondaryTextBrush}"
                                                               TextWrapping="Wrap" />

                                                    <TextBlock Text="Hierarchy"
                                                               Style="{StaticResource FoundationsSubsectionTitleStyle}" />
                                                    <WrapPanel Margin="0,8,0,0">
                                                        <Button Style="{StaticResource CommitToolbarButtonStyle}"
                                                                Content="Primary action" />
                                                        <Button Style="{StaticResource ToolbarButtonStyle}"
                                                                Content="Secondary action" />
                                                        <Button Style="{StaticResource CancelToolbarButtonStyle}"
                                                                Content="Danger action" />
                                                    </WrapPanel>

                                                    <TextBlock Margin="0,18,0,0"
                                                               Text="States"
                                                               Style="{StaticResource FoundationsSubsectionTitleStyle}" />
                                                    <WrapPanel Margin="0,8,0,0">
                                                        <Button Style="{StaticResource CommitToolbarButtonStyle}"
                                                                Content="Enabled primary" />
                                                        <Button Style="{StaticResource ToolbarButtonStyle}"
                                                                Content="Enabled secondary" />
                                                        <Button Style="{StaticResource CancelToolbarButtonStyle}"
                                                                Content="Enabled danger" />
                                                        <Button Style="{StaticResource CommitToolbarButtonStyle}"
                                                                IsEnabled="False"
                                                                Content="Disabled primary" />
                                                        <Button Style="{StaticResource ToolbarButtonStyle}"
                                                                IsEnabled="False"
                                                                Content="Disabled secondary" />
                                                    </WrapPanel>

                                                    <Border Margin="0,18,0,0"
                                                            Padding="14"
                                                            Background="{DynamicResource DemoTokenBackgroundBrush}"
                                                            BorderBrush="{DynamicResource DemoTokenBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="10">
                                                        <StackPanel>
                                                            <TextBlock Text="Current guidance"
                                                                       Style="{StaticResource FoundationsSubsectionTitleStyle}" />
                                                            <TextBlock Margin="0,8,0,0"
                                                                       Text="Use `CommitToolbarButtonStyle` for the single highest-priority confirm action, `ToolbarButtonStyle` for neutral actions and `CancelToolbarButtonStyle` for destructive or escape-oriented actions."
                                                                       FontSize="12"
                                                                       Foreground="{DynamicResource DemoPrimaryTextBrush}"
                                                                       TextWrapping="Wrap" />
                                                            <TextBlock Margin="0,8,0,0"
                                                                       Text="Shared constraints: radius 6, compact 32px minimum height, semi-bold emphasis only for high-priority actions and disabled opacity reduced instead of changing layout."
                                                                       FontSize="12"
                                                                       Foreground="{DynamicResource DemoSecondaryTextBrush}"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>

                                    <ScrollViewer x:Name="ApplicationStateManagerSurfaceScrollViewer"
                                                  Visibility="{Binding ShowApplicationStateManagerSurface, Converter={StaticResource BooleanToVisibilityConverter}}"
