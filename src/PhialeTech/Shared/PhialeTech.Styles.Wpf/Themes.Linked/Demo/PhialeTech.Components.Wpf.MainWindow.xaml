                                                                                                   Text="{Binding ComponentId}"
                                                                                                   FontSize="12"
                                                                                                   Foreground="{DynamicResource DemoPrimaryTextBrush}" />
                                                                                    </Grid>
                                                                                    <TextBlock Text="{Binding DataContext.DefinitionManagerResponsibilitiesTitle, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                               FontSize="12"
                                                                                               FontFamily="Bahnschrift SemiBold"
                                                                                               Foreground="{DynamicResource DemoHeaderTextBrush}" />
                                                                                    <ItemsControl Margin="0,10,0,0"
                                                                                                  ItemsSource="{Binding Responsibilities}"
                                                                                                  ItemTemplate="{StaticResource DefinitionManagerBulletTemplate}" />
                                                                                    <TextBlock Margin="0,8,0,0"
                                                                                               Text="{Binding DataContext.DefinitionManagerOutOfScopeTitle, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                               FontSize="12"
                                                                                               FontFamily="Bahnschrift SemiBold"
                                                                                               Foreground="{DynamicResource DemoHeaderTextBrush}" />
                                                                                    <ItemsControl Margin="0,10,0,0"
                                                                                                  ItemsSource="{Binding OutOfScope}"
                                                                                                  ItemTemplate="{StaticResource DefinitionManagerBulletTemplate}" />
                                                                                </StackPanel>
                                                                            </Border>
                                                                        </StackPanel>
                                                                    </DataTemplate>
                                                                </ContentControl.ContentTemplate>
                                                            </ContentControl>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1">
