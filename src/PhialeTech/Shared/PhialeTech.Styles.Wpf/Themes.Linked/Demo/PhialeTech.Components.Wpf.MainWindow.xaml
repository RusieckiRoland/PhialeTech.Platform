                                                               Text="{Binding WebComponentsScrollHostDescription}"
                                                               FontSize="13"
                                                               Foreground="{DynamicResource DemoSecondaryTextBrush}"
                                                               TextWrapping="Wrap" />
                                                    <Border Margin="0,18,0,0"
                                                            Padding="14"
                                                            Background="{DynamicResource DemoTokenBackgroundBrush}"
                                                            BorderBrush="{DynamicResource DemoTokenBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="10">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding WebComponentsScrollHostPointOne}"
                                                                       FontSize="12"
                                                                       Foreground="{DynamicResource DemoPrimaryTextBrush}"
                                                                       TextWrapping="Wrap" />
                                                            <TextBlock Margin="0,10,0,0"
                                                                       Text="{Binding WebComponentsScrollHostPointTwo}"
                                                                       FontSize="12"
                                                                       Foreground="{DynamicResource DemoPrimaryTextBrush}"
                                                                       TextWrapping="Wrap" />
                                                            <TextBlock Margin="0,10,0,0"
                                                                       Text="{Binding WebComponentsScrollHostPointThree}"
                                                                       FontSize="12"
                                                                       Foreground="{DynamicResource DemoPrimaryTextBrush}"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>

                    <TabItem Header="{Binding CodeTabText}">
                        <Grid Margin="0,20,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="{Binding FileLabelText}"
                                       FontFamily="Bahnschrift SemiBold"
                                       FontSize="14"
                                       Foreground="{DynamicResource DemoHeaderTextBrush}" />
                            <ComboBox x:Name="CodeFileComboBox"
                                      Grid.Row="1"
                                      Margin="0,10,0,16"
                                      Width="260"
                                      ItemsSource="{Binding AvailableCodeFiles}"
                                      SelectedItem="{Binding SelectedCodeFile, Mode=TwoWay}"
                                      TextSearch.TextPath="FileName">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FileName}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Border Grid.Row="2"
                                    Style="{StaticResource DemoCodeSurfaceBorderStyle}"
                                    Padding="0">
                                <TextBox x:Name="CodePreviewTextBox"
                                         Style="{StaticResource DemoCodeTextBoxStyle}"
                                         Text="{Binding SourceCodeText, Mode=OneWay}"
                                         IsReadOnly="True"
                                         VerticalContentAlignment="Stretch"
                                         BorderBrush="Transparent" />
                            </Border>
                        </Grid>
                    </TabItem>

                    <TabItem Header="{Binding ExplanationTabText}"
                             Visibility="{Binding ShowWebComponentsExplanationTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid Margin="0,20,0,0">
                            <Border Style="{StaticResource FoundationsSectionBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="{Binding WebComponentsScrollHostTitle}"
                                               Style="{StaticResource SectionHeadlineStyle}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding WebComponentsScrollHostDescription}"
                                               FontSize="13"
                                               Foreground="{DynamicResource DemoSecondaryTextBrush}"
                                               TextWrapping="Wrap" />

                                    <Border Margin="0,18,0,0"
                                            Padding="14"
                                            Background="{DynamicResource DemoTokenBackgroundBrush}"
                                            BorderBrush="{DynamicResource DemoTokenBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10">
                                        <StackPanel>
                                            <TextBlock Text="{Binding WebComponentsScrollHostPointOne}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource DemoPrimaryTextBrush}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Margin="0,10,0,0"
                                                       Text="{Binding WebComponentsScrollHostPointTwo}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource DemoPrimaryTextBrush}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Margin="0,10,0,0"
                                                       Text="{Binding WebComponentsScrollHostPointThree}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource DemoPrimaryTextBrush}"
                                                       TextWrapping="Wrap" />
