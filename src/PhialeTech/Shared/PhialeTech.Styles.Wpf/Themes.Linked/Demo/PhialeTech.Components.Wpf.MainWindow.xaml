                                      Padding="8,4"
                                      Margin="0,0,10,0"
                                      ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=InputInteractionOptions}"
                                      SelectedItem="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=SelectedInputInteractionMode, Mode=TwoWay}"
                                      Background="{DynamicResource DemoInputBackgroundBrush}"
                                      BorderBrush="{DynamicResource DemoInputBorderBrush}"
                                      BorderThickness="1" />
                            <TextBlock Text="Density"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"
                                       FontFamily="Bahnschrift SemiBold"
                                       FontSize="13"
                                       Foreground="{DynamicResource DemoHeaderTextBrush}" />
                            <ComboBox Width="140"
                                      Padding="8,4"
                                      ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=InputDensityOptions}"
                                      SelectedItem="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=SelectedInputDensityMode, Mode=TwoWay}"
                                      Background="{DynamicResource DemoInputBackgroundBrush}"
                                      BorderBrush="{DynamicResource DemoInputBorderBrush}"
                                      BorderThickness="1" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding ThemeLabelText}"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"
                                       FontFamily="Bahnschrift SemiBold"
                                       FontSize="13"
                                       Foreground="{DynamicResource DemoHeaderTextBrush}" />
                            <ComboBox Width="140"
                                      Padding="8,4"
                                      ItemsSource="{Binding ThemeOptions}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Code"
                                      SelectedValue="{Binding SelectedThemeCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Background="{DynamicResource DemoInputBackgroundBrush}"
                                      BorderBrush="{DynamicResource DemoInputBorderBrush}"
                                      BorderThickness="1" />
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <StackPanel x:Name="ExampleHeaderPanel" Grid.Row="1" Margin="0,26,0,20">
                    <TextBlock Text="{Binding DetailHeadline}"
                               FontFamily="Bahnschrift SemiBold"
                               FontSize="34"
                               Foreground="{DynamicResource DemoPrimaryTextBrush}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding SelectedExampleDescription}"
                               FontSize="15"
                               Foreground="{DynamicResource DemoSecondaryTextBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>

                <TabControl x:Name="ExampleTabControl"
                            Grid.Row="2"
                            SelectedIndex="{Binding SelectedTabIndex}"
                            Style="{StaticResource DemoTabControlStyle}"
                            ItemContainerStyle="{StaticResource DemoTabItemStyle}">
                    <TabItem Header="{Binding DemoTabText}">
                        <Grid x:Name="DemoTabExportGrid"
                              Margin="0,20,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="2"
                                    Margin="0,18,0,0"
                                    Background="{DynamicResource DemoPanelBackgroundBrush}"
                                    BorderBrush="{DynamicResource DemoPanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="18">
                                <Grid>
                                    <ScrollViewer x:Name="FoundationsSurfaceScrollViewer"
                                                  Visibility="{Binding ShowFoundationsSurface, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <StackPanel x:Name="FoundationsSurfaceContentPanel"
                                                    Margin="0,0,8,0">
                                            <Border Style="{StaticResource FoundationsSectionBorderStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding FoundationsIntroTitle}"
                                                               Style="{StaticResource SectionHeadlineStyle}" />
                                                    <TextBlock Text="{Binding FoundationsIntroDescription}"
                                                               FontSize="14"
                                                               Foreground="{DynamicResource DemoSecondaryTextBrush}"
                                                               TextWrapping="Wrap" />
                                                    <ItemsControl Margin="0,14,0,0"
                                                                  ItemsSource="{Binding FoundationsHighlights}"
                                                                  ItemTemplate="{StaticResource FoundationsHighlightTemplate}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>

                                            <Grid Margin="0,16,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="1.2*" />
                                                    <ColumnDefinition Width="0.85*" />
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0"
                                                        Margin="0,0,16,0"
                                                        Style="{StaticResource FoundationsSectionBorderStyle}">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding FoundationsTypographyTitle}"
                                                                   Style="{StaticResource SectionHeadlineStyle}" />
                                                        <TextBlock Margin="0,0,0,14"
                                                                   Text="{Binding FoundationsTypographyDescription}"
                                                                   FontSize="13"
                                                                   Foreground="{DynamicResource DemoSecondaryTextBrush}"
                                                                   TextWrapping="Wrap" />
                                                        <ItemsControl ItemsSource="{Binding FoundationsTypographyTokens}"
                                                                      ItemTemplate="{StaticResource FoundationsTypographyTokenTemplate}" />
                                                    </StackPanel>
                                                </Border>

                                                <StackPanel Grid.Column="1">
                                                    <Border Style="{StaticResource FoundationsSectionBorderStyle}">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding FoundationsColorsTitle}"
                                                                       Style="{StaticResource SectionHeadlineStyle}" />
                                                            <TextBlock Margin="0,0,0,14"
                                                                       Text="{Binding FoundationsColorsDescription}"
                                                                       FontSize="13"
                                                                       Foreground="{DynamicResource DemoSecondaryTextBrush}"
                                                                       TextWrapping="Wrap" />

                                                            <TextBlock Text="{Binding FoundationsTextColorsTitle}"
                                                                       Style="{StaticResource FoundationsSubsectionTitleStyle}" />
                                                            <ItemsControl ItemsSource="{Binding FoundationsTextColorTokens}"
                                                                          ItemTemplate="{StaticResource FoundationsColorTokenTemplate}" />

                                                            <TextBlock Margin="0,8,0,0"
                                                                       Text="{Binding FoundationsSurfaceColorsTitle}"
                                                                       Style="{StaticResource FoundationsSubsectionTitleStyle}" />
                                                            <ItemsControl ItemsSource="{Binding FoundationsSurfaceTokens}"
                                                                          ItemTemplate="{StaticResource FoundationsColorTokenTemplate}" />

                                                            <TextBlock Margin="0,8,0,0"
                                                                       Text="{Binding FoundationsFormShellColorsTitle}"
                                                                       Style="{StaticResource FoundationsSubsectionTitleStyle}" />
                                                            <TextBlock Margin="0,0,0,8"
                                                                       Text="{Binding FoundationsFormShellColorsDescription}"
                                                                       FontSize="12"
                                                                       Foreground="{DynamicResource DemoSecondaryTextBrush}"
                                                                       TextWrapping="Wrap" />
                                                            <ItemsControl ItemsSource="{Binding FoundationsFormShellTokens}"
                                                                          ItemTemplate="{StaticResource FoundationsColorTokenTemplate}" />

                                                            <TextBlock Margin="0,10,0,0"
                                                                       Text="{Binding FoundationsFormShellSpacingTitle}"
                                                                       Style="{StaticResource FoundationsSubsectionTitleStyle}" />
                                                            <TextBlock Margin="0,0,0,8"
                                                                       Text="{Binding FoundationsFormShellSpacingDescription}"
                                                                       FontSize="12"
                                                                       Foreground="{DynamicResource DemoSecondaryTextBrush}"
                                                                       TextWrapping="Wrap" />
                                                            <ItemsControl ItemsSource="{Binding FoundationsFormShellSpacingTokens}"
                                                                          ItemTemplate="{StaticResource FoundationsMeasureTokenTemplate}" />

                                                            <Border Margin="0,10,0,0"
                                                                    Background="{DynamicResource Brush.FormShell.ContentBackground}"
                                                                    BorderBrush="{DynamicResource Brush.FormShell.RegionBorder}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="10">
                                                                    <Grid ClipToBounds="True">
                                                                        <Grid.RowDefinitions>
                                                                            <RowDefinition Height="Auto" />
                                                                            <RowDefinition Height="Auto" />
                                                                            <RowDefinition Height="Auto" />
                                                                            <RowDefinition Height="Auto" />
                                                                            <RowDefinition Height="*" />
                                                                            <RowDefinition Height="Auto" />
                                                                            <RowDefinition Height="Auto" />
                                                                            <RowDefinition Height="Auto" />
                                                                        </Grid.RowDefinitions>

                                                                    <Border Grid.Row="0"
                                                                            Padding="{DynamicResource Thickness.FormShell.HeaderPadding}"
                                                                            Background="{DynamicResource Brush.FormShell.HeaderBackground}">
                                                                        <StackPanel>
                                                                            <TextBlock Text="HeaderBackground"
                                                                                       FontSize="12"
                                                                                       FontWeight="SemiBold"
                                                                                       Foreground="{DynamicResource DemoPrimaryTextBrush}" />
                                                                            <TextBlock Margin="0,4,0,0"
                                                                                       Text="Metadata, title and top shell chrome."
                                                                                       FontSize="11"
                                                                                       Foreground="{DynamicResource DemoSecondaryTextBrush}"
                                                                                       TextWrapping="Wrap" />
                                                                        </StackPanel>
                                                                    </Border>

                                                                    <Border Grid.Row="1"
                                                                            Height="1"
                                                                            Background="{DynamicResource Brush.FormShell.Divider}" />

                                                                    <Border Grid.Row="2"
