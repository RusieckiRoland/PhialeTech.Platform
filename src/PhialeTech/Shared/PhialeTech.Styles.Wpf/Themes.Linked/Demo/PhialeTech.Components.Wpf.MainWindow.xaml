                                                                       Text="{Binding DefinitionManagerSampleDescription}"
                                                                       FontSize="13"
                                                                       Foreground="{DynamicResource DemoSecondaryTextBrush}"
                                                                       TextWrapping="Wrap" />

                                                            <Border Padding="14"
                                                                    Background="{DynamicResource DemoPanelBackgroundBrush}"
                                                                    BorderBrush="{DynamicResource DemoPanelBorderBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="10">
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding DefinitionManagerSampleDefinition.Title}"
                                                                               FontSize="17"
                                                                               FontFamily="Bahnschrift SemiBold"
                                                                               Foreground="{DynamicResource DemoPrimaryTextBrush}" />
                                                                    <TextBlock Margin="0,6,0,12"
                                                                               Text="{Binding DefinitionManagerSampleDefinition.Summary}"
                                                                               FontSize="13"
                                                                               Foreground="{DynamicResource DemoSecondaryTextBrush}"
                                                                               TextWrapping="Wrap" />
                                                                    <ItemsControl ItemsSource="{Binding DefinitionManagerSampleDefinition.Fields}"
                                                                                  ItemTemplate="{StaticResource DefinitionManagerFieldTemplate}" />
                                                                    <Border Margin="0,10,0,0"
                                                                            Padding="12"
                                                                            Background="{DynamicResource DemoTokenBackgroundBrush}"
                                                                            BorderBrush="{DynamicResource DemoTokenBorderBrush}"
                                                                            BorderThickness="1"
                                                                            CornerRadius="10">
                                                                        <StackPanel>
                                                                            <TextBlock Text="{Binding DefinitionManagerFieldConsumer}"
                                                                                       FontSize="11"
                                                                                       FontFamily="Bahnschrift SemiBold"
                                                                                       Foreground="{DynamicResource DemoHeaderTextBrush}" />
                                                                            <TextBlock Margin="0,6,0,0"
                                                                                       Text="{Binding DefinitionManagerSampleDefinition.ConsumerHint}"
                                                                                       FontSize="12"
                                                                                       Foreground="{DynamicResource DemoPrimaryTextBrush}"
                                                                                       TextWrapping="Wrap" />
                                                                            <TextBlock Margin="0,12,0,0"
                                                                                       Text="{Binding DefinitionManagerFieldStateOverlay}"
                                                                                       FontSize="11"
                                                                                       FontFamily="Bahnschrift SemiBold"
                                                                                       Foreground="{DynamicResource DemoHeaderTextBrush}" />
                                                                            <TextBlock Margin="0,6,0,0"
                                                                                       Text="{Binding DefinitionManagerSampleDefinition.StateOverlayHint}"
                                                                                       FontSize="12"
                                                                                       Foreground="{DynamicResource DemoPrimaryTextBrush}"
                                                                                       TextWrapping="Wrap" />
                                                                        </StackPanel>
                                                                    </Border>
                                                                </StackPanel>
                                                            </Border>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </ScrollViewer>

                                    <grid:PhialeGrid x:Name="DemoGrid"
                                                     Visibility="{Binding ShowGridSurface, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                     Background="{DynamicResource DemoGridBackgroundBrush}"
                                                     BorderBrush="{DynamicResource DemoGridBorderBrush}"
                                                     Foreground="{DynamicResource DemoGridTextBrush}"
                                                     SelectCurrentRow="True"
                                                     MultiSelect="False"
                                                     EditSessionContext="{Binding GridEditSessionContext}"
                                                     Groups="{Binding GridGroups, Mode=TwoWay}"
                                                     Sorts="{Binding GridSorts, Mode=TwoWay}"
                                                     Summaries="{Binding GridSummaries}"
                                                     SideToolRegionTitle="{Binding GridSideToolRegionTitleText}"
                                                     SideToolRegionUsesDrawerChrome="{Binding ShowSummaryDesignerTools}"
                                                     IsGridReadOnly="{Binding IsGridReadOnly}"
                                                     LanguageCode="{Binding LanguageCode}">
                                        <grid:PhialeGrid.TopCommandContent>
                                            <DockPanel Tag="DemoGridTopCommandStrip"
                                                       LastChildFill="True"
                                                       Visibility="{Binding ShowGridEditCommandBar, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <WrapPanel Tag="DemoGridTopCommandStatusStrip"
                                                           DockPanel.Dock="Right"
                                                           Orientation="Horizontal"
                                                           VerticalAlignment="Center"
                                                           Margin="12,0,0,0">
                                                    <Border Style="{StaticResource GridCommandStripBadgeBorderStyle}"
                                                            Visibility="{Binding RelativeSource={RelativeSource AncestorType={x:Type grid:PhialeGrid}}, Path=HasPendingEdits, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Style="{StaticResource GridCommandStripBadgeTextStyle}"
                                                                       Text="{Binding RelativeSource={RelativeSource AncestorType={x:Type grid:PhialeGrid}}, Path=PendingEditCount}" />
                                                            <TextBlock Margin="4,0,0,0"
                                                                       Style="{StaticResource GridCommandStripBadgeTextStyle}"
                                                                       Text="{Binding DirtyRowsBadgeLabelText}" />
                                                        </StackPanel>
                                                    </Border>
                                                    <Border Style="{StaticResource GridCommandStripBadgeBorderStyle}"
                                                            Background="{DynamicResource DemoWarningBackgroundBrush}"
                                                            BorderBrush="{DynamicResource DemoWarningBorderBrush}"
                                                            Visibility="{Binding RelativeSource={RelativeSource AncestorType={x:Type grid:PhialeGrid}}, Path=HasValidationIssues, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Style="{StaticResource GridCommandStripBadgeTextStyle}"
                                                                       Foreground="{DynamicResource DemoWarningTextBrush}"
                                                                       Text="{Binding RelativeSource={RelativeSource AncestorType={x:Type grid:PhialeGrid}}, Path=ValidationIssueCount}" />
                                                            <TextBlock Margin="4,0,0,0"
                                                                       Style="{StaticResource GridCommandStripBadgeTextStyle}"
                                                                       Foreground="{DynamicResource DemoWarningTextBrush}"
                                                                       Text="{Binding ValidationIssuesBadgeLabelText}" />
                                                        </StackPanel>
                                                    </Border>
                                                </WrapPanel>

                                                <WrapPanel Tag="DemoGridTopCommandActions"
                                                           Orientation="Horizontal"
                                                           VerticalAlignment="Center">
                                                    <Button Style="{StaticResource GridCommandStripButtonStyle}"
                                                            Click="HandleAddDemoRecordClick">
                                                        <Button.Content>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Margin="0,0,6,0"
                                                                           FontSize="12"
                                                                           FontWeight="Bold"
                                                                           Text="+" />
                                                                <TextBlock Text="{Binding AddRecordText}" />
                                                            </StackPanel>
                                                        </Button.Content>
                                                    </Button>
                                                    <Button Style="{StaticResource GridCommandStripButtonStyle}"
                                                            Click="HandleBeginCurrentEditClick">
                                                        <Button.Content>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Margin="0,0,6,0"
                                                                           FontSize="12"
                                                                           Text="✎" />
                                                                <TextBlock Text="{Binding EditRecordText}" />
                                                            </StackPanel>
                                                        </Button.Content>
                                                    </Button>
                                                    <Button Style="{StaticResource GridCommandStripButtonStyle}"
                                                            Click="HandlePostCurrentEditClick">
                                                        <Button.Content>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Margin="0,0,6,0"
                                                                           FontSize="12"
                                                                           Text="✓" />
                                                                <TextBlock Text="{Binding ApplyCurrentEditText}" />
                                                            </StackPanel>
                                                        </Button.Content>
                                                    </Button>
                                                    <Button Style="{StaticResource GridCommandStripButtonStyle}"
                                                            Click="HandleCancelCurrentEditClick">
                                                        <Button.Content>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Margin="0,0,6,0"
                                                                           FontSize="12"
                                                                           Text="✕" />
                                                                <TextBlock Text="{Binding CancelCurrentEditText}" />
                                                            </StackPanel>
                                                        </Button.Content>
                                                    </Button>
                                                    <Border Width="1"
                                                            Height="18"
                                                            Margin="8,0,6,0"
                                                            VerticalAlignment="Center"
                                                            Background="{DynamicResource DemoTokenBorderBrush}" />
                                                    <Button Style="{StaticResource GridCommandStripPrimaryButtonStyle}"
                                                            IsEnabled="{Binding RelativeSource={RelativeSource AncestorType={x:Type grid:PhialeGrid}}, Path=HasPendingEdits}"
                                                            Click="HandleCommitEditsClick">
                                                        <Button.Content>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Margin="0,0,6,0"
                                                                           FontSize="12"
                                                                           Text="✓" />
                                                                <TextBlock Text="{Binding CommitText}" />
                                                            </StackPanel>
                                                        </Button.Content>
                                                    </Button>
                                                    <Button Style="{StaticResource GridCommandStripDangerButtonStyle}"
                                                            IsEnabled="{Binding RelativeSource={RelativeSource AncestorType={x:Type grid:PhialeGrid}}, Path=HasPendingEdits}"
                                                            Click="HandleCancelEditsClick">
                                                        <Button.Content>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Margin="0,0,6,0"
                                                                           FontSize="12"
                                                                           Text="✕" />
                                                                <TextBlock Text="{Binding CancelText}" />
                                                            </StackPanel>
                                                        </Button.Content>
                                                    </Button>
                                                </WrapPanel>
                                            </DockPanel>
                                        </grid:PhialeGrid.TopCommandContent>
                                        <grid:PhialeGrid.SideToolContent>
                                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled">
                                                <StackPanel Visibility="{Binding ShowGridSideToolRegionContent, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="Grid tools"
                                                               Style="{StaticResource SectionHeadlineStyle}" />

                                                    <WrapPanel Visibility="{Binding ShowGridModeTools, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <TextBlock Margin="0,6,10,0"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource DemoSecondaryTextBrush}"
                                                                   Text="Interaction" />
                                                        <ComboBox Width="140"
                                                                  Margin="0,0,10,10"
                                                                  Style="{StaticResource DemoComboBoxStyle}"
                                                                  SelectedValue="{Binding RelativeSource={RelativeSource AncestorType={x:Type grid:PhialeGrid}}, Path=InteractionMode, Mode=TwoWay}"
                                                                  SelectedValuePath="Tag">
                                                            <ComboBoxItem Tag="{x:Static grid:GridInteractionMode.Classic}" Content="Classic" />
                                                            <ComboBoxItem Tag="{x:Static grid:GridInteractionMode.Touch}" Content="Touch" />
                                                            <ComboBoxItem Tag="{x:Static grid:GridInteractionMode.Auto}" Content="Auto" />
                                                        </ComboBox>
                                                        <TextBlock Margin="0,6,10,0"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource DemoSecondaryTextBrush}"
                                                                   Text="Density" />
                                                        <ComboBox Width="160"
                                                                  Margin="0,0,10,10"
                                                                  Style="{StaticResource DemoComboBoxStyle}"
                                                                  SelectedValue="{Binding RelativeSource={RelativeSource AncestorType={x:Type grid:PhialeGrid}}, Path=Density, Mode=TwoWay}"
                                                                  SelectedValuePath="Tag">
                                                            <ComboBoxItem Tag="{x:Static grid:GridDensity.Compact}" Content="Compact" />
                                                            <ComboBoxItem Tag="{x:Static grid:GridDensity.Comfortable}" Content="Comfortable" />
                                                            <ComboBoxItem Tag="{x:Static grid:GridDensity.Touch}" Content="Touch" />
                                                        </ComboBox>
                                                    </WrapPanel>

                                                    <Border Visibility="{Binding ShowLayoutTools, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                            Margin="0,0,0,10"
                                                            Padding="12,10"
                                                            Background="{DynamicResource DemoHintBackgroundBrush}"
                                                            BorderBrush="{DynamicResource DemoHintBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="10">
                                                        <TextBlock Text="{Binding LayoutToolsHintText}"
                                                                   FontSize="13"
                                                                   Foreground="{DynamicResource DemoHintTextBrush}"
                                                                   TextWrapping="Wrap" />
                                                    </Border>

                                                    <WrapPanel Visibility="{Binding ShowSearchTools, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <TextBox Width="240"
                                                                 Margin="0,0,10,10"
                                                                 Padding="12,8"
                                                                 Text="{Binding GridSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        <Button Style="{StaticResource ToolbarButtonStyle}"
                                                                Content="{Binding ApplySearchText}"
                                                                Click="HandleApplySearchClick" />
                                                        <Button Style="{StaticResource ToolbarButtonStyle}"
                                                                Content="{Binding ClearSearchText}"
                                                                Click="HandleClearSearchClick" />
                                                    </WrapPanel>

                                                    <WrapPanel Visibility="{Binding ShowFilteringTools, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <Button Style="{StaticResource ToolbarButtonStyle}"
                                                                Content="{Binding FocusMunicipalityFilterText}"
                                                                Click="HandleFocusMunicipalityFilterClick" />
                                                        <Button Style="{StaticResource ToolbarButtonStyle}"
                                                                Content="{Binding FocusOwnerFilterText}"
                                                                Click="HandleFocusOwnerFilterClick" />
                                                        <Button Style="{StaticResource ToolbarButtonStyle}"
                                                                Content="{Binding ClearColumnFiltersText}"
                                                                Click="HandleClearColumnFiltersClick" />
                                                    </WrapPanel>

                                                    <WrapPanel Visibility="{Binding ShowStateTools, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <Button Style="{StaticResource ToolbarButtonStyle}"
                                                                Content="{Binding SaveStateText}"
                                                                Click="HandleSaveStateClick" />
                                                        <Button Style="{StaticResource ToolbarButtonStyle}"
                                                                Content="{Binding RestoreStateText}"
                                                                Click="HandleRestoreStateClick" />
                                                        <Button Style="{StaticResource ToolbarButtonStyle}"
                                                                Content="{Binding ResetStateText}"
                                                                Click="HandleResetStateClick" />
                                                        <TextBlock Style="{StaticResource ToolbarStatusTextStyle}"
                                                                   Text="{Binding StateStatusText}" />
                                                    </WrapPanel>

                                                    <Border Margin="0,0,0,12"
                                                            Padding="12"
                                                            Background="{DynamicResource DemoTokenBackgroundBrush}"
                                                            BorderBrush="{DynamicResource DemoTokenBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="10"
                                                            Visibility="{Binding ShowSelectionTools, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <StackPanel>
                                                            <TextBlock Text="Selection commands"
                                                                       FontFamily="Bahnschrift SemiBold"
                                                                       FontSize="13"
                                                                       Foreground="{DynamicResource DemoHeaderTextBrush}" />
                                                            <WrapPanel Margin="0,10,0,0">
                                                                <Button Style="{StaticResource ToolbarButtonStyle}"
                                                                        Content="Show single current row"
                                                                        Click="HandleShowSingleCurrentRowScenarioClick" />
                                                                <Button Style="{StaticResource ToolbarButtonStyle}"
                                                                        Content="Show MultiSelect demo"
                                                                        Click="HandleShowMultiSelectScenarioClick" />
                                                                <Button Style="{StaticResource ToolbarButtonStyle}"
                                                                        Content="{Binding CopySelectionText}"
                                                                        Click="HandleCopySelectionClick" />
                                                                <Button Style="{StaticResource ToolbarButtonStyle}"
                                                                        Content="{Binding SelectVisibleRowsText}"
                                                                        Click="HandleSelectVisibleRowsClick" />
                                                                <Button Style="{StaticResource ToolbarButtonStyle}"
                                                                        Content="{Binding ClearSelectionText}"
                                                                        Click="HandleClearSelectionClick" />
                                                            </WrapPanel>
                                                            <TextBlock Margin="0,10,0,0"
                                                                       FontSize="13"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource DemoSecondaryTextBrush}"
                                                                       Text="{Binding SelectionScenarioStatusText}"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                    </Border>

                                                    <Border Margin="0,0,0,12"
                                                            Padding="12"
                                                            Background="{DynamicResource DemoTokenBackgroundBrush}"
                                                            BorderBrush="{DynamicResource DemoTokenBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="10"
                                                            Visibility="{Binding ShowEditingTools, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <StackPanel>
                                                            <TextBlock Text="Editing scenarios"
                                                                       FontFamily="Bahnschrift SemiBold"
                                                                       FontSize="13"
                                                                       Foreground="{DynamicResource DemoHeaderTextBrush}" />
                                                            <WrapPanel Margin="0,10,0,0">
                                                                <Button Style="{StaticResource ToolbarButtonStyle}"
                                                                        Content="Show row-state baseline"
                                                                        Click="HandleShowRowStateBaselineScenarioClick" />
                                                                <Button Style="{StaticResource ToolbarButtonStyle}"
                                                                        Content="Show current + edited"
                                                                        Click="HandleShowEditedPriorityScenarioClick" />
                                                                <Button Style="{StaticResource ToolbarButtonStyle}"
                                                                        Content="Show current + error"
                                                                        Click="HandleShowInvalidPriorityScenarioClick" />
                                                                <Button Style="{StaticResource ToolbarButtonStyle}"
                                                                        Content="Reset row-state demo"
                                                                        Click="HandleResetRowStateScenarioClick" />
                                                                <Button Style="{StaticResource ToolbarButtonStyle}"
                                                                        Content="Scroll to edited row"
                                                                        Click="HandleScrollEditedRowDemoClick" />
                                                                <Button Style="{StaticResource ToolbarButtonStyle}"
                                                                        Content="Scroll to error cell"
                                                                        Click="HandleScrollErrorCellDemoClick" />
                                                                <Button Style="{StaticResource ToolbarButtonStyle}"
                                                                        Content="Scroll to last column"
                                                                        Click="HandleScrollFarColumnDemoClick" />
                                                            </WrapPanel>
                                                            <Border Margin="0,10,0,0"
                                                                    Style="{StaticResource DemoStatusBannerBorderStyle}"
                                                                    Visibility="{Binding RelativeSource={RelativeSource AncestorType={x:Type grid:PhialeGrid}}, Path=HasPendingEdits, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType={x:Type grid:PhialeGrid}}, Path=PendingEditBannerText}"
                                                                           FontSize="13"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource DemoWarningTextBrush}"
                                                                           TextWrapping="Wrap" />
                                                            </Border>
                                                            <TextBlock Margin="0,10,0,0"
                                                                       FontSize="13"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource DemoSecondaryTextBrush}"
                                                                       Text="{Binding EditingScenarioStatusText}"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                    </Border>

                                                    <Expander Visibility="{Binding ShowConstraintTools, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                              Margin="0,0,0,12"
                                                              IsExpanded="False"
                                                              Background="{DynamicResource DemoTokenBackgroundBrush}"
                                                              BorderBrush="{DynamicResource DemoTokenBorderBrush}"
                                                              BorderThickness="1">
                                                        <Expander.Header>
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding ConstraintRulesTitle}"
                                                                           FontFamily="Bahnschrift SemiBold"
                                                                           FontSize="14"
                                                                           Foreground="{DynamicResource DemoHeaderTextBrush}" />
                                                                <TextBlock Margin="0,4,0,0"
                                                                           FontSize="12"
                                                                           Foreground="{DynamicResource DemoSecondaryTextBrush}"
                                                                           Text="Open the code tab to see constraints defined in EditSession field definitions, not in GridColumnDefinition."
                                                                           TextWrapping="Wrap" />
                                                            </StackPanel>
                                                        </Expander.Header>
                                                        <Border Padding="12"
                                                                Background="{DynamicResource DemoTokenBackgroundBrush}"
                                                                BorderBrush="{DynamicResource DemoTokenBorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="10">
                                                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                                          HorizontalScrollBarVisibility="Disabled"
                                                                          MaxHeight="220"
                                                                          CanContentScroll="False">
                                                                <ItemsControl ItemsSource="{Binding ConstraintRules}">
                                                                    <ItemsControl.ItemsPanel>
                                                                        <ItemsPanelTemplate>
                                                                            <WrapPanel />
                                                                        </ItemsPanelTemplate>
                                                                    </ItemsControl.ItemsPanel>
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Border Width="360"
                                                                                    Margin="0,0,10,8"
                                                                                    Padding="8,6"
                                                                                    Background="{DynamicResource DemoSurfaceBrush}"
                                                                                    BorderBrush="{DynamicResource DemoTokenBorderBrush}"
                                                                                    BorderThickness="1"
                                                                                    CornerRadius="8">
                                                                                <TextBlock FontSize="12"
                                                                                           Foreground="{DynamicResource DemoPrimaryTextBrush}"
                                                                                           TextWrapping="Wrap"
                                                                                           Text="{Binding}" />
                                                                            </Border>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </ScrollViewer>
                                                        </Border>
                                                    </Expander>

                                                    <TextBlock Margin="0,0,0,12"
                                                               Visibility="{Binding ShowConstraintTools, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource DemoSecondaryTextBrush}"
                                                               Text="{Binding ConstraintScenarioStatusText}"
                                                               TextWrapping="Wrap" />

                                                    <Border Margin="0,0,0,12"
                                                            Padding="12,10"
                                                            Background="{DynamicResource DemoPanelBackgroundBrush}"
                                                            BorderBrush="{DynamicResource DemoPanelBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="12"
                                                            Visibility="{Binding ShowSummaryDesignerTools, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                            </Grid.RowDefinitions>

                                                            <DockPanel Grid.Row="0"
                                                                       LastChildFill="False">
                                                                <TextBlock VerticalAlignment="Center"
                                                                           Text="Summary designer"
                                                                           FontFamily="Bahnschrift SemiBold"
                                                                           FontSize="14"
                                                                           Foreground="{DynamicResource DemoHeaderTextBrush}" />

                                                                <WrapPanel DockPanel.Dock="Right">
                                                                    <Button Style="{StaticResource GridCommandStripButtonStyle}"
                                                                            Click="HandleAddSummaryClick">
                                                                        <Button.Content>
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <TextBlock Margin="0,0,6,0"
                                                                                           FontSize="12"
                                                                                           FontWeight="Bold"
                                                                                           Text="+" />
                                                                                <TextBlock Text="{Binding AddSummaryText}" />
                                                                            </StackPanel>
                                                                        </Button.Content>
                                                                    </Button>
                                                                    <Button Style="{StaticResource GridCommandStripButtonStyle}"
                                                                            Click="HandleResetSummariesClick">
                                                                        <Button.Content>
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <TextBlock Margin="0,0,6,0"
                                                                                           FontSize="12"
                                                                                           Text="↺" />
                                                                                <TextBlock Text="{Binding ResetSummariesText}" />
                                                                            </StackPanel>
                                                                        </Button.Content>
                                                                    </Button>
                                                                </WrapPanel>
                                                            </DockPanel>

                                                            <TextBlock Grid.Row="1"
                                                                       Margin="0,6,0,10"
                                                                       FontSize="12"
                                                                       Foreground="{DynamicResource DemoSecondaryTextBrush}"
                                                                       Text="Configure summary definitions here. The bottom summary region should only present results."
                                                                       TextWrapping="Wrap" />

                                                            <StackPanel Grid.Row="2">
                                                                <WrapPanel Margin="0,0,0,10">
                                                                    <ComboBox Width="220"
                                                                              Margin="0,0,10,10"
                                                                              Style="{StaticResource DemoComboBoxStyle}"
                                                                              ItemsSource="{Binding AvailableSummaryColumns}"
                                                                              DisplayMemberPath="Header"
                                                                              SelectedItem="{Binding SelectedSummaryColumn, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                                    <ComboBox Width="180"
                                                                              Margin="0,0,10,10"
                                                                              Style="{StaticResource DemoComboBoxStyle}"
                                                                              ItemsSource="{Binding AvailableSummaryTypes}"
                                                                              DisplayMemberPath="DisplayName"
                                                                              SelectedItem="{Binding SelectedSummaryType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                                </WrapPanel>
                                                                <ItemsControl ItemsSource="{Binding ConfiguredSummaries}">
                                                                    <ItemsControl.ItemsPanel>
                                                                        <ItemsPanelTemplate>
                                                                            <WrapPanel />
                                                                        </ItemsPanelTemplate>
                                                                    </ItemsControl.ItemsPanel>
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Border Margin="0,0,10,10"
                                                                                    Padding="10,6"
                                                                                    Background="{DynamicResource DemoTokenBackgroundBrush}"
                                                                                    BorderBrush="{DynamicResource DemoTokenBorderBrush}"
                                                                                    BorderThickness="1"
                                                                                    CornerRadius="10">
                                                                                <StackPanel Orientation="Horizontal">
                                                                                    <TextBlock Text="{Binding Label}"
                                                                                               FontSize="11"
                                                                                               FontWeight="Normal"
                                                                                               Foreground="{DynamicResource DemoTokenTextBrush}" />
                                                                                    <Button Margin="8,0,0,0"
                                                                                            Padding="2,0"
                                                                                            Background="Transparent"
                                                                                            BorderThickness="0"
                                                                                            Tag="{Binding}"
                                                                                            Click="HandleRemoveSummaryClick">
                                                                                        <TextBlock Text="x"
                                                                                                   FontSize="11"
                                                                                                   FontWeight="Normal"
                                                                                                   Foreground="{DynamicResource DemoSecondaryTextBrush}" />
                                                                                    </Button>
                                                                                </StackPanel>
                                                                            </Border>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>

                                                    <Border Margin="0,0,0,12"
                                                            Padding="12"
                                                            Background="{DynamicResource DemoTokenBackgroundBrush}"
