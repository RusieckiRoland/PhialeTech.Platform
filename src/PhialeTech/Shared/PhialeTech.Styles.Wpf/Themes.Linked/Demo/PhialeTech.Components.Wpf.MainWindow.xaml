<shell:PhialeWindow x:Class="PhialeTech.Components.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:PhialeTech.Components.Wpf.Converters"
        xmlns:demoControls="clr-namespace:PhialeTech.Components.Wpf.Controls"
        xmlns:styles="clr-namespace:PhialeTech.Styles.Wpf;assembly=PhialeTech.Styles.Wpf"
        xmlns:grid="clr-namespace:PhialeTech.PhialeGrid.Wpf.Controls;assembly=PhialeTech.Grid.Wpf"
        xmlns:selector="clr-namespace:PhialeTech.ActiveLayerSelector.Wpf.Controls;assembly=PhialeTech.ActiveLayerSelector.Wpf"
        xmlns:yamlDocument="clr-namespace:PhialeTech.YamlApp.Wpf.Document;assembly=PhialeTech.YamlApp.Wpf"
        xmlns:yaml="clr-namespace:PhialeTech.YamlApp.Wpf.Controls.TextBox;assembly=PhialeTech.YamlApp.Wpf"
        xmlns:yamlInteger="clr-namespace:PhialeTech.YamlApp.Wpf.Controls.IntegerBox;assembly=PhialeTech.YamlApp.Wpf"
        xmlns:yamlBadge="clr-namespace:PhialeTech.YamlApp.Wpf.Controls.Badges;assembly=PhialeTech.YamlApp.Wpf"
        xmlns:yamlButton="clr-namespace:PhialeTech.YamlApp.Wpf.Controls.Buttons;assembly=PhialeTech.YamlApp.Wpf"
        xmlns:componentHost="clr-namespace:PhialeTech.ComponentHost.Wpf.Controls;assembly=PhialeTech.ComponentHost.Wpf"
        xmlns:shell="clr-namespace:PhialeTech.Shell.Wpf.Controls;assembly=PhialeTech.Shell.Wpf"
        xmlns:webHost="clr-namespace:PhialeTech.WebHost.Wpf.Controls;assembly=PhialeTech.WebHost.Wpf"
        mc:Ignorable="d"
        Title="{Binding AppTitle}"
        ShellState="{Binding RelativeSource={RelativeSource Self}, Path=ShellState}"
        Width="1560"
        Height="920"
        MinWidth="1280"
        MinHeight="760"
        Background="{DynamicResource DemoWindowBackgroundBrush}"
        FontFamily="Segoe UI">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PhialeTech.Styles.Wpf;component/Themes/Demo.Theme.Day.xaml" />
                <ResourceDictionary Source="pack://application:,,,/PhialeTech.Styles.Wpf;component/Themes/Demo.Controls.xaml" />
                <ResourceDictionary Source="pack://application:,,,/PhialeTech.Styles.Wpf;component/Themes/Demo.Wpf.Shared.xaml" />
                <ResourceDictionary Source="pack://application:,,,/PhialeTech.Styles.Wpf;component/Themes/YamlApp.Styles.xaml" />
                <ResourceDictionary Source="pack://application:,,,/PhialeTech.YamlApp.Wpf;component/Themes/YamlApp.ControlStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
            <Style TargetType="{x:Type ComboBox}" BasedOn="{StaticResource DemoComboBoxStyle}" />
            <Style TargetType="{x:Type ComboBoxItem}" BasedOn="{StaticResource DemoComboBoxItemStyle}" />
            <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource DemoScrollBarStyle}" />
            <Style TargetType="{x:Type ScrollViewer}" BasedOn="{StaticResource DemoScrollViewerStyle}" />
            <Style x:Key="FoundationsSectionBorderStyle" TargetType="Border" BasedOn="{StaticResource DemoSurfaceBorderStyle}">
                <Setter Property="Padding" Value="18" />
                <Setter Property="CornerRadius" Value="14" />
            </Style>
            <Style x:Key="GridCommandStripButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                <Setter Property="MinHeight" Value="28" />
                <Setter Property="Padding" Value="10,3" />
                <Setter Property="Margin" Value="0,0,6,0" />
                <Setter Property="FontSize" Value="12" />
            </Style>
            <Style x:Key="GridCommandStripPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource CommitToolbarButtonStyle}">
                <Setter Property="MinHeight" Value="28" />
                <Setter Property="Padding" Value="10,3" />
                <Setter Property="Margin" Value="0,0,6,0" />
                <Setter Property="FontSize" Value="12" />
            </Style>
            <Style x:Key="GridCommandStripDangerButtonStyle" TargetType="Button" BasedOn="{StaticResource CancelToolbarButtonStyle}">
                <Setter Property="MinHeight" Value="28" />
                <Setter Property="Padding" Value="10,3" />
                <Setter Property="Margin" Value="0,0,6,0" />
                <Setter Property="FontSize" Value="12" />
            </Style>
            <Style x:Key="GridCommandStripBadgeBorderStyle" TargetType="Border">
                <Setter Property="Padding" Value="8,2" />
                <Setter Property="Margin" Value="6,0,0,0" />
                <Setter Property="CornerRadius" Value="999" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Background" Value="{DynamicResource DemoTokenBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource DemoTokenBorderBrush}" />
            </Style>
            <Style x:Key="GridCommandStripBadgeTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11" />
                <Setter Property="FontFamily" Value="Bahnschrift SemiBold" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Foreground" Value="{DynamicResource DemoSecondaryTextBrush}" />
            </Style>
            <Style x:Key="FoundationsSubsectionTitleStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Bahnschrift SemiBold" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="Foreground" Value="{DynamicResource DemoHeaderTextBrush}" />
                <Setter Property="Margin" Value="0,0,0,10" />
            </Style>
            <Style x:Key="FoundationsTypographySampleStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource DemoPrimaryTextBrush}" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding SampleTone}" Value="secondary">
                        <Setter Property="Foreground" Value="{DynamicResource DemoSecondaryTextBrush}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding SampleTone}" Value="header">
                        <Setter Property="Foreground" Value="{DynamicResource DemoHeaderTextBrush}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding SampleTone}" Value="token">
                        <Setter Property="Foreground" Value="{DynamicResource DemoTokenTextBrush}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <DataTemplate x:Key="FoundationsHighlightTemplate">
                <Border Margin="0,0,10,10"
                        Style="{StaticResource DemoTokenBorderStyle}">
                    <TextBlock Text="{Binding}"
                               FontSize="11"
                               Foreground="{DynamicResource DemoTokenTextBrush}" />
                </Border>
            </DataTemplate>
            <DataTemplate x:Key="FoundationsTypographyTokenTemplate">
                <Border Margin="0,0,0,12"
                        Padding="14"
                        Background="{DynamicResource DemoTokenBackgroundBrush}"
                        BorderBrush="{DynamicResource DemoTokenBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="240" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding TokenName}"
                                       FontSize="11"
                                       FontFamily="Bahnschrift SemiBold"
                                       Foreground="{DynamicResource DemoHeaderTextBrush}" />
                            <TextBlock Margin="0,4,0,0"
                                       Text="{Binding Role}"
                                       FontSize="14"
                                       FontFamily="Bahnschrift SemiBold"
                                       Foreground="{DynamicResource DemoPrimaryTextBrush}" />
                            <TextBlock Margin="0,6,0,0"
                                       Text="{Binding Usage}"
                                       FontSize="12"
                                       Foreground="{DynamicResource DemoSecondaryTextBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <Border Grid.Column="1"
                                Margin="18,0,0,0"
                                Padding="14,12"
                                Background="{DynamicResource DemoPanelBackgroundBrush}"
                                BorderBrush="{DynamicResource DemoPanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10">
                            <StackPanel>
                                <TextBlock Text="{Binding SampleText}"
                                           Style="{StaticResource FoundationsTypographySampleStyle}"
                                           FontFamily="{Binding FontFamilyName}"
                                           FontSize="{Binding FontSize}"
                                           FontWeight="{Binding FontWeight}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,8,0,0"
                                           Text="{Binding StyleSummary}"
                                           FontSize="11"
                                           Foreground="{DynamicResource DemoTokenTextBrush}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </DataTemplate>
            <DataTemplate x:Key="FoundationsColorTokenTemplate">
                <Border Margin="0,0,0,10"
                        Padding="12"
                        Background="{DynamicResource DemoTokenBackgroundBrush}"
                        BorderBrush="{DynamicResource DemoTokenBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="{Binding TokenName}"
                                       FontSize="11"
                                       FontFamily="Bahnschrift SemiBold"
                                       Foreground="{DynamicResource DemoHeaderTextBrush}" />
                            <TextBlock Margin="0,4,0,0"
                                       Text="{Binding Usage}"
                                       FontSize="12"
                                       Foreground="{DynamicResource DemoSecondaryTextBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                            <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="{Binding DataContext.FoundationsDayLabel, RelativeSource={RelativeSource AncestorType=Window}}"
                                           FontSize="10"
                                           Foreground="{DynamicResource DemoSecondaryTextBrush}"
                                           HorizontalAlignment="Center" />
                                <Border Width="82"
                                        Height="28"
                                        Margin="0,4,0,0"
                                        Background="{Binding DayHex}"
                                        BorderBrush="{DynamicResource DemoPanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6" />
                                <TextBlock Margin="0,4,0,0"
                                           FontSize="10"
                                           Foreground="{DynamicResource DemoTokenTextBrush}"
                                           HorizontalAlignment="Center"
                                           Text="{Binding DayHex}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="{Binding DataContext.FoundationsNightLabel, RelativeSource={RelativeSource AncestorType=Window}}"
                                           FontSize="10"
                                           Foreground="{DynamicResource DemoSecondaryTextBrush}"
                                           HorizontalAlignment="Center" />
                                <Border Width="82"
                                        Height="28"
                                        Margin="0,4,0,0"
                                        Background="{Binding NightHex}"
                                        BorderBrush="{DynamicResource DemoPanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6" />
                                <TextBlock Margin="0,4,0,0"
                                           FontSize="10"
                                           Foreground="{DynamicResource DemoTokenTextBrush}"
                                           HorizontalAlignment="Center"
                                           Text="{Binding NightHex}" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
            </DataTemplate>
            <DataTemplate x:Key="FoundationsMeasureTokenTemplate">
                <Border Margin="0,0,0,10"
                        Padding="12"
                        Background="{DynamicResource DemoTokenBackgroundBrush}"
                        BorderBrush="{DynamicResource DemoTokenBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="76" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="64"
                                Height="32"
                                Background="{DynamicResource DemoPlatformBadgeBackgroundBrush}"
                                BorderBrush="{DynamicResource DemoPlatformBadgeBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="Bahnschrift SemiBold"
                                       FontSize="12"
                                       Foreground="{DynamicResource DemoPlatformBadgeTextBrush}"
                                       Text="{Binding Value}" />
                        </Border>
                        <StackPanel Grid.Column="1"
                                    Margin="12,0,0,0">
                            <TextBlock Text="{Binding TokenName}"
                                       FontSize="11"
                                       FontFamily="Bahnschrift SemiBold"
                                       Foreground="{DynamicResource DemoHeaderTextBrush}" />
                            <TextBlock Margin="0,4,0,0"
                                       Text="{Binding Usage}"
                                       FontSize="12"
                                       Foreground="{DynamicResource DemoSecondaryTextBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>
            </DataTemplate>
            <DataTemplate x:Key="DefinitionManagerBulletTemplate">
                <Border Margin="0,0,0,10"
                        Style="{StaticResource DemoTokenBorderStyle}">
                    <TextBlock Text="{Binding}"
                               FontSize="12"
                               Foreground="{DynamicResource DemoPrimaryTextBrush}"
                               TextWrapping="Wrap" />
                </Border>
            </DataTemplate>
            <DataTemplate x:Key="DefinitionManagerFieldTemplate">
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="132" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding Label}"
                               FontSize="11"
                               FontFamily="Bahnschrift SemiBold"
                               Foreground="{DynamicResource DemoHeaderTextBrush}" />
                    <TextBlock Grid.Column="1"
                               Margin="12,0,0,0"
                               Text="{Binding Value}"
                               FontSize="12"
                               Foreground="{DynamicResource DemoPrimaryTextBrush}"
                               TextWrapping="Wrap" />
                </Grid>
            </DataTemplate>
            <DataTemplate x:Key="LicenseFileTemplate">
                <TextBlock Margin="0,0,0,4"
                           Text="{Binding}"
                           FontSize="12"
                           Foreground="{DynamicResource DemoPrimaryTextBrush}"
                           TextWrapping="Wrap" />
            </DataTemplate>
            <DataTemplate x:Key="ThirdPartyLicenseEntryTemplate">
                <Border Margin="0,0,0,14"
                        Style="{StaticResource DemoSurfaceBorderStyle}"
                        Padding="18">
                    <StackPanel>
                        <TextBlock Text="{Binding ComponentName}"
                                   Style="{StaticResource SectionHeadlineStyle}" />
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding DataContext.LicenseFieldUsedBy, RelativeSource={RelativeSource AncestorType=Window}}"
                                       FontSize="11"
                                       FontFamily="Bahnschrift SemiBold"
                                       Foreground="{DynamicResource DemoHeaderTextBrush}" />
                            <TextBlock Grid.Column="1"
                                       Margin="12,0,0,0"
                                       Text="{Binding UsedBy}"
                                       FontSize="12"
                                       Foreground="{DynamicResource DemoPrimaryTextBrush}"
                                       TextWrapping="Wrap" />
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding DataContext.LicenseFieldLicense, RelativeSource={RelativeSource AncestorType=Window}}"
                                       FontSize="11"
                                       FontFamily="Bahnschrift SemiBold"
                                       Foreground="{DynamicResource DemoHeaderTextBrush}" />
                            <TextBlock Grid.Column="1"
                                       Margin="12,0,0,0"
                                       Text="{Binding LicenseName}"
                                       FontSize="12"
                                       Foreground="{DynamicResource DemoPrimaryTextBrush}"
                                       TextWrapping="Wrap" />
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding DataContext.LicenseFieldCopyright, RelativeSource={RelativeSource AncestorType=Window}}"
                                       FontSize="11"
                                       FontFamily="Bahnschrift SemiBold"
                                       Foreground="{DynamicResource DemoHeaderTextBrush}" />
                            <TextBlock Grid.Column="1"
                                       Margin="12,0,0,0"
                                       Text="{Binding CopyrightNotice}"
                                       FontSize="12"
                                       Foreground="{DynamicResource DemoPrimaryTextBrush}"
                                       TextWrapping="Wrap" />
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding DataContext.LicenseFieldRequirement, RelativeSource={RelativeSource AncestorType=Window}}"
                                       FontSize="11"
                                       FontFamily="Bahnschrift SemiBold"
                                       Foreground="{DynamicResource DemoHeaderTextBrush}" />
                            <TextBlock Grid.Column="1"
                                       Margin="12,0,0,0"
                                       Text="{Binding RequirementSummary}"
                                       FontSize="12"
                                       Foreground="{DynamicResource DemoPrimaryTextBrush}"
                                       TextWrapping="Wrap" />
                        </Grid>
                        <TextBlock Margin="0,12,0,0"
                                   Text="{Binding DataContext.LicenseFieldFiles, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontSize="11"
                                   FontFamily="Bahnschrift SemiBold"
                                   Foreground="{DynamicResource DemoHeaderTextBrush}" />
                        <ItemsControl Margin="0,8,0,0"
                                      ItemsSource="{Binding LocalFiles}"
                                      ItemTemplate="{StaticResource LicenseFileTemplate}" />
                    </StackPanel>
                </Border>
            </DataTemplate>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition>
                <ColumnDefinition.Style>
                    <Style TargetType="ColumnDefinition">
                        <Setter Property="Width" Value="296" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDrawerOpen}" Value="False">
                                <Setter Property="Width" Value="76" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ColumnDefinition.Style>
            </ColumnDefinition>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Background="{DynamicResource DemoSidebarBackgroundBrush}" BorderBrush="{DynamicResource DemoSidebarBorderBrush}" BorderThickness="0,0,1,0">
            <Grid Margin="14,18,14,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button x:Name="DrawerCollapseButton"
                            Grid.Column="0"
                            Style="{StaticResource DrawerToggleButtonStyle}"
                            Command="{Binding ToggleDrawerCommand}"
                            ToolTip="{Binding DrawerCloseText}"
                            Content="&lt;&lt;"
                            Visibility="{Binding IsDrawerOpen, Converter={StaticResource BooleanToVisibilityConverter}}" />

                    <Button x:Name="DrawerExpandButton"
                            Grid.Column="0"
                            Style="{StaticResource DrawerToggleButtonStyle}"
                            Command="{Binding ToggleDrawerCommand}"
                            ToolTip="{Binding DrawerOpenText}"
                            Content="&gt;&gt;"
                            Visibility="{Binding IsDrawerClosed, Converter={StaticResource BooleanToVisibilityConverter}}" />

                    <StackPanel Grid.Column="1"
                                Margin="12,0,0,0"
                                Visibility="{Binding IsDrawerOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="{Binding AppTitle}"
                                   FontFamily="Bahnschrift SemiBold"
                                   FontSize="28"
                                   Foreground="{DynamicResource DemoPrimaryTextBrush}"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,4,0,0"
                                   Text="{Binding AppSubtitle}"
                                   FontSize="13"
                                   Foreground="{DynamicResource DemoSecondaryTextBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1"
                      Margin="0,18,0,0">
                    <ScrollViewer x:Name="SidebarNavigationScrollViewer"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Visibility="{Binding IsDrawerOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="{Binding LanguageLabelText}"
                                       FontFamily="Bahnschrift SemiBold"
                                       FontSize="14"
                                       Foreground="{DynamicResource DemoHeaderTextBrush}"
                                       Margin="0,0,0,8" />
                            <ComboBox x:Name="LanguagePickerComboBox"
                                      ItemsSource="{Binding LanguageOptions}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Code"
                                      SelectedValue="{Binding LanguageCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Background="{DynamicResource DemoInputBackgroundBrush}"
                                      BorderBrush="{DynamicResource DemoInputBorderBrush}"
                                      BorderThickness="1"
                                      Padding="10,6" />

                            <TextBlock Text="{Binding SearchPlaceholder}"
                                       FontFamily="Bahnschrift SemiBold"
                                       FontSize="14"
                                       Foreground="{DynamicResource DemoHeaderTextBrush}"
                                       Margin="0,22,0,8" />
                <Border Background="{DynamicResource DemoInputBackgroundBrush}"
                        BorderBrush="{DynamicResource DemoInputBorderBrush}"
                        BorderThickness="1"
                        styles:RoundedChildClipBehavior.ClipChildToBorder="True"
                        CornerRadius="10">
                    <TextBox x:Name="SidebarSearchTextBox"
                             BorderThickness="0"
                             Background="Transparent"
                                         Padding="12,9"
                                         FontSize="14"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                            </Border>

                            <TextBlock Text="{Binding ComponentsTitle}"
                                       FontFamily="Bahnschrift SemiBold"
                                       FontSize="14"
                                       Foreground="{DynamicResource DemoHeaderTextBrush}"
                                       Margin="0,26,0,10" />
                            <ItemsControl x:Name="DrawerGroupsItemsControl"
                                          ItemsSource="{Binding DrawerGroups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource DrawerGroupButtonStyle}"
                                                Command="{Binding DataContext.SelectDrawerGroupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding Id}"
                                                Tag="{Binding IsSelected}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Width="10"
                                                         Height="10"
                                                         Fill="{Binding AccentHex}"
                                                         VerticalAlignment="Top"
                                                         Margin="0,5,0,0" />
                                                <StackPanel Grid.Column="1"
                                                            Margin="12,0,0,0">
                                                    <TextBlock Text="{Binding Title}"
                                                               FontFamily="Bahnschrift SemiBold"
                                                               FontSize="16"
                                                               Foreground="{DynamicResource DemoPrimaryTextBrush}" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               Text="{Binding Description}"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource DemoSecondaryTextBrush}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Visibility="{Binding IsDrawerClosed, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl x:Name="DrawerRailGroupsItemsControl"
                                      ItemsSource="{Binding DrawerGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource DrawerRailButtonStyle}"
                                            Command="{Binding DataContext.SelectDrawerGroupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding Id}"
                                            Tag="{Binding IsSelected}"
                                            ToolTip="{Binding Title}">
                                        <Ellipse Width="10"
                                                 Height="10"
                                                 Fill="{Binding AccentHex}" />
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <shell:PhialeAppShell Grid.Column="1"
                              Margin="30,26,30,26"
                              ShellState="{Binding RelativeSource={RelativeSource AncestorType={x:Type shell:PhialeWindow}}, Path=ShellState}">
            <Grid>
                <Grid Visibility="{Binding IsOverviewVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <Grid Width="{Binding RelativeSource={RelativeSource AncestorType={x:Type ScrollContentPresenter}}, Path=ActualWidth}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0"
                                   Margin="0,0,0,16"
                                   Visibility="{Binding HasOverviewResults, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                   Text="{Binding EmptySearchText}" />

                        <ItemsControl Grid.Row="1"
                                      ItemsSource="{Binding VisibleSections}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,28">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Style="{StaticResource SectionHeadlineStyle}" Text="{Binding Title}" />
                                        <ItemsControl Grid.Row="1"
                                                      ItemsSource="{Binding Rows}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <ItemsControl ItemsSource="{Binding Examples}"
                                                                  Margin="0,0,0,16">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel Orientation="Horizontal" />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Button Width="330"
                                                                        Height="168"
                                                                        Margin="0,0,16,0"
                                                                        Style="{StaticResource OverviewCardButtonStyle}"
                                                                        Command="{Binding DataContext.SelectExampleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding Id}" />
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <Grid Visibility="{Binding IsDetailVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
