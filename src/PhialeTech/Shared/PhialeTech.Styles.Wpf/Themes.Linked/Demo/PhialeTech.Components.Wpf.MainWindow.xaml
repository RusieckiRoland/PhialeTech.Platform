                                                                               Text="{Binding ApplicationStateManagerSampleDefinition.Summary}"
                                                                               FontSize="13"
                                                                               Foreground="{DynamicResource DemoSecondaryTextBrush}"
                                                                               TextWrapping="Wrap" />
                                                                    <ItemsControl ItemsSource="{Binding ApplicationStateManagerSampleDefinition.Fields}"
                                                                                  ItemTemplate="{StaticResource DefinitionManagerFieldTemplate}" />
                                                                    <Border Margin="0,10,0,0"
                                                                            Padding="12"
                                                                            Background="{DynamicResource DemoTokenBackgroundBrush}"
                                                                            BorderBrush="{DynamicResource DemoTokenBorderBrush}"
                                                                            BorderThickness="1"
                                                                            CornerRadius="10">
                                                                        <StackPanel>
                                                                            <TextBlock Text="{Binding DefinitionManagerFieldConsumer}"
                                                                                       FontSize="11"
                                                                                       FontFamily="Bahnschrift SemiBold"
                                                                                       Foreground="{DynamicResource DemoHeaderTextBrush}" />
                                                                            <TextBlock Margin="0,6,0,0"
                                                                                       Text="{Binding ApplicationStateManagerSampleDefinition.ConsumerHint}"
