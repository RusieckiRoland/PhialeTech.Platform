                                                                                FieldChromeMode="InlineHint"
                                                                                MinValue="0"
                                                                                MaxValue="9999" />
                                                    <yamlInteger:YamlIntegerBox Width="320"
                                                                                Margin="0,18,0,0"
                                                                                Caption="Balance"
                                                                                CaptionPlacement="Left"
                                                                                Placeholder="Enter balance"
                                                                                FieldChromeMode="InlineHint"
                                                                                MinValue="-9999"
                                                                                MaxValue="9999" />
                                                    <yamlInteger:YamlIntegerBox Width="320"
                                                                                Margin="0,18,0,0"
                                                                                Caption="Balance"
                                                                                Text="-24"
                                                                                FieldChromeMode="InlineHint"
                                                                                MinValue="-9999"
                                                                                MaxValue="9999" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>
<ScrollViewer Visibility="{Binding ShowLicenseSurface, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <StackPanel>
                                            <Border Visibility="{Binding IsMyLicenseExample, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                    Style="{StaticResource FoundationsSectionBorderStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding LicenseMyPlaceholderTitle}"
                                                               Style="{StaticResource SectionHeadlineStyle}" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               Text="{Binding LicenseMyPlaceholderDescription}"
                                                               FontSize="13"
                                                               Foreground="{DynamicResource DemoSecondaryTextBrush}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                            <StackPanel Visibility="{Binding IsThirdPartyLicensesExample, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <Border Style="{StaticResource FoundationsSectionBorderStyle}">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding LicenseThirdPartyIntroTitle}"
                                                                   Style="{StaticResource SectionHeadlineStyle}" />
                                                        <TextBlock Margin="0,6,0,0"
                                                                   Text="{Binding LicenseThirdPartyIntroDescription}"
                                                                   FontSize="13"
                                                                   Foreground="{DynamicResource DemoSecondaryTextBrush}"
                                                                   TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Border>
                                                <ItemsControl Margin="0,16,0,0"
                                                              ItemsSource="{Binding ThirdPartyLicenseEntries}"
                                                              ItemTemplate="{StaticResource ThirdPartyLicenseEntryTemplate}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </ScrollViewer>
                                    <Border Visibility="{Binding ShowWebComponentsSurface, Converter={StaticResource BooleanToVisibilityConverter}}"
                                            Style="{StaticResource DemoSurfaceBorderStyle}"
                                            ClipToBounds="True"
                                            Padding="18">
                                        <ContentControl x:Name="WebHostSamplePresenter"
                                                        Focusable="False"
                                                        ClipToBounds="True"
                                                        HorizontalContentAlignment="Stretch"
                                                        VerticalContentAlignment="Stretch" />
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>

                    <TabItem Header="{Binding CodeTabText}">
                        <Grid Margin="0,20,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="{Binding FileLabelText}"
                                       FontFamily="Bahnschrift SemiBold"
                                       FontSize="14"
                                       Foreground="{DynamicResource DemoHeaderTextBrush}" />
                            <ComboBox x:Name="CodeFileComboBox"
                                      Grid.Row="1"
                                      Margin="0,10,0,16"
                                      Width="260"
                                      ItemsSource="{Binding AvailableCodeFiles}"
                                      SelectedItem="{Binding SelectedCodeFile, Mode=TwoWay}"
                                      TextSearch.TextPath="FileName">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FileName}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Border Grid.Row="2"
                                    Style="{StaticResource DemoCodeSurfaceBorderStyle}"
                                    Padding="0">
                                <TextBox x:Name="CodePreviewTextBox"
                                         Style="{StaticResource DemoCodeTextBoxStyle}"
                                         Text="{Binding SourceCodeText, Mode=OneWay}"
                                         IsReadOnly="True"
                                         VerticalContentAlignment="Stretch"
                                         BorderBrush="Transparent" />
                            </Border>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>
    </Grid>
</Window>

