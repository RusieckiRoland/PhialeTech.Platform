                                                                                       Content="Yaml overlay sheet"
                                                                                       IconKey="preview"
                                                                                       Tone="Primary"
                                                                                       Variant="ActionStrip"
                                                                                       CommandId="demo.modal.yaml.sheet"
                                                                                       ToolTip="Open a generated YamlApp form inside an overlay sheet"
                                                                                       Invoked="HandleHostedModalButtonInvoked" />
                                                            </WrapPanel>
                                                            <Border Margin="0,8,0,0"
                                                                    Padding="12"
                                                                    Background="{DynamicResource DemoPanelBackgroundBrush}"
                                                                    BorderBrush="{DynamicResource DemoPanelBorderBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="10">
                                                                <StackPanel>
                                                                    <TextBlock Text="Last hosted modal result"
                                                                               Style="{StaticResource FoundationsSubsectionTitleStyle}" />
                                                                    <TextBlock Margin="0,6,0,0"
                                                                               Foreground="{DynamicResource DemoPrimaryTextBrush}"
                                                                               Text="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=HostedModalLastResultText}"
                                                                               TextWrapping="Wrap" />
                                                                </StackPanel>
                                                            </Border>
                                                        </StackPanel>
                                                    </Border>

                                                    <Grid Margin="0,18,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="0.95*" />
                                                            <ColumnDefinition Width="20" />
                                                            <ColumnDefinition Width="1.25*" />
                                                        </Grid.ColumnDefinitions>

                                                        <Border Padding="12"
                                                                Background="{DynamicResource DemoTokenBackgroundBrush}"
                                                                BorderBrush="{DynamicResource DemoTokenBorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="10">
                                                            <StackPanel>
                                                                <TextBlock Text="Last command"
                                                                           Style="{StaticResource FoundationsSubsectionTitleStyle}" />
                                                                <TextBlock Margin="0,6,0,0"
                                                                           Foreground="{DynamicResource DemoPrimaryTextBrush}"
                                                                           Text="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=YamlPrimitiveLastCommandText}"
                                                                           TextWrapping="Wrap" />
                                                            </StackPanel>
                                                        </Border>

                                                        <Border Grid.Column="2"
                                                                Padding="12"
                                                                Background="{DynamicResource DemoTokenBackgroundBrush}"
                                                                BorderBrush="{DynamicResource DemoTokenBorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="10">
                                                            <StackPanel>
                                                                <TextBlock Text="YAML sample"
                                                                           Style="{StaticResource FoundationsSubsectionTitleStyle}" />
                                                                <TextBox Margin="0,8,0,0"
                                                                         Padding="0"
                                                                         BorderThickness="0"
                                                                         Background="Transparent"
                                                                         Foreground="{DynamicResource DemoPrimaryTextBrush}"
                                                                         FontFamily="Consolas"
                                                                         FontSize="12"
                                                                         IsReadOnly="True"
                                                                         AcceptsReturn="True"
                                                                         TextWrapping="NoWrap"
                                                                         HorizontalScrollBarVisibility="Auto"
                                                                         VerticalScrollBarVisibility="Disabled"
                                                                         Text="layout:&#10;  type: Column&#10;  items:&#10;    - type: Badge&#10;      text: Draft&#10;      iconKey: draft&#10;      tone: Accent&#10;      size: Compact&#10;      toolTip: Workflow status&#10;&#10;    - type: Row&#10;      items:&#10;        - type: Button&#10;          text: Validate&#10;          iconKey: validate&#10;          commandId: validate&#10;          variant: Toolbar&#10;          size: Compact&#10;          toolTip: Validate the current document&#10;&#10;        - type: Button&#10;          iconKey: history&#10;          commandId: history&#10;          variant: Toolbar&#10;          size: Compact&#10;          toolTip: Open activity history&#10;&#10;    - type: Row&#10;      items:&#10;        - type: Button&#10;          text: Cancel&#10;          iconKey: cancel&#10;          commandId: cancel&#10;          variant: ActionStrip&#10;          toolTip: Cancel editing&#10;&#10;        - type: Button&#10;          text: OK&#10;          iconKey: ok&#10;          commandId: confirm&#10;          tone: Primary&#10;          variant: ActionStrip&#10;          size: Regular&#10;          toolTip: Confirm and close" />
                                                            </StackPanel>
                                                        </Border>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                        </webHost:PhialeWebComponentScrollHost.HostedContent>
                                    </webHost:PhialeWebComponentScrollHost>
<ScrollViewer Visibility="{Binding ShowLicenseSurface, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <StackPanel>
                                            <Border Visibility="{Binding IsMyLicenseExample, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                    Style="{StaticResource FoundationsSectionBorderStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding LicenseMyPlaceholderTitle}"
                                                               Style="{StaticResource SectionHeadlineStyle}" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               Text="{Binding LicenseMyPlaceholderDescription}"
                                                               FontSize="13"
                                                               Foreground="{DynamicResource DemoSecondaryTextBrush}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                            <StackPanel Visibility="{Binding IsThirdPartyLicensesExample, Converter={StaticResource BooleanToVisibilityConverter}}">
