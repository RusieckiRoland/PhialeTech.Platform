<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PhialeTech.Shell.Wpf.Controls"
    xmlns:shellChrome="clr-namespace:System.Windows.Shell;assembly=PresentationFramework">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/PhialeTech.Styles.Wpf;component/Themes/Controls.Core.xaml" />
        <ResourceDictionary Source="pack://application:,,,/PhialeTech.Styles.Wpf;component/Themes/Shell.Styles.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style TargetType="{x:Type controls:PhialeWindow}">
        <Setter Property="Background" Value="{DynamicResource Brush.Shell.Window.Background}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="WindowStyle" Value="None" />
        <Setter Property="AllowsTransparency" Value="False" />
        <Setter Property="ResizeMode" Value="CanResize" />
        <Setter Property="CaptionHeight" Value="{DynamicResource Size.Shell.TitleBar.Height}" />
        <Setter Property="ResizeBorderThickness" Value="{DynamicResource Thickness.Shell.Window.ResizeBorderThickness}" />
        <Setter Property="WindowCornerRadius" Value="{DynamicResource CornerRadius.Shell.Window.Root}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:PhialeWindow}">
                    <Border Style="{StaticResource Shell.WindowRootBorderStyle}"
                            UseLayoutRounding="True"
                            SnapsToDevicePixels="True">
                        <Grid UseLayoutRounding="True"
                              SnapsToDevicePixels="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <controls:PhialeTitleBar Grid.Row="0"
                                                     Height="{TemplateBinding CaptionHeight}"
                                                     ShellState="{TemplateBinding ShellState}" />
                            <ContentPresenter Grid.Row="1"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:PhialeTitleBar}">
        <Setter Property="Height" Value="{DynamicResource Size.Shell.TitleBar.Height}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:PhialeTitleBar}">
                    <Border Style="{StaticResource Shell.TitleBarRootBorderStyle}">
                        <Grid shellChrome:WindowChrome.IsHitTestVisibleInChrome="False">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Vertical"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=ShellState.ApplicationTitle}"
                                           Style="{StaticResource Shell.TitleBarApplicationTitleTextStyle}" />
                                <TextBlock x:Name="ApplicationSubtitleText"
                                           Text="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=ShellState.ApplicationSubtitle}"
                                           Style="{StaticResource Shell.TitleBarApplicationSubtitleTextStyle}" />
                            </StackPanel>

                            <StackPanel x:Name="PART_LeadingCommandsHost"
                                        Grid.Column="1"
                                        Orientation="Horizontal"
                                        Margin="{DynamicResource Thickness.Shell.TitleBar.CommandHostMargin}"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        shellChrome:WindowChrome.IsHitTestVisibleInChrome="True" />

                            <StackPanel x:Name="PART_TrailingCommandsHost"
                                        Grid.Column="2"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Right"
                                        shellChrome:WindowChrome.IsHitTestVisibleInChrome="True" />

                            <StackPanel Grid.Column="3"
                                        Orientation="Horizontal"
                                        Margin="{DynamicResource Thickness.Shell.TitleBar.SystemButtonsMargin}"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Right"
                                        shellChrome:WindowChrome.IsHitTestVisibleInChrome="True">
                                <Button Style="{StaticResource Shell.TitleBarSystemButtonStyle}"
                                        Tag="system:minimize"
                                        Content="&#xE921;" />
                                <Button Style="{StaticResource Shell.TitleBarSystemButtonStyle}"
                                        Tag="system:maximize"
                                        Content="&#xE922;" />
                                <Button Style="{StaticResource Shell.TitleBarSystemCloseButtonStyle}"
                                        Tag="system:close"
                                        Content="&#xE8BB;" />
                            </StackPanel>
                    </Grid>
                </Border>
                <ControlTemplate.Triggers>
                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=ShellState.ApplicationSubtitle}" Value="">
                        <Setter TargetName="ApplicationSubtitleText" Property="Visibility" Value="Collapsed" />
                    </DataTrigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Setter.Value>
    </Setter>
</Style>

    <Style TargetType="{x:Type controls:PhialeAppShell}">
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:PhialeAppShell}">
                    <Grid Background="{DynamicResource Brush.Shell.Window.Background}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="NavigationRailColumn"
                                              Width="{DynamicResource GridLength.Shell.NavigationRail.Width}" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="NavigationRailHost"
                                Grid.Column="0"
                                Style="{StaticResource Shell.NavigationRailBorderStyle}">
                            <StackPanel x:Name="PART_NavigationHost" />
                        </Border>

                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition x:Name="StatusBarRow" Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border x:Name="ViewHeaderHost"
                                    Grid.Row="0"
                                    Style="{StaticResource Shell.ViewHeaderBorderStyle}">
                                <StackPanel>
                                    <TextBlock x:Name="ViewTitleText"
                                               Text="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=ShellState.ViewTitle}"
                                               Style="{StaticResource Shell.ViewTitleTextStyle}" />
                                    <TextBlock x:Name="ViewDescriptionText"
                                               Text="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=ShellState.ViewDescription}"
                                               Style="{StaticResource Shell.ViewDescriptionTextStyle}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1"
                                    Style="{StaticResource Shell.ContentHostBorderStyle}">
                                <ContentPresenter Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                            </Border>

                            <Border x:Name="StatusBarHost"
                                    Grid.Row="2"
                                    Style="{StaticResource Shell.StatusBarBorderStyle}">
                                <StackPanel x:Name="PART_StatusHost"
                                            Orientation="Horizontal" />
                            </Border>
                        </Grid>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=ShellState.NavigationItems.Count}" Value="0">
                            <Setter TargetName="NavigationRailHost" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="NavigationRailColumn" Property="ColumnDefinition.Width" Value="{DynamicResource GridLength.Shell.NavigationRail.Collapsed}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=ShellState.StatusItems.Count}" Value="0">
                            <Setter TargetName="StatusBarHost" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="StatusBarRow" Property="RowDefinition.Height" Value="{DynamicResource GridLength.Shell.StatusBar.CollapsedHeight}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=ShellState.ViewDescription}" Value="">
                            <Setter TargetName="ViewDescriptionText" Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
