<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <Style x:Key="FocusVisualStyle.Ring" TargetType="{x:Type Control}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate>
                    <Rectangle
                        Margin="1"
                        RadiusX="3"
                        RadiusY="3"
                        SnapsToDevicePixels="True"
                        Stroke="{DynamicResource Brush.Focus.Ring}"
                        StrokeThickness="2" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Text.Secondary" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Normal" />
    </Style>

    <Style x:Key="Text.Muted" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Muted}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Normal" />
    </Style>

    <FontFamily x:Key="Text.ControlTitle.FontFamily">Bahnschrift SemiBold</FontFamily>
    <sys:Double x:Key="Text.ControlTitle.FontSize">22</sys:Double>
    <FontFamily x:Key="Text.ControlLabel.FontFamily">Bahnschrift SemiBold</FontFamily>
    <sys:Double x:Key="Text.ControlLabel.FontSize">15</sys:Double>
    <FontFamily x:Key="Text.Label.FontFamily">Bahnschrift SemiBold</FontFamily>
    <sys:Double x:Key="Text.Label.FontSize">14</sys:Double>
    <FontFamily x:Key="Text.Support.FontFamily">Segoe UI</FontFamily>
    <sys:Double x:Key="Text.Support.FontSize">13</sys:Double>
    <FontFamily x:Key="Text.FormTitle.FontFamily">Bahnschrift SemiBold</FontFamily>
    <sys:Double x:Key="Text.FormTitle.FontSize">18</sys:Double>
    <FontFamily x:Key="Text.FormSubtitle.FontFamily">Bahnschrift SemiBold</FontFamily>
    <sys:Double x:Key="Text.FormSubtitle.FontSize">13</sys:Double>
    <FontFamily x:Key="Text.FormDescription.FontFamily">Segoe UI</FontFamily>
    <sys:Double x:Key="Text.FormDescription.FontSize">12</sys:Double>
    <FontFamily x:Key="Text.FormMeta.FontFamily">Segoe UI</FontFamily>
    <sys:Double x:Key="Text.FormMeta.FontSize">12</sys:Double>
    <FontFamily x:Key="Text.FormSection.FontFamily">Bahnschrift SemiBold</FontFamily>
    <sys:Double x:Key="Text.FormSection.FontSize">14</sys:Double>
    <FontFamily x:Key="Text.FormFooter.FontFamily">Segoe UI</FontFamily>
    <sys:Double x:Key="Text.FormFooter.FontSize">12</sys:Double>
    <FontFamily x:Key="Text.Icon.FontFamily">Segoe MDL2 Assets</FontFamily>
    <sys:Double x:Key="Text.Icon.FontSize">12</sys:Double>
    <FontFamily x:Key="Text.Badge.FontFamily">Bahnschrift SemiBold</FontFamily>
    <sys:Double x:Key="Text.Badge.FontSize">12</sys:Double>
    <FontFamily x:Key="Text.Button.FontFamily">Bahnschrift SemiBold</FontFamily>
    <sys:Double x:Key="Text.Button.FontSize">13</sys:Double>

    <FontFamily x:Key="YamlTextBox.Caption.FontFamily">Bahnschrift SemiBold</FontFamily>
    <sys:Double x:Key="YamlTextBox.Caption.FontSize">14</sys:Double>
    <FontFamily x:Key="YamlTextBox.Support.FontFamily">Segoe UI</FontFamily>
    <sys:Double x:Key="YamlTextBox.Support.FontSize">12</sys:Double>
    <FontFamily x:Key="YamlTextBox.Editor.FontFamily">Segoe UI</FontFamily>
    <sys:Double x:Key="YamlTextBox.Card.CornerRadius">12</sys:Double>
    <CornerRadius x:Key="YamlTextBox.Card.CornerRadius.Border">12</CornerRadius>
    <sys:Double x:Key="YamlTextBox.Input.CornerRadius">9</sys:Double>
    <CornerRadius x:Key="YamlTextBox.Input.CornerRadius.Border">9</CornerRadius>
    <sys:Double x:Key="YamlTextBox.Framed.MinHeight">94</sys:Double>
    <sys:Double x:Key="YamlTextBox.Inline.MinHeight">94</sys:Double>
    <Thickness x:Key="YamlTextBox.Framed.EditorMargin">14,32,14,26</Thickness>
    <Thickness x:Key="YamlTextBox.Inline.EditorMargin">0,32,0,26</Thickness>
    <sys:Double x:Key="YamlTextBox.Framed.Editor.FontSize">13</sys:Double>
    <sys:Double x:Key="YamlTextBox.Inline.Editor.FontSize">13</sys:Double>
    <sys:Double x:Key="YamlTextBox.Framed.ClearButton.Width">18</sys:Double>
    <sys:Double x:Key="YamlTextBox.Framed.ClearButton.Height">18</sys:Double>
    <sys:Double x:Key="YamlTextBox.Inline.ClearButton.Width">18</sys:Double>
    <sys:Double x:Key="YamlTextBox.Inline.ClearButton.Height">18</sys:Double>

    <ControlTemplate x:Key="ChromeInlineActionButtonTemplate" TargetType="{x:Type Button}">
        <Border
            x:Name="ChromeInlineActionButtonRoot"
            Background="Transparent"
            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
            <Border
                x:Name="ChromeInlineActionButtonChrome"
                Margin="1"
                Background="{TemplateBinding Background}"
                CornerRadius="8"
                SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
                <ContentPresenter
                    Margin="{TemplateBinding Padding}"
                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                    RecognizesAccessKey="True" />
            </Border>
        </Border>
    </ControlTemplate>

    <ControlTemplate x:Key="ChromeHostedTextBoxTemplate" TargetType="{x:Type TextBox}">
        <ScrollViewer
            x:Name="PART_ContentHost"
            Background="Transparent"
            HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
            VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}" />
    </ControlTemplate>

    <Style TargetType="{x:Type TextBox}">
        <Setter Property="Background" Value="{DynamicResource Brush.Surface1}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="FocusVisualStyle" Value="{DynamicResource FocusVisualStyle.Ring}" />
        <Style.Triggers>
            <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Focus.Ring}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.6" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ComboBox.DropDownItem" TargetType="{x:Type ComboBoxItem}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                    <Border
                        x:Name="ComboBoxDropDownItemChrome"
                        Margin="2,1"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="6"
                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
                        <ContentPresenter
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            RecognizesAccessKey="True"
                            TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="ComboBoxDropDownItemChrome" Property="Background" Value="{DynamicResource Brush.Hover.Fill}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ComboBoxDropDownItemChrome" Property="Background" Value="{DynamicResource Brush.Selection.Active.Fill}" />
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Selection.Active.Text}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ComboBoxItem}" BasedOn="{StaticResource ComboBox.DropDownItem}" />

    <Style TargetType="{x:Type ComboBox}">
        <Setter Property="Background" Value="{DynamicResource Brush.Surface1}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource ComboBox.DropDownItem}" />
        <Setter Property="FocusVisualStyle" Value="{DynamicResource FocusVisualStyle.Ring}" />
        <Style.Triggers>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Focus.Ring}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.6" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="{x:Type DatePicker}">
        <Setter Property="Background" Value="{DynamicResource Brush.Surface1}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CalendarStyle" Value="{DynamicResource Calendar.Shared.Style}" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="FocusVisualStyle" Value="{DynamicResource FocusVisualStyle.Ring}" />
        <Style.Triggers>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Focus.Ring}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.6" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="Calendar.Shared.PopupHostStyle" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="Calendar.Shared.HeaderButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        <Setter Property="FontFamily" Value="{DynamicResource Text.ControlTitle.FontFamily}" />
        <Setter Property="FontSize" Value="{DynamicResource Text.ControlTitle.FontSize}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="12,4" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border
                        x:Name="CalendarHeaderButtonChrome"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="10"
                        SnapsToDevicePixels="True">
                        <ContentPresenter
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            RecognizesAccessKey="True"
                            TextElement.FontFamily="{TemplateBinding FontFamily}"
                            TextElement.FontSize="{TemplateBinding FontSize}"
                            TextElement.FontWeight="{TemplateBinding FontWeight}"
                            TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="CalendarHeaderButtonChrome" Property="Background" Value="{DynamicResource Brush.Hover.Fill}" />
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="CalendarHeaderButtonChrome" Property="Background" Value="{DynamicResource Brush.Surface2}" />
                            <Setter TargetName="CalendarHeaderButtonChrome" Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
                            <Setter TargetName="CalendarHeaderButtonChrome" Property="BorderThickness" Value="1" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="CalendarHeaderButtonChrome" Property="BorderBrush" Value="{DynamicResource Brush.Focus.Ring}" />
                            <Setter TargetName="CalendarHeaderButtonChrome" Property="BorderThickness" Value="1" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Calendar.Shared.NavButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Width" Value="38" />
        <Setter Property="Height" Value="38" />
        <Setter Property="MinWidth" Value="38" />
        <Setter Property="MinHeight" Value="38" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="{DynamicResource Brush.Surface1}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Accent.Strong}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border
                        x:Name="CalendarNavButtonChrome"
                        Width="{TemplateBinding Width}"
                        Height="{TemplateBinding Height}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="10"
                        SnapsToDevicePixels="True">
                        <Grid>
                            <Path
                                x:Name="CalendarNavGlyph"
                                Width="11"
                                Height="15"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Data="M 6.5 1 L 1.5 6 L 6.5 11"
                                Stroke="{TemplateBinding Foreground}"
                                StrokeEndLineCap="Round"
                                StrokeLineJoin="Round"
                                StrokeStartLineCap="Round"
                                StrokeThickness="2.2" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Tag" Value="Next">
                            <Setter TargetName="CalendarNavGlyph" Property="Data" Value="M 1.5 1 L 6.5 6 L 1.5 11" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="CalendarNavButtonChrome" Property="Background" Value="{DynamicResource Brush.Hover.Fill}" />
                            <Setter TargetName="CalendarNavButtonChrome" Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="CalendarNavButtonChrome" Property="Background" Value="{DynamicResource Brush.Surface2}" />
                            <Setter TargetName="CalendarNavButtonChrome" Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Accent.Strong}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="CalendarNavButtonChrome" Property="BorderBrush" Value="{DynamicResource Brush.Focus.Ring}" />
                            <Setter TargetName="CalendarNavButtonChrome" Property="Background" Value="{DynamicResource Brush.Surface1}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.42" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Calendar.Shared.TodayButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Accent}" />
        <Setter Property="FontFamily" Value="{DynamicResource Text.Support.FontFamily}" />
        <Setter Property="FontSize" Value="{DynamicResource Text.Support.FontSize}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border
                        x:Name="CalendarTodayButtonChrome"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="9"
                        SnapsToDevicePixels="True">
                        <ContentPresenter
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            RecognizesAccessKey="True"
                            TextElement.FontFamily="{TemplateBinding FontFamily}"
                            TextElement.FontSize="{TemplateBinding FontSize}"
                            TextElement.FontWeight="{TemplateBinding FontWeight}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="CalendarTodayButtonChrome" Property="Background" Value="{DynamicResource Brush.Hover.Fill}" />
                            <Setter TargetName="CalendarTodayButtonChrome" Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Accent.Strong}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="CalendarTodayButtonChrome" Property="Background" Value="{DynamicResource Brush.Surface2}" />
                            <Setter TargetName="CalendarTodayButtonChrome" Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="CalendarTodayButtonChrome" Property="BorderBrush" Value="{DynamicResource Brush.Focus.Ring}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.42" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Calendar.Shared.DayButtonStyle" TargetType="{x:Type primitives:CalendarDayButton}">
        <Setter Property="FontFamily" Value="{DynamicResource Text.ControlLabel.FontFamily}" />
        <Setter Property="FontSize" Value="{DynamicResource Text.ControlLabel.FontSize}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type primitives:CalendarDayButton}">
                    <Grid
                        Margin="2"
                        SnapsToDevicePixels="True"
                        UseLayoutRounding="True">
                        <Border
                            x:Name="CalendarDayButtonChrome"
                            Width="34"
                            Height="32"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10"
                            SnapsToDevicePixels="True"
                            UseLayoutRounding="True">
                            <ContentPresenter
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                ContentSource="Content"
                                RecognizesAccessKey="True"
                                TextElement.FontFamily="{TemplateBinding FontFamily}"
                                TextElement.FontSize="{TemplateBinding FontSize}"
                                TextElement.FontWeight="{TemplateBinding FontWeight}" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="CalendarDayButtonChrome" Property="Background" Value="{DynamicResource Brush.Hover.Fill}" />
                            <Setter TargetName="CalendarDayButtonChrome" Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
                        </Trigger>
                        <Trigger Property="IsToday" Value="True">
                            <Setter TargetName="CalendarDayButtonChrome" Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="CalendarDayButtonChrome" Property="Background" Value="{DynamicResource Brush.Selection.Active.Fill}" />
                            <Setter TargetName="CalendarDayButtonChrome" Property="BorderBrush" Value="{DynamicResource Brush.Selection.Active.Fill}" />
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Selection.Active.Text}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True" />
                                <Condition Property="IsToday" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="CalendarDayButtonChrome" Property="BorderBrush" Value="{DynamicResource Brush.Accent.Strong}" />
                        </MultiTrigger>
                        <Trigger Property="IsInactive" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Muted}" />
                            <Setter Property="Opacity" Value="0.78" />
                        </Trigger>
                        <Trigger Property="IsBlackedOut" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Muted}" />
                            <Setter Property="Opacity" Value="0.36" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.34" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource Calendar.Shared.DayButtonStyle}" TargetType="{x:Type primitives:CalendarDayButton}" />

    <Style x:Key="Calendar.Shared.MonthButtonStyle" TargetType="{x:Type primitives:CalendarButton}">
        <Setter Property="FontFamily" Value="{DynamicResource Text.ControlLabel.FontFamily}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="{DynamicResource Text.ControlLabel.FontSize}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type primitives:CalendarButton}">
                    <Border
                        x:Name="CalendarMonthButtonChrome"
                        MinWidth="60"
                        MinHeight="40"
                        Margin="3"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="10"
                        SnapsToDevicePixels="True">
                        <ContentPresenter
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            ContentSource="Content"
                            RecognizesAccessKey="True"
                            TextElement.FontFamily="{TemplateBinding FontFamily}"
                            TextElement.FontSize="{TemplateBinding FontSize}"
                            TextElement.FontWeight="{TemplateBinding FontWeight}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="CalendarMonthButtonChrome" Property="Background" Value="{DynamicResource Brush.Hover.Fill}" />
                            <Setter TargetName="CalendarMonthButtonChrome" Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}" />
                        </Trigger>
                        <Trigger Property="HasSelectedDays" Value="True">
                            <Setter TargetName="CalendarMonthButtonChrome" Property="Background" Value="{DynamicResource Brush.Selection.Active.Fill}" />
                            <Setter TargetName="CalendarMonthButtonChrome" Property="BorderBrush" Value="{DynamicResource Brush.Selection.Active.Fill}" />
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Selection.Active.Text}" />
                        </Trigger>
                        <Trigger Property="IsInactive" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Muted}" />
                            <Setter Property="Opacity" Value="0.62" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.34" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource Calendar.Shared.MonthButtonStyle}" TargetType="{x:Type primitives:CalendarButton}" />

    <Style x:Key="Calendar.Shared.ItemStyle" TargetType="{x:Type primitives:CalendarItem}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type primitives:CalendarItem}">
                    <ControlTemplate.Resources>
                        <DataTemplate x:Key="{ComponentResourceKey ResourceId=DayTitleTemplate, TypeInTargetAssembly={x:Type primitives:CalendarItem}}">
                            <TextBlock
