<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
        <ResourceDictionary.MergedDictionaries>
            <ResourceDictionary Source="Controls.Core.xaml" />
        </ResourceDictionary.MergedDictionaries>

        <Style x:Key="ColumnChipButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{DynamicResource FocusVisualStyle.Ring}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ColumnChipActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ColumnChipButtonStyle}">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="MinWidth" Value="18" />
            <Setter Property="MinHeight" Value="18" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ActionButtonBorder"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="999">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ActionButtonBorder" Property="Background" Value="{DynamicResource PgHoverBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ActionButtonBorder" Property="Background" Value="{DynamicResource PgInputBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=Root, Path=IsTouchInteractionMode}" Value="True">
                    <Setter Property="Width" Value="30" />
                    <Setter Property="Height" Value="30" />
                    <Setter Property="MinWidth" Value="30" />
                    <Setter Property="MinHeight" Value="30" />
                    <Setter Property="Background" Value="{DynamicResource PgInputBackgroundBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource PgControlBorderBrush}" />
                    <Setter Property="BorderThickness" Value="1" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PgActionButtonStyle" TargetType="Button" BasedOn="{StaticResource Button.Secondary}" />

        <Style x:Key="PgEditingComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource PgPrimaryTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="PgEditingComboBoxItemBorder"
                                Margin="0,1"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="PgEditingComboBoxItemBorder" Property="Background" Value="{DynamicResource PgHoverBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="PgEditingComboBoxItemBorder" Property="Background" Value="{DynamicResource PgSelectionBackgroundBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource PgSelectionTextBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="PgEditingComboBoxTemplate" TargetType="ComboBox">
            <Grid x:Name="PgEditingComboRoot"
                  Background="Transparent"
                  SnapsToDevicePixels="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="26" />
                </Grid.ColumnDefinitions>
                <ContentPresenter x:Name="ContentSite"
                                  Grid.Column="0"
                                  Margin="4,0,2,0"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center"
                                  Content="{TemplateBinding SelectionBoxItem}"
                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                  IsHitTestVisible="False"
                                  RecognizesAccessKey="True"
                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                  TextElement.Foreground="{TemplateBinding Foreground}" />
                <TextBox x:Name="PART_EditableTextBox"
                         Grid.Column="0"
                         Margin="4,0,2,0"
                         Background="Transparent"
                         BorderBrush="Transparent"
                         BorderThickness="0"
                         FocusVisualStyle="{x:Null}"
                         Foreground="{TemplateBinding Foreground}"
                         HorizontalAlignment="Stretch"
                         IsReadOnly="{TemplateBinding IsReadOnly}"
                         Padding="0"
                         SelectionBrush="{DynamicResource PgSelectionBackgroundBrush}"
                         SelectionTextBrush="{DynamicResource PgSelectionTextBrush}"
                         Template="{DynamicResource ChromeHostedTextBoxTemplate}"
                         VerticalAlignment="Center"
                         VerticalContentAlignment="Center"
                         Visibility="Hidden" />
                <ToggleButton x:Name="DropDownToggle"
                              Grid.Column="1"
                              MinWidth="26"
                              MinHeight="0"
                              Margin="0"
                              Padding="0"
                              Background="Transparent"
                              BorderBrush="Transparent"
                              BorderThickness="0"
                              ClickMode="Press"
                              Focusable="False"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              HorizontalContentAlignment="Center"
                              VerticalContentAlignment="Center"
                              IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                              OverridesDefaultStyle="True">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="PgEditingComboToggleHitArea"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                            </Border>
                        </ControlTemplate>
                    </ToggleButton.Template>
                    <Path x:Name="PgEditingComboChevron"
                          Width="10"
                          Height="6"
                          Data="M 1 1 L 5 5 L 9 1"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Stroke="{DynamicResource PgSecondaryMutedBrush}"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          StrokeStartLineCap="Round"
                          StrokeThickness="1.6" />
                </ToggleButton>
                <Popup x:Name="PART_Popup"
                       AllowsTransparency="True"
                       Focusable="False"
                       IsOpen="{TemplateBinding IsDropDownOpen}"
                       Placement="Bottom"
                       PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                       PopupAnimation="Fade">
                    <Border x:Name="PgEditingComboDropDownBorder"
                            MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                            Margin="0,6,0,0"
                            Background="{DynamicResource PgPanelBackgroundBrush}"
                            BorderBrush="{DynamicResource PgControlBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="4"
                            SnapsToDevicePixels="True">
                        <ScrollViewer MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      CanContentScroll="True"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                        </ScrollViewer>
                    </Border>
                </Popup>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="HasItems" Value="False">
                    <Setter TargetName="PgEditingComboDropDownBorder" Property="MinHeight" Value="24" />
                </Trigger>
                <Trigger Property="IsEditable" Value="True">
                    <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden" />
                    <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="PgEditingComboChevron" Property="Stroke" Value="{DynamicResource PgPrimaryTextBrush}" />
                </Trigger>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter TargetName="PgEditingComboChevron" Property="Stroke" Value="{DynamicResource PgAccentBrush}" />
                </Trigger>
                <Trigger Property="IsDropDownOpen" Value="True">
                    <Setter TargetName="PgEditingComboChevron" Property="Stroke" Value="{DynamicResource PgAccentBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="PgEditingComboRoot" Property="Opacity" Value="0.55" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="PgEditingCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="MinWidth" Value="24" />
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource PgControlBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PgPrimaryTextBrush}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid x:Name="PgEditingCheckBoxRoot"
                              Width="{TemplateBinding Width}"
                              Height="{TemplateBinding Height}"
                              Background="Transparent"
                              SnapsToDevicePixels="True">
                            <Border x:Name="PgEditingCheckBoxBox"
                                    Width="20"
                                    Height="20"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource PgRowAccentBackgroundBrush}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1.5"
                                    CornerRadius="4" />
                            <Path x:Name="PgEditingCheckBoxCheck"
                                  Width="12"
                                  Height="9"
                                  Data="M 0.5 4.5 L 4.2 8 L 11.5 0.5"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Stroke="{DynamicResource PgSelectionTextBrush}"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  StrokeStartLineCap="Round"
                                  StrokeThickness="2.1"
                                  Stretch="Fill"
                                  Visibility="Collapsed" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PgEditingCheckBoxBox" Property="BorderBrush" Value="{DynamicResource PgSelectionBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="PgEditingCheckBoxBox" Property="Background" Value="{DynamicResource PgSelectionBackgroundBrush}" />
                                <Setter TargetName="PgEditingCheckBoxBox" Property="BorderBrush" Value="{DynamicResource PgAccentBrush}" />
                                <Setter TargetName="PgEditingCheckBoxCheck" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="PgEditingCheckBoxBox" Property="BorderBrush" Value="{DynamicResource PgFocusRingBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="PgEditingCheckBoxRoot" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PgHeaderMenuButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="{DynamicResource PgGridHeaderMenuButtonSize}" />
            <Setter Property="Height" Value="{DynamicResource PgGridHeaderMenuButtonSize}" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{DynamicResource PgPanelBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PgControlBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource PgSecondaryMutedBrush}" />
            <Setter Property="FocusVisualStyle" Value="{DynamicResource FocusVisualStyle.Ring}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PgGridCornerOptionsButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource PgHeaderBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PgHeaderBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,1,2" />
            <Setter Property="Foreground" Value="{DynamicResource PgHeaderTextBrush}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CornerBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CornerBorder" Property="Background" Value="{DynamicResource PgFilterRowBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CornerBorder" Property="Background" Value="{DynamicResource PgSelectionInactiveBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PgMasterDetailCornerOptionsButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource PgPrimaryTextBrush}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="MasterDetailCornerBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MasterDetailCornerBorder" Property="Background" Value="{DynamicResource PgHoverBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="MasterDetailCornerBorder" Property="Background" Value="{DynamicResource PgSelectionInactiveBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PgColumnContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource PgPanelBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PgControlBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource PgPrimaryTextBrush}" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="MaxHeight" Value="560" />
            <Setter Property="HasDropShadow" Value="False" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          CanContentScroll="True"
                                          Background="{TemplateBinding Background}"
                                          MaxHeight="{TemplateBinding MaxHeight}">
                                <StackPanel IsItemsHost="True"
                                            KeyboardNavigation.DirectionalNavigation="Cycle" />
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PgColumnContextMenuSectionTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PgMutedTextBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="PgColumnContextMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource PgPrimaryTextBrush}" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="Margin" Value="2,1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FocusVisualStyle" Value="{DynamicResource FocusVisualStyle.Ring}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="ItemBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Grid x:Name="CheckboxStateHost"
                                          Grid.Column="0"
                                          Width="18"
                                          Height="18"
                                          Margin="0,0,10,0"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Visibility="Collapsed">
                                        <Border x:Name="CheckboxOutline"
                                                CornerRadius="4"
                                                BorderThickness="1"
                                                Background="Transparent" />
                                        <Path x:Name="CheckboxCheck"
                                              Data="M 4 9.5 L 7.5 13 L 14 6.5"
                                              StrokeThickness="1.8"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Stretch="Fill"
                                              Margin="1.5"
                                              Visibility="Collapsed" />
                                    </Grid>

                                    <Grid x:Name="RadioStateHost"
                                          Grid.Column="0"
                                          Width="18"
                                          Height="18"
                                          Margin="0,0,10,0"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Visibility="Collapsed">
                                        <Ellipse x:Name="RadioOutline"
                                                 Width="14"
                                                 Height="14"
                                                 StrokeThickness="1.2"
                                                 Fill="Transparent"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
                                        <Ellipse x:Name="RadioDot"
                                                 Width="6"
                                                 Height="6"
                                                 Visibility="Collapsed"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
                                    </Grid>

                                    <ContentPresenter x:Name="IconHost"
                                                      Grid.Column="1"
                                                      ContentSource="Icon"
                                                      Margin="0,0,10,0"
                                                      VerticalAlignment="Center" />
                                    <ContentPresenter Grid.Column="2"
                                                      ContentSource="Header"
                                                      RecognizesAccessKey="True"
                                                      VerticalAlignment="Center" />
                                    <Path x:Name="SubmenuChevron"
                                          Grid.Column="3"
                                          Margin="10,0,0,0"
                                          Width="8"
                                          Height="12"
                                          Data="M 2 2 L 6 6 L 2 10"
                                          Stretch="Fill"
                                          Visibility="Collapsed"
                                          VerticalAlignment="Center" />
                                </Grid>
                            </Border>

                            <Popup x:Name="SubmenuPopup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   HorizontalOffset="6"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Right"
                                   PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                   PopupAnimation="Fade">
                                <Border x:Name="SubmenuBorder"
                                        Background="{DynamicResource PgPanelBackgroundBrush}"
                                        BorderBrush="{DynamicResource PgControlBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="8"
                                        SnapsToDevicePixels="True">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  CanContentScroll="True"
                                                  Background="{DynamicResource PgPanelBackgroundBrush}"
                                                  MaxHeight="520">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Cycle" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Icon" Value="{x:Null}">
                                <Setter TargetName="IconHost" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="IsCheckable" Value="True">
                                <Setter TargetName="CheckboxStateHost" Property="Visibility" Value="Visible" />
                                <Setter TargetName="CheckboxOutline" Property="BorderBrush" Value="{DynamicResource PgControlBorderBrush}" />
                            </Trigger>
                            <Trigger Property="Tag" Value="radio">
                                <Setter TargetName="CheckboxStateHost" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="RadioStateHost" Property="Visibility" Value="Visible" />
                                <Setter TargetName="RadioOutline" Property="Stroke" Value="{DynamicResource PgControlBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource PgHoverBackgroundBrush}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource PgSelectionBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckboxOutline" Property="Background" Value="{DynamicResource PgSelectionBackgroundBrush}" />
                                <Setter TargetName="CheckboxOutline" Property="BorderBrush" Value="{DynamicResource PgAccentBrush}" />
                                <Setter TargetName="CheckboxCheck" Property="Visibility" Value="Visible" />
                                <Setter TargetName="CheckboxCheck" Property="Stroke" Value="{DynamicResource PgSelectionTextBrush}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Tag" Value="radio" />
                                    <Condition Property="IsChecked" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="RadioOutline" Property="Stroke" Value="{DynamicResource PgAccentBrush}" />
                                <Setter TargetName="RadioDot" Property="Visibility" Value="Visible" />
                                <Setter TargetName="RadioDot" Property="Fill" Value="{DynamicResource PgAccentBrush}" />
                            </MultiTrigger>
                            <Trigger Property="HasItems" Value="True">
                                <Setter TargetName="SubmenuChevron" Property="Visibility" Value="Visible" />
                                <Setter TargetName="SubmenuChevron" Property="Stroke" Value="{DynamicResource PgMutedTextBrush}" />
                                <Setter TargetName="SubmenuChevron" Property="StrokeThickness" Value="1.4" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource PgMutedTextBrush}" />
                                <Setter TargetName="ItemBorder" Property="Opacity" Value="0.68" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PgColumnContextMenuSeparatorStyle" TargetType="Separator">
            <Setter Property="Margin" Value="10,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1"
                                Background="{DynamicResource PgGridLineBrush}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PgGridHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PgHeaderTextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="PgGridSurfaceHeaderPresenterStyle" TargetType="ContentControl">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContentControl">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PgGridSurfaceCellPresenterStyle" TargetType="ContentControl">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContentControl">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PgGridSurfaceOverlayPresenterStyle" TargetType="ContentControl">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContentControl">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PgGridFilterTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource PgFilterInputBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PgFilterInputBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource PgPrimaryTextBrush}" />
            <Setter Property="Padding" Value="{DynamicResource PgGridFilterTextPadding}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="PgGridFilterCueIconStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PgFilterCueBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>

        <Style x:Key="PgGridFilterIconPathStyle" TargetType="Path">
            <Setter Property="Fill" Value="{DynamicResource PgFilterCueBrush}" />
            <Setter Property="Width" Value="12" />
            <Setter Property="Height" Value="12" />
            <Setter Property="Stretch" Value="Uniform" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>

        <Style x:Key="PgScrollBarButtonStyle" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="{DynamicResource PgScrollTrackBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PgScrollBorderBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="{TemplateBinding Background}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PgScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder"
                                Margin="1"
                                Background="{DynamicResource PgScrollThumbBrush}"
                                BorderBrush="{DynamicResource PgScrollBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="5" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder"
                                        Property="Background"
                                        Value="{DynamicResource PgScrollThumbHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PgScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Width" Value="12" />
            <Setter Property="Background" Value="{DynamicResource PgScrollTrackBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border x:Name="ScrollBarChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource PgScrollBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="0,0,6,6">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True"
                                   Focusable="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton x:Name="PART_DecreaseButton"
                                                  Style="{StaticResource PgScrollBarButtonStyle}"
                                                  Command="ScrollBar.PageUpCommand" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource PgScrollBarThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton x:Name="PART_IncreaseButton"
                                                  Style="{StaticResource PgScrollBarButtonStyle}"
                                                  Command="ScrollBar.PageDownCommand" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Height" Value="12" />
                                <Setter Property="Width" Value="Auto" />
                                <Setter TargetName="ScrollBarChrome" Property="CornerRadius" Value="6,6,0,0" />
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
                                <Setter TargetName="PART_DecreaseButton" Property="Command" Value="ScrollBar.PageLeftCommand" />
                                <Setter TargetName="PART_IncreaseButton" Property="Command" Value="ScrollBar.PageRightCommand" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar" BasedOn="{StaticResource PgScrollBarStyle}" />

        <Style TargetType="ScrollViewer">
            <Setter Property="Background" Value="{DynamicResource PgScrollCornerBrush}" />
        </Style>

        <Style x:Key="PgGroupingPanelVisibilityStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=Root, Path=HasHierarchy}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PgGroupChipBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="8,3" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=Root, Path=IsTouchInteractionMode}" Value="True">
                    <Setter Property="Padding" Value="10,6" />
                    <Setter Property="CornerRadius" Value="10" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PgGroupChipTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=Root, Path=IsTouchInteractionMode}" Value="True">
                    <Setter Property="FontSize" Value="12" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PgGroupChipActionTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=Root, Path=IsTouchInteractionMode}" Value="True">
                    <Setter Property="FontSize" Value="14" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PgFilterPanelVisibilityStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=Root, Path=HasHierarchy}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PgEmptyRowsBorderStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=Root, Path=HasRows}" Value="False">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
</ResourceDictionary>
