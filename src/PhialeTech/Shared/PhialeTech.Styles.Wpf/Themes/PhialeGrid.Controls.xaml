                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PgGridCornerOptionsButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource PgHeaderBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PgHeaderBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,2" />
        <Setter Property="Foreground" Value="{DynamicResource PgHeaderTextBrush}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
