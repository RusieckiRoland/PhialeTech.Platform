<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Controls.Core.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style x:Key="ColumnChipButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FocusVisualStyle" Value="{DynamicResource FocusVisualStyle.Ring}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style
        x:Key="ColumnChipActionButtonStyle"
        BasedOn="{StaticResource ColumnChipButtonStyle}"
        TargetType="Button">
        <Setter Property="Width" Value="18" />
        <Setter Property="Height" Value="18" />
        <Setter Property="MinWidth" Value="18" />
        <Setter Property="MinHeight" Value="18" />
        <Setter Property="Margin" Value="8,0,0,0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        x:Name="ActionButtonBorder"
                        Width="{TemplateBinding Width}"
                        Height="{TemplateBinding Height}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="999">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ActionButtonBorder" Property="Background" Value="{DynamicResource PgHoverBackgroundBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ActionButtonBorder" Property="Background" Value="{DynamicResource PgInputBackgroundBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <DataTrigger Binding="{Binding ElementName=Root, Path=IsTouchInteractionMode}" Value="True">
                <Setter Property="Width" Value="30" />
                <Setter Property="Height" Value="30" />
                <Setter Property="MinWidth" Value="30" />
                <Setter Property="MinHeight" Value="30" />
                <Setter Property="Background" Value="{DynamicResource PgInputBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource PgControlBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style
        x:Key="PgActionButtonStyle"
        BasedOn="{StaticResource Button.Secondary}"
        TargetType="Button" />

    <Style x:Key="PgWorkspacePanelTabControlStyle" TargetType="TabControl">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="{DynamicResource PgWorkspacePanelTabControlPadding}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabControl">
                    <Grid Background="Transparent" KeyboardNavigation.TabNavigation="Local">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TabPanel
                            Grid.Row="0"
                            Background="Transparent"
                            IsItemsHost="True" />
                        <ContentPresenter
                            Grid.Row="1"
                            Margin="{DynamicResource PgWorkspacePanelContentMargin}"
                            ContentSource="SelectedContent" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PgWorkspacePanelTabItemStyle" TargetType="TabItem">
        <Setter Property="Padding" Value="{DynamicResource PgWorkspacePanelTabItemPadding}" />
        <Setter Property="Margin" Value="{DynamicResource PgWorkspacePanelTabItemMargin}" />
        <Setter Property="Background" Value="{DynamicResource PgInputBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PgInputBorderBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource PgPanelTextBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border
                        x:Name="PgWorkspacePanelTabItemChrome"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource CornerRadius.Grid.RegionHeader}">
                        <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            ContentSource="Header" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="PgWorkspacePanelTabItemChrome" Property="Background" Value="{DynamicResource PgSelectionInactiveBackgroundBrush}" />
                            <Setter TargetName="PgWorkspacePanelTabItemChrome" Property="BorderBrush" Value="{DynamicResource PgAccentBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource PgPrimaryTextBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PgWorkspacePanelHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource PgPrimaryTextBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="PgWorkspacePanelCaptionTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource PgPanelTextBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="PgWorkspacePanelBodyTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource PgPanelTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="PgWorkspacePanelCardBorderStyle" TargetType="Border">
        <Setter Property="MinHeight" Value="{DynamicResource PgWorkspacePanelCardMinHeight}" />
        <Setter Property="Margin" Value="{DynamicResource PgWorkspacePanelCardMargin}" />
        <Setter Property="Padding" Value="{DynamicResource PgWorkspacePanelCardPadding}" />
        <Setter Property="Background" Value="{DynamicResource PgInputBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PgInputBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource CornerRadius.Grid.RegionHeader}" />
    </Style>

    <Style
        x:Key="PgWorkspacePanelWarningCardBorderStyle"
        BasedOn="{StaticResource PgWorkspacePanelCardBorderStyle}"
        TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource PgWarningBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PgWarningBorderBrush}" />
    </Style>

    <Style
        x:Key="PgWorkspacePanelLinkButtonStyle"
        BasedOn="{StaticResource Button.Tertiary}"
        TargetType="Button">
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Margin" Value="{DynamicResource PgWorkspacePanelInlineButtonMargin}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource PgAccentBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="PgWorkspacePanelExpandedTabStripStyle" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Bottom" />
        <Setter Property="Margin" Value="{DynamicResource PgWorkspacePanelExpandedTabStripMargin}" />
    </Style>

    <Style x:Key="PgWorkspacePanelCollapsedRailBorderStyle" TargetType="Border">
        <Setter Property="Width" Value="{DynamicResource PgGridSideToolCollapsedRailWidth}" />
        <Setter Property="Padding" Value="{DynamicResource PgWorkspacePanelCollapsedRailPadding}" />
        <Setter Property="Background" Value="{DynamicResource PgPanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PgPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource CornerRadius.Grid.RegionSurface}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="PgWorkspacePanelCollapsedRailTabStackStyle" TargetType="StackPanel">
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="-6,0,0,0" />
    </Style>

    <Style
        x:Key="PgWorkspacePanelExpandedTabButtonStyle"
        BasedOn="{StaticResource Button.Tertiary}"
        TargetType="Button">
        <Setter Property="Padding" Value="{DynamicResource PgWorkspacePanelBottomTabItemPadding}" />
        <Setter Property="Margin" Value="{DynamicResource PgWorkspacePanelBottomTabItemMargin}" />
        <Setter Property="MinWidth" Value="{DynamicResource PgWorkspacePanelExpandedTabMinWidth}" />
        <Setter Property="Height" Value="{DynamicResource PgWorkspacePanelExpandedTabHeight}" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Bottom" />
        <Setter Property="Foreground" Value="{DynamicResource PgPanelTextBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="BorderBrush" Value="{DynamicResource PgInputBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="{DynamicResource PgGridRegionSurfaceBackgroundBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid
                        MinWidth="{TemplateBinding MinWidth}"
                        Height="{TemplateBinding Height}"
                        SnapsToDevicePixels="True">
                        <Canvas IsHitTestVisible="False">
                            <Path
                                x:Name="PgWorkspacePanelExpandedTabChrome"
                                Width="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=ActualWidth}"
                                Height="{TemplateBinding Height}"
                                Data="M 0.5,0.5 L 5.5,16.5 Q 7.5,23.5 14.5,23.5 L 85.5,23.5 Q 92.5,23.5 94.5,16.5 L 99.5,0.5 Z"
                                Fill="{TemplateBinding Background}"
                                Stretch="Fill"
                                Stroke="{TemplateBinding BorderBrush}"
                                StrokeThickness="1" />
                        </Canvas>
                        <ContentPresenter
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PgWorkspacePanelExpandedTabChrome" Property="Stroke" Value="{DynamicResource PgAccentBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource PgAccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource PgAccentBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style
        x:Key="PgWorkspacePanelExpandedActiveTabButtonStyle"
        BasedOn="{StaticResource PgWorkspacePanelExpandedTabButtonStyle}"
        TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource PgAccentBrush}" />
    </Style>

    <Style
        x:Key="PgWorkspacePanelBottomTabButtonStyle"
        BasedOn="{StaticResource PgWorkspacePanelExpandedTabButtonStyle}"
        TargetType="Button" />

    <Style
        x:Key="PgWorkspacePanelCollapsedRailTabButtonStyle"
        BasedOn="{StaticResource Button.Tertiary}"
        TargetType="Button">
        <Setter Property="Width" Value="{DynamicResource PgWorkspacePanelCollapsedRailTabWidth}" />
        <Setter Property="MinHeight" Value="{DynamicResource PgWorkspacePanelCollapsedRailTabHeight}" />
        <Setter Property="Padding" Value="{DynamicResource PgWorkspacePanelCollapsedRailTabItemPadding}" />
        <Setter Property="Margin" Value="{DynamicResource PgWorkspacePanelCollapsedRailTabItemMargin}" />
        <Setter Property="Foreground" Value="{DynamicResource PgPanelTextBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="BorderBrush" Value="{DynamicResource PgInputBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="{DynamicResource PgGridRegionSurfaceBackgroundBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid
                        Width="{TemplateBinding Width}"
                        MinHeight="{TemplateBinding MinHeight}"
                        SnapsToDevicePixels="True">
                        <Canvas IsHitTestVisible="False">
                            <Path
                                x:Name="PgWorkspacePanelCollapsedRailTabChrome"
                                Width="{TemplateBinding Width}"
                                Height="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=ActualHeight}"
                                Data="M 0,0 L 22,3 Q 28,5 28,14 L 28,86 Q 28,95 22,97 L 0,100 Z"
                                Fill="{TemplateBinding Background}"
                                Stretch="Fill"
                                Stroke="{TemplateBinding BorderBrush}"
                                StrokeThickness="1" />
                        </Canvas>
                        <ContentPresenter
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PgWorkspacePanelCollapsedRailTabChrome" Property="Stroke" Value="{DynamicResource PgAccentBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource PgAccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource PgAccentBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style
        x:Key="PgWorkspacePanelCollapsedRailActiveTabButtonStyle"
        BasedOn="{StaticResource PgWorkspacePanelCollapsedRailTabButtonStyle}"
        TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource PgAccentBrush}" />
    </Style>

    <Style x:Key="PgGridToolsPanelLabelTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource PgPanelTextBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="PgGridToolsComboBoxItemStyle" TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource PgPrimaryTextBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="{DynamicResource PgGridToolsComboBoxItemPadding}" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border
                        x:Name="PgGridToolsComboBoxItemBorder"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="PgGridToolsComboBoxItemBorder" Property="Background" Value="{DynamicResource PgHoverBackgroundBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="PgGridToolsComboBoxItemBorder" Property="Background" Value="{DynamicResource PgSelectionBackgroundBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource PgSelectionTextBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PgGridToolsComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Background" Value="{DynamicResource PgInputBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PgInputBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource PgPrimaryTextBrush}" />
        <Setter Property="Padding" Value="{DynamicResource PgGridToolsComboBoxPadding}" />
        <Setter Property="MinHeight" Value="{DynamicResource PgGridToolsComboBoxMinHeight}" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource PgGridToolsComboBoxItemStyle}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid SnapsToDevicePixels="True">
                        <Border
                            x:Name="PgGridToolsComboBoxChrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{DynamicResource CornerRadius.Grid.RegionHeader}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ToggleButton
                                    x:Name="PgGridToolsComboBoxDropDownToggle"
                                    Grid.ColumnSpan="2"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    ClickMode="Press"
                                    Focusable="False"
                                    IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}" />
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <ContentPresenter
                                    Grid.Column="0"
                                    Margin="{TemplateBinding Padding}"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    Content="{TemplateBinding SelectionBoxItem}"
                                    ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                    ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                    ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                    IsHitTestVisible="False"
                                    TextElement.Foreground="{TemplateBinding Foreground}" />
                                <Path
                                    x:Name="PgGridToolsComboBoxChevron"
                                    Grid.Column="1"
                                    Width="10"
                                    Height="6"
                                    Margin="{DynamicResource PgGridToolsComboBoxChevronMargin}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Data="M 1 1 L 5 5 L 9 1"
                                    IsHitTestVisible="False"
                                    Stroke="{DynamicResource PgMutedTextBrush}"
                                    StrokeEndLineCap="Round"
                                    StrokeLineJoin="Round"
                                    StrokeStartLineCap="Round"
                                    StrokeThickness="1.6" />
                            </Grid>
                        </Border>
                        <Popup
                            AllowsTransparency="True"
                            Focusable="False"
                            IsOpen="{TemplateBinding IsDropDownOpen}"
                            Placement="Bottom"
                            PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                            PopupAnimation="Fade">
                            <Border
                                x:Name="PgGridToolsComboBoxDropDownBorder"
                                MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                Margin="{DynamicResource PgGridToolsComboBoxDropDownMargin}"
                                Background="{DynamicResource PgPanelBackgroundBrush}"
                                BorderBrush="{DynamicResource PgControlBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource CornerRadius.Grid.RegionHeader}"
                                SnapsToDevicePixels="True">
                                <ScrollViewer
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    CanContentScroll="True"
                                    HorizontalScrollBarVisibility="Disabled"
                                    VerticalScrollBarVisibility="Auto">
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PgGridToolsComboBoxChrome" Property="BorderBrush" Value="{DynamicResource PgHoverBorderBrush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="PgGridToolsComboBoxChrome" Property="BorderBrush" Value="{DynamicResource PgAccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PgEditingComboBoxItemStyle" TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource PgPrimaryTextBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border
                        x:Name="PgEditingComboBoxItemBorder"
                        Margin="0,1"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="6"
                        SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="PgEditingComboBoxItemBorder" Property="Background" Value="{DynamicResource PgHoverBackgroundBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="PgEditingComboBoxItemBorder" Property="Background" Value="{DynamicResource PgSelectionBackgroundBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource PgSelectionTextBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ControlTemplate x:Key="PgEditingComboBoxTemplate" TargetType="ComboBox">
        <Grid
            x:Name="PgEditingComboRoot"
            Background="Transparent"
            SnapsToDevicePixels="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="26" />
            </Grid.ColumnDefinitions>
            <ContentPresenter
                x:Name="ContentSite"
                Grid.Column="0"
                Margin="4,0,2,0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"
                Content="{TemplateBinding SelectionBoxItem}"
                ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                IsHitTestVisible="False"
                RecognizesAccessKey="True"
                SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                TextElement.Foreground="{TemplateBinding Foreground}" />
            <TextBox
                x:Name="PART_EditableTextBox"
                Grid.Column="0"
                Margin="4,0,2,0"
                Padding="0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"
                VerticalContentAlignment="Center"
                Background="Transparent"
                BorderBrush="Transparent"
                BorderThickness="0"
                FocusVisualStyle="{x:Null}"
                Foreground="{TemplateBinding Foreground}"
                IsReadOnly="{TemplateBinding IsReadOnly}"
                SelectionBrush="{DynamicResource PgSelectionBackgroundBrush}"
                SelectionTextBrush="{DynamicResource PgSelectionTextBrush}"
                Template="{DynamicResource ChromeHostedTextBoxTemplate}"
                Visibility="Hidden" />
            <ToggleButton
                x:Name="DropDownToggle"
                Grid.Column="1"
                MinWidth="26"
                MinHeight="0"
                Margin="0"
                Padding="0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Background="Transparent"
                BorderBrush="Transparent"
                BorderThickness="0"
                ClickMode="Press"
                Focusable="False"
                IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                OverridesDefaultStyle="True">
                <ToggleButton.Template>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border
                            x:Name="PgEditingComboToggleHitArea"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </ControlTemplate>
                </ToggleButton.Template>
                <Path
                    x:Name="PgEditingComboChevron"
                    Width="10"
                    Height="6"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Data="M 1 1 L 5 5 L 9 1"
                    Stroke="{DynamicResource PgSecondaryMutedBrush}"
                    StrokeEndLineCap="Round"
                    StrokeLineJoin="Round"
                    StrokeStartLineCap="Round"
                    StrokeThickness="1.6" />
            </ToggleButton>
            <Popup
                x:Name="PART_Popup"
                AllowsTransparency="True"
                Focusable="False"
                IsOpen="{TemplateBinding IsDropDownOpen}"
                Placement="Bottom"
                PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                PopupAnimation="Fade">
                <Border
                    x:Name="PgEditingComboDropDownBorder"
                    MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                    Margin="0,6,0,0"
                    Padding="4"
                    Background="{DynamicResource PgPanelBackgroundBrush}"
                    BorderBrush="{DynamicResource PgControlBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    SnapsToDevicePixels="True">
                    <ScrollViewer
                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                        Background="Transparent"
                        BorderThickness="0"
                        CanContentScroll="True"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">
                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                    </ScrollViewer>
                </Border>
            </Popup>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="HasItems" Value="False">
                <Setter TargetName="PgEditingComboDropDownBorder" Property="MinHeight" Value="24" />
            </Trigger>
            <Trigger Property="IsEditable" Value="True">
                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden" />
                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="PgEditingComboChevron" Property="Stroke" Value="{DynamicResource PgPrimaryTextBrush}" />
            </Trigger>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter TargetName="PgEditingComboChevron" Property="Stroke" Value="{DynamicResource PgAccentBrush}" />
            </Trigger>
            <Trigger Property="IsDropDownOpen" Value="True">
                <Setter TargetName="PgEditingComboChevron" Property="Stroke" Value="{DynamicResource PgAccentBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="PgEditingComboRoot" Property="Opacity" Value="0.55" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="PgEditingCheckBoxStyle" TargetType="CheckBox">
        <Setter Property="Width" Value="24" />
        <Setter Property="Height" Value="24" />
        <Setter Property="MinWidth" Value="24" />
        <Setter Property="MinHeight" Value="24" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource PgControlBorderBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource PgPrimaryTextBrush}" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid
                        x:Name="PgEditingCheckBoxRoot"
                        Width="{TemplateBinding Width}"
                        Height="{TemplateBinding Height}"
                        Background="Transparent"
                        SnapsToDevicePixels="True">
                        <Border
                            x:Name="PgEditingCheckBoxBox"
                            Width="20"
                            Height="20"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="{DynamicResource PgRowAccentBackgroundBrush}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1.5"
                            CornerRadius="4" />
                        <Path
                            x:Name="PgEditingCheckBoxCheck"
                            Width="12"
                            Height="9"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Data="M 0.5 4.5 L 4.2 8 L 11.5 0.5"
                            Stretch="Fill"
                            Stroke="{DynamicResource PgSelectionTextBrush}"
                            StrokeEndLineCap="Round"
                            StrokeLineJoin="Round"
                            StrokeStartLineCap="Round"
                            StrokeThickness="2.1"
                            Visibility="Collapsed" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PgEditingCheckBoxBox" Property="BorderBrush" Value="{DynamicResource PgSelectionBorderBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="PgEditingCheckBoxBox" Property="Background" Value="{DynamicResource PgSelectionBackgroundBrush}" />
                            <Setter TargetName="PgEditingCheckBoxBox" Property="BorderBrush" Value="{DynamicResource PgAccentBrush}" />
                            <Setter TargetName="PgEditingCheckBoxCheck" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="PgEditingCheckBoxBox" Property="BorderBrush" Value="{DynamicResource PgFocusRingBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="PgEditingCheckBoxRoot" Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PgHeaderMenuButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="{DynamicResource PgGridHeaderMenuButtonSize}" />
        <Setter Property="Height" Value="{DynamicResource PgGridHeaderMenuButtonSize}" />
        <Setter Property="Margin" Value="8,0,0,0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="{DynamicResource PgPanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PgControlBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource PgSecondaryMutedBrush}" />
        <Setter Property="FocusVisualStyle" Value="{DynamicResource FocusVisualStyle.Ring}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
