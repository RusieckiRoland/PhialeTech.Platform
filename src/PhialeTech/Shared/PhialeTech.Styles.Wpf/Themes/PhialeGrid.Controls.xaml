        </Setter>
    </Style>

    <Style x:Key="PgColumnContextMenuStyle" TargetType="ContextMenu">
        <Setter Property="Background" Value="{DynamicResource PgPanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PgControlBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource PgPrimaryTextBrush}" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="MaxHeight" Value="560" />
        <Setter Property="HasDropShadow" Value="False" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <Border
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="12">
                        <ScrollViewer
                            MaxHeight="{TemplateBinding MaxHeight}"
                            Background="{TemplateBinding Background}"
                            CanContentScroll="True"
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto">
                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle" />
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PgColumnContextMenuSectionTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource PgMutedTextBrush}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="PgColumnContextMenuItemStyle" TargetType="MenuItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource PgPrimaryTextBrush}" />
        <Setter Property="Padding" Value="12,9" />
        <Setter Property="Margin" Value="2,1" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FocusVisualStyle" Value="{DynamicResource FocusVisualStyle.Ring}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Grid SnapsToDevicePixels="True">
                        <Border
                            x:Name="ItemBorder"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Grid
                                    x:Name="CheckboxStateHost"
                                    Grid.Column="0"
                                    Width="18"
                                    Height="18"
                                    Margin="0,0,10,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Visibility="Collapsed">
                                    <Border
                                        x:Name="CheckboxOutline"
                                        Background="Transparent"
                                        BorderThickness="1"
                                        CornerRadius="4" />
                                    <Path
                                        x:Name="CheckboxCheck"
                                        Margin="1.5"
                                        Data="M 4 9.5 L 7.5 13 L 14 6.5"
                                        Stretch="Fill"
                                        StrokeEndLineCap="Round"
                                        StrokeLineJoin="Round"
                                        StrokeStartLineCap="Round"
                                        StrokeThickness="1.8"
                                        Visibility="Collapsed" />
                                </Grid>

                                <Grid
                                    x:Name="RadioStateHost"
                                    Grid.Column="0"
                                    Width="18"
                                    Height="18"
                                    Margin="0,0,10,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Visibility="Collapsed">
                                    <Ellipse
                                        x:Name="RadioOutline"
                                        Width="14"
                                        Height="14"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Fill="Transparent"
                                        StrokeThickness="1.2" />
                                    <Ellipse
                                        x:Name="RadioDot"
                                        Width="6"
                                        Height="6"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed" />
                                </Grid>

                                <ContentPresenter
                                    x:Name="IconHost"
                                    Grid.Column="1"
                                    Margin="0,0,10,0"
                                    VerticalAlignment="Center"
                                    ContentSource="Icon" />
                                <ContentPresenter
                                    Grid.Column="2"
                                    VerticalAlignment="Center"
                                    ContentSource="Header"
                                    RecognizesAccessKey="True" />
                                <Path
                                    x:Name="SubmenuChevron"
                                    Grid.Column="3"
                                    Width="8"
                                    Height="12"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    Data="M 2 2 L 6 6 L 2 10"
                                    Stretch="Fill"
                                    Visibility="Collapsed" />
                            </Grid>
                        </Border>

                        <Popup
                            x:Name="SubmenuPopup"
                            AllowsTransparency="True"
                            Focusable="False"
                            HorizontalOffset="6"
                            IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                            Placement="Right"
                            PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                            PopupAnimation="Fade">
                            <Border
                                x:Name="SubmenuBorder"
                                Padding="8"
                                Background="{DynamicResource PgPanelBackgroundBrush}"
                                BorderBrush="{DynamicResource PgControlBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                                <ScrollViewer
                                    MaxHeight="520"
                                    Background="{DynamicResource PgPanelBackgroundBrush}"
                                    CanContentScroll="True"
                                    HorizontalScrollBarVisibility="Disabled"
                                    VerticalScrollBarVisibility="Auto">
                                    <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle" />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Icon" Value="{x:Null}">
                            <Setter TargetName="IconHost" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsCheckable" Value="True">
                            <Setter TargetName="CheckboxStateHost" Property="Visibility" Value="Visible" />
                            <Setter TargetName="CheckboxOutline" Property="BorderBrush" Value="{DynamicResource PgControlBorderBrush}" />
                        </Trigger>
                        <Trigger Property="Tag" Value="radio">
                            <Setter TargetName="CheckboxStateHost" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="RadioStateHost" Property="Visibility" Value="Visible" />
                            <Setter TargetName="RadioOutline" Property="Stroke" Value="{DynamicResource PgControlBorderBrush}" />
                        </Trigger>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource PgHoverBackgroundBrush}" />
                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource PgSelectionBorderBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckboxOutline" Property="Background" Value="{DynamicResource PgSelectionBackgroundBrush}" />
                            <Setter TargetName="CheckboxOutline" Property="BorderBrush" Value="{DynamicResource PgAccentBrush}" />
                            <Setter TargetName="CheckboxCheck" Property="Visibility" Value="Visible" />
                            <Setter TargetName="CheckboxCheck" Property="Stroke" Value="{DynamicResource PgSelectionTextBrush}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Tag" Value="radio" />
                                <Condition Property="IsChecked" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="RadioOutline" Property="Stroke" Value="{DynamicResource PgAccentBrush}" />
                            <Setter TargetName="RadioDot" Property="Visibility" Value="Visible" />
                            <Setter TargetName="RadioDot" Property="Fill" Value="{DynamicResource PgAccentBrush}" />
                        </MultiTrigger>
                        <Trigger Property="HasItems" Value="True">
                            <Setter TargetName="SubmenuChevron" Property="Visibility" Value="Visible" />
                            <Setter TargetName="SubmenuChevron" Property="Stroke" Value="{DynamicResource PgMutedTextBrush}" />
                            <Setter TargetName="SubmenuChevron" Property="StrokeThickness" Value="1.4" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource PgMutedTextBrush}" />
                            <Setter TargetName="ItemBorder" Property="Opacity" Value="0.68" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PgColumnContextMenuSeparatorStyle" TargetType="Separator">
        <Setter Property="Margin" Value="10,8" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                    <Border Height="1" Background="{DynamicResource PgGridLineBrush}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PgGridHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource PgHeaderTextBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="PgGridSortGlyphTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource PgSortGlyphBrush}" />
        <Setter Property="FontSize" Value="{DynamicResource PgGridSortGlyphFontSize}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="PgGridSurfaceHeaderPresenterStyle" TargetType="ContentControl">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        SnapsToDevicePixels="True">
                        <ContentPresenter
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PgGridSurfaceCellPresenterStyle" TargetType="ContentControl">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PgGridSurfaceOverlayPresenterStyle" TargetType="ContentControl">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PgGridFilterTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource PgFilterInputBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PgFilterInputBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource PgPrimaryTextBrush}" />
        <Setter Property="Padding" Value="{DynamicResource PgGridFilterTextPadding}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="PgGridFilterCueIconStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource PgFilterCueBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="IsHitTestVisible" Value="False" />
    </Style>

    <Style x:Key="PgGridFilterIconPathStyle" TargetType="Path">
        <Setter Property="Fill" Value="{DynamicResource PgFilterCueBrush}" />
        <Setter Property="Width" Value="12" />
        <Setter Property="Height" Value="12" />
        <Setter Property="Stretch" Value="Uniform" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="IsHitTestVisible" Value="False" />
    </Style>

    <Style x:Key="PgScrollBarButtonStyle" TargetType="RepeatButton">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Background" Value="{DynamicResource PgScrollTrackBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PgScrollBorderBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="{TemplateBinding Background}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PgScrollBarThumbStyle" TargetType="Thumb">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border
                        x:Name="ThumbBorder"
                        Margin="1"
                        Background="{DynamicResource PgScrollThumbBrush}"
                        BorderBrush="{DynamicResource PgScrollBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="5" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource PgScrollThumbHoverBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PgScrollBarStyle" TargetType="ScrollBar">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Width" Value="12" />
        <Setter Property="Background" Value="{DynamicResource PgScrollTrackBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Border
                        x:Name="ScrollBarChrome"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{DynamicResource PgScrollBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="0,0,6,6">
                        <Track
                            x:Name="PART_Track"
                            Focusable="False"
                            IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton
                                    x:Name="PART_DecreaseButton"
                                    Command="ScrollBar.PageUpCommand"
                                    Style="{StaticResource PgScrollBarButtonStyle}" />
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource PgScrollBarThumbStyle}" />
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton
                                    x:Name="PART_IncreaseButton"
                                    Command="ScrollBar.PageDownCommand"
                                    Style="{StaticResource PgScrollBarButtonStyle}" />
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Orientation" Value="Horizontal">
                            <Setter Property="Height" Value="12" />
                            <Setter Property="Width" Value="Auto" />
                            <Setter TargetName="ScrollBarChrome" Property="CornerRadius" Value="6,6,0,0" />
                            <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
                            <Setter TargetName="PART_DecreaseButton" Property="Command" Value="ScrollBar.PageLeftCommand" />
                            <Setter TargetName="PART_IncreaseButton" Property="Command" Value="ScrollBar.PageRightCommand" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource PgScrollBarStyle}" TargetType="ScrollBar" />

    <Style TargetType="ScrollViewer">
        <Setter Property="Background" Value="{DynamicResource PgScrollCornerBrush}" />
    </Style>

    <Style x:Key="PgGroupingPanelVisibilityStyle" TargetType="Border">
        <Setter Property="Visibility" Value="Visible" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding ElementName=Root, Path=HasHierarchy}" Value="True">
                <Setter Property="Visibility" Value="Collapsed" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="PgGroupChipBorderStyle" TargetType="Border">
        <Setter Property="Padding" Value="8,3" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding ElementName=Root, Path=IsTouchInteractionMode}" Value="True">
                <Setter Property="Padding" Value="10,6" />
                <Setter Property="CornerRadius" Value="10" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="PgGroupChipTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding ElementName=Root, Path=IsTouchInteractionMode}" Value="True">
                <Setter Property="FontSize" Value="12" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="PgGroupChipActionTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding ElementName=Root, Path=IsTouchInteractionMode}" Value="True">
                <Setter Property="FontSize" Value="14" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="PgFilterPanelVisibilityStyle" TargetType="FrameworkElement">
        <Setter Property="Visibility" Value="Visible" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding ElementName=Root, Path=HasHierarchy}" Value="True">
                <Setter Property="Visibility" Value="Collapsed" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="PgEmptyRowsBorderStyle" TargetType="Border">
        <Setter Property="Visibility" Value="Collapsed" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding ElementName=Root, Path=HasRows}" Value="False">
                <Setter Property="Visibility" Value="Visible" />
            </DataTrigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
