                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="CornerBorder" Property="Background" Value="{DynamicResource PgFilterRowBackgroundBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="CornerBorder" Property="Background" Value="{DynamicResource PgSelectionInactiveBackgroundBrush}" />
