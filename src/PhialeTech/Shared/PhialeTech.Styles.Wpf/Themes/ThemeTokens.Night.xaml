    <SolidColorBrush x:Key="Brush.Button.Danger.Border" Color="{DynamicResource Color.Danger.Border}" />
    <SolidColorBrush x:Key="Brush.Button.Danger.Foreground" Color="{DynamicResource Color.Danger.Text}" />
    <SolidColorBrush x:Key="Brush.Button.Danger.HoverBackground" Color="#5B3136" />
    <SolidColorBrush x:Key="Brush.Button.Danger.HoverBorder" Color="#F08B95" />
    <SolidColorBrush x:Key="Brush.Button.Tertiary.Background" Color="#00FFFFFF" />
    <SolidColorBrush x:Key="Brush.Button.Tertiary.Border" Color="#00FFFFFF" />
    <SolidColorBrush x:Key="Brush.Button.Tertiary.Foreground" Color="{DynamicResource Color.Accent.Strong}" />
