    <SolidColorBrush x:Key="Brush.Selection.Inactive.Text" Color="{DynamicResource Color.Selection.Inactive.Text}" />
    <SolidColorBrush x:Key="Brush.Warning.Fill" Color="{DynamicResource Color.Warning.Fill}" />
    <SolidColorBrush x:Key="Brush.Warning.Border" Color="{DynamicResource Color.Warning.Border}" />
    <SolidColorBrush x:Key="Brush.Warning.Text" Color="{DynamicResource Color.Warning.Text}" />
    <SolidColorBrush x:Key="Brush.Danger.Fill" Color="{DynamicResource Color.Danger.Fill}" />
    <SolidColorBrush x:Key="Brush.Danger.Border" Color="{DynamicResource Color.Danger.Border}" />
    <SolidColorBrush x:Key="Brush.Danger.Text" Color="{DynamicResource Color.Danger.Text}" />
    <SolidColorBrush x:Key="Brush.Scroll.Track" Color="{DynamicResource Color.Scroll.Track}" />
    <SolidColorBrush x:Key="Brush.Scroll.Thumb" Color="{DynamicResource Color.Scroll.Thumb}" />
    <SolidColorBrush x:Key="Brush.Scroll.ThumbHover" Color="{DynamicResource Color.Scroll.ThumbHover}" />
    <SolidColorBrush x:Key="Brush.Scroll.Border" Color="{DynamicResource Color.Scroll.Border}" />
    <SolidColorBrush x:Key="Brush.Scroll.Corner" Color="{DynamicResource Color.Scroll.Corner}" />
    <SolidColorBrush x:Key="Brush.Badge.Fill" Color="{DynamicResource Color.Badge.Fill}" />
    <SolidColorBrush x:Key="Brush.Badge.Border" Color="{DynamicResource Color.Badge.Border}" />
    <SolidColorBrush x:Key="Brush.Badge.Text" Color="{DynamicResource Color.Badge.Text}" />

    <SolidColorBrush x:Key="Brush.Button.Primary.Background" Color="{DynamicResource Color.Accent}" />
    <SolidColorBrush x:Key="Brush.Button.Primary.Border" Color="{DynamicResource Color.Accent}" />
    <SolidColorBrush x:Key="Brush.Button.Primary.Foreground" Color="{DynamicResource Color.Text.Inverse}" />
    <SolidColorBrush x:Key="Brush.Button.Primary.HoverBackground" Color="{DynamicResource Color.Accent.Strong}" />
    <SolidColorBrush x:Key="Brush.Button.Primary.HoverBorder" Color="{DynamicResource Color.Accent.Strong}" />
    <SolidColorBrush x:Key="Brush.Button.Secondary.Background" Color="#2A3240" />
    <SolidColorBrush x:Key="Brush.Button.Secondary.Border" Color="#4A556A" />
    <SolidColorBrush x:Key="Brush.Button.Secondary.Foreground" Color="#ECF1F8" />
