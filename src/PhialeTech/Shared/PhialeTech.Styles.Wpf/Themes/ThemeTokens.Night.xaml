<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="Color.Surface0">#171C25</Color>
    <Color x:Key="Color.Surface1">#1E232D</Color>
    <Color x:Key="Color.Surface2">#242B36</Color>
    <Color x:Key="Color.Surface3">#202733</Color>
    <Color x:Key="Color.Border.Subtle">#343C4B</Color>
    <Color x:Key="Color.Border.Default">#3E4657</Color>
    <Color x:Key="Color.Border.Strong">#5A667D</Color>
    <Color x:Key="Color.Text.Primary">#F4F6FA</Color>
    <Color x:Key="Color.Text.Secondary">#D1D9E7</Color>
    <Color x:Key="Color.Text.Muted">#BBC5D4</Color>
    <Color x:Key="Color.Text.Inverse">#07101F</Color>
    <Color x:Key="Color.Accent">#5D9FFF</Color>
    <Color x:Key="Color.Accent.Strong">#84B8FF</Color>
    <Color x:Key="Color.Hover.Fill">#273144</Color>
    <Color x:Key="Color.Focus.Ring">#84B8FF</Color>
    <Color x:Key="Color.Selection.Active.Fill">#274E7A</Color>
    <Color x:Key="Color.Selection.Active.Border">#84B8FF</Color>
    <Color x:Key="Color.Selection.Active.Text">#F8FBFF</Color>
    <Color x:Key="Color.Selection.Inactive.Fill">#2C3443</Color>
    <Color x:Key="Color.Selection.Inactive.Border">#586782</Color>
    <Color x:Key="Color.Selection.Inactive.Text">#DCE6F6</Color>
    <Color x:Key="Color.Warning.Fill">#3B3221</Color>
    <Color x:Key="Color.Warning.Border">#A8801D</Color>
    <Color x:Key="Color.Warning.Text">#FFD882</Color>
    <Color x:Key="Color.Danger.Fill">#4A2528</Color>
    <Color x:Key="Color.Danger.Border">#DD6B74</Color>
    <Color x:Key="Color.Danger.Text">#FFD9DC</Color>
    <Color x:Key="Color.Scroll.Track">#232B38</Color>
    <Color x:Key="Color.Scroll.Thumb">#4A5870</Color>
    <Color x:Key="Color.Scroll.ThumbHover">#61779A</Color>
    <Color x:Key="Color.Scroll.Border">#3C475B</Color>
    <Color x:Key="Color.Scroll.Corner">#1E232D</Color>
    <Color x:Key="Color.Badge.Fill">#2C3443</Color>
    <Color x:Key="Color.Badge.Border">#475268</Color>
    <Color x:Key="Color.Badge.Text">#D3DBE8</Color>
    <Color x:Key="Color.Grid.Filter.Background">#1B2230</Color>
    <Color x:Key="Color.Grid.Filter.Border">#313C50</Color>
    <Color x:Key="Color.Grid.Header.Background">#27405E</Color>
    <Color x:Key="Color.Grid.Header.Border">#6FA7E6</Color>
    <Color x:Key="Color.Grid.Header.Separator">#53779F</Color>
    <Color x:Key="Color.Grid.Header.Text">#F2F8FF</Color>

    <SolidColorBrush x:Key="Brush.Surface0" Color="{DynamicResource Color.Surface0}" />
    <SolidColorBrush x:Key="Brush.Surface1" Color="{DynamicResource Color.Surface1}" />
    <SolidColorBrush x:Key="Brush.Surface2" Color="{DynamicResource Color.Surface2}" />
    <SolidColorBrush x:Key="Brush.Surface3" Color="{DynamicResource Color.Surface3}" />
    <SolidColorBrush x:Key="Brush.Border.Subtle" Color="{DynamicResource Color.Border.Subtle}" />
    <SolidColorBrush x:Key="Brush.Border.Default" Color="{DynamicResource Color.Border.Default}" />
    <SolidColorBrush x:Key="Brush.Border.Strong" Color="{DynamicResource Color.Border.Strong}" />
    <SolidColorBrush x:Key="Brush.Text.Primary" Color="{DynamicResource Color.Text.Primary}" />
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="{DynamicResource Color.Text.Secondary}" />
    <SolidColorBrush x:Key="Brush.Text.Muted" Color="{DynamicResource Color.Text.Muted}" />
    <SolidColorBrush x:Key="Brush.Text.Inverse" Color="{DynamicResource Color.Text.Inverse}" />
    <SolidColorBrush x:Key="Brush.Accent" Color="{DynamicResource Color.Accent}" />
    <SolidColorBrush x:Key="Brush.Accent.Strong" Color="{DynamicResource Color.Accent.Strong}" />
    <SolidColorBrush x:Key="Brush.Hover.Fill" Color="{DynamicResource Color.Hover.Fill}" />
