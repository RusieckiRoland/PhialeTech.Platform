    <SolidColorBrush x:Key="PgAccentBrush" Color="{DynamicResource Color.Accent}" />
    <SolidColorBrush x:Key="PgHeaderBackgroundBrush" Color="{DynamicResource Color.Grid.Header.Background}" />
    <SolidColorBrush x:Key="PgHeaderBorderBrush" Color="{DynamicResource Color.Grid.Header.Border}" />
