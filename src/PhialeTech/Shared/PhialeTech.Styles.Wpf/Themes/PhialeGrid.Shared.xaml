    <SolidColorBrush x:Key="PgCurrentRowBorderBrush" Color="{DynamicResource Color.Selection.Active.Border}" />
    <SolidColorBrush x:Key="PgRowIndicatorColumnBackgroundBrush" Color="{DynamicResource Color.Surface2}" />
    <SolidColorBrush x:Key="PgRowIndicatorColumnCurrentBackgroundBrush" Color="{DynamicResource Color.Selection.Active.Fill}" />
    <SolidColorBrush x:Key="PgFocusRingBrush" Color="{DynamicResource Color.Focus.Ring}" />
    <SolidColorBrush x:Key="PgScrollTrackBrush" Color="{DynamicResource Color.Scroll.Track}" />
    <SolidColorBrush x:Key="PgScrollThumbBrush" Color="{DynamicResource Color.Scroll.Thumb}" />
