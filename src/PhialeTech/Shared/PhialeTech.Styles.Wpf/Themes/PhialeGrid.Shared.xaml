<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:system="clr-namespace:System;assembly=mscorlib">
    <SolidColorBrush x:Key="PgSurfaceBrush" Color="{DynamicResource Color.Surface0}" />
    <SolidColorBrush x:Key="PgControlBorderBrush" Color="{DynamicResource Color.Border.Default}" />
    <SolidColorBrush x:Key="PgPanelBackgroundBrush" Color="{DynamicResource Color.Surface0}" />
    <SolidColorBrush x:Key="PgPanelBorderBrush" Color="{DynamicResource Color.Border.Subtle}" />
    <SolidColorBrush x:Key="PgPanelTextBrush" Color="{DynamicResource Color.Text.Secondary}" />
