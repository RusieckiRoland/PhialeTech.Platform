    <SolidColorBrush x:Key="PgFilterInputBorderBrush" Color="{DynamicResource Color.Border.Default}" />
    <SolidColorBrush x:Key="PgGridLineBrush" Color="{DynamicResource Color.Border.Subtle}" />
    <SolidColorBrush x:Key="PgGridBackgroundBrush" Color="{DynamicResource Color.Surface0}" />
    <SolidColorBrush x:Key="PgGridBorderBrush" Color="{DynamicResource Color.Border.Default}" />
    <SolidColorBrush x:Key="PgPrimaryTextBrush" Color="{DynamicResource Color.Text.Primary}" />
    <SolidColorBrush x:Key="PgSortGlyphBrush" Color="{DynamicResource Color.Accent}" />
    <SolidColorBrush x:Key="PgSortOrderBrush" Color="{DynamicResource Color.Accent.Strong}" />
    <SolidColorBrush x:Key="PgSortBadgeBackgroundBrush" Color="{DynamicResource Color.Badge.Fill}" />
    <SolidColorBrush x:Key="PgSortBadgeBorderBrush" Color="{DynamicResource Color.Badge.Border}" />
    <SolidColorBrush x:Key="PgSortBadgeTextBrush" Color="{DynamicResource Color.Badge.Text}" />
    <SolidColorBrush x:Key="PgRowBackgroundBrush" Color="{DynamicResource Color.Surface0}" />
    <SolidColorBrush x:Key="PgRowAccentBackgroundBrush" Color="{DynamicResource Color.Surface1}" />
    <SolidColorBrush x:Key="PgMasterDetailHeaderBackgroundBrush" Color="{DynamicResource Color.Surface3}" />
    <SolidColorBrush x:Key="PgMasterDetailDetailBackgroundBrush" Color="{DynamicResource Color.Surface1}" />
    <SolidColorBrush x:Key="PgLoadMoreBackgroundBrush" Color="{DynamicResource Color.Warning.Fill}" />
    <SolidColorBrush x:Key="PgLoadMoreTextBrush" Color="{DynamicResource Color.Warning.Text}" />
    <SolidColorBrush x:Key="PgDetailsBackgroundBrush" Color="{DynamicResource Color.Surface1}" />
    <SolidColorBrush x:Key="PgDetailsBorderBrush" Color="{DynamicResource Color.Border.Default}" />
    <SolidColorBrush x:Key="PgDetailsBorderLightBrush" Color="{DynamicResource Color.Border.Subtle}" />
    <SolidColorBrush x:Key="PgEmptyBackgroundBrush" Color="{DynamicResource Color.Surface1}" />
    <SolidColorBrush x:Key="PgEmptyBorderBrush" Color="{DynamicResource Color.Border.Subtle}" />
    <SolidColorBrush x:Key="PgSummaryPanelBorderBrush" Color="{DynamicResource Color.Border.Subtle}" />
