    <SolidColorBrush x:Key="PgScrollBorderBrush" Color="{DynamicResource Color.Scroll.Border}" />
    <SolidColorBrush x:Key="PgScrollCornerBrush" Color="{DynamicResource Color.Scroll.Corner}" />

    <Thickness x:Key="PgGridCellPadding">8,4</Thickness>
    <Thickness x:Key="PgGridHeaderPadding">10,8</Thickness>
    <Thickness x:Key="PgGridFilterTextPadding">8,6,24,6</Thickness>
    <Thickness x:Key="PgGridColumnHeaderBorderThickness">0,0,0,2</Thickness>
    <Thickness x:Key="PgGridRowHeaderBorderThickness">0,0,1,2</Thickness>
    <Thickness x:Key="PgGridRowDetailsMargin">28,0,0,8</Thickness>
    <system:Double x:Key="PgGridRowHeaderWidth">28</system:Double>
    <system:Double x:Key="PgGridFilterClearButtonSize">18</system:Double>
    <system:Double x:Key="PgGridHeaderMenuButtonSize">18</system:Double>

    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="{DynamicResource Color.Surface2}" />
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="{DynamicResource Color.Surface0}" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightBrushKey}" Color="{DynamicResource Color.Scroll.Track}" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightLightBrushKey}" Color="{DynamicResource Color.Surface0}" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkBrushKey}" Color="{DynamicResource Color.Border.Subtle}" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkDarkBrushKey}" Color="{DynamicResource Color.Border.Default}" />
    <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="{DynamicResource Color.Text.Muted}" />
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="{DynamicResource Color.Selection.Active.Fill}" />
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="{DynamicResource Color.Selection.Inactive.Fill}" />
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="{DynamicResource Color.Selection.Active.Text}" />
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="{DynamicResource Color.Selection.Inactive.Text}" />
