        <Setter Property="Background" Value="{DynamicResource Brush.FormShell.FooterBackground}" />
        <Setter Property="Padding" Value="{DynamicResource Thickness.FormShell.FooterPadding}" />
    </Style>

    <Style
        x:Key="YamlDocument.ContentRegionBorderStyle"
        BasedOn="{StaticResource YamlDocument.SectionBorderStyle}"
        TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{DynamicResource Brush.FormShell.ContentBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.FormShell.RegionBorder}" />
