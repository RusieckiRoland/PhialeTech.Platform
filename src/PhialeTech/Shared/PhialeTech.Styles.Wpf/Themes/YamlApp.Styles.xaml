        <Setter Property="BorderBrush" Value="{DynamicResource Brush.FormShell.Divider}" />
    </Style>

    <Style
        x:Key="YamlDocument.BottomActionPanelMergedShellRegionStyle"
        BasedOn="{StaticResource YamlDocument.BottomActionPanelShellRegionStyle}"
        TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{DynamicResource Brush.FormShell.FooterBackground}" />
        <Setter Property="Padding" Value="{DynamicResource Thickness.FormShell.BottomActionMergedPadding}" />
    </Style>

