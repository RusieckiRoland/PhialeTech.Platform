<UserControl x:Class="PhialeTech.PhialeGrid.Wpf.Controls.PhialeChangePanel"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:grid="clr-namespace:PhialeTech.PhialeGrid.Wpf.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="360"
             d:DesignWidth="280"
             Loaded="HandleChangePanelLoaded">
    <DockPanel LastChildFill="True">
        <StackPanel DockPanel.Dock="Bottom"
                    Margin="{DynamicResource PgWorkspacePanelSectionMargin}">
            <Button Style="{DynamicResource PgWorkspacePanelLinkButtonStyle}"
                    Content="{Binding ChangePanelRowsFilterToggleText}"
                    Click="HandleChangedRowsFilterToggleClick" />
            <TextBlock Margin="{DynamicResource PgWorkspacePanelInlineButtonMargin}"
                       Style="{DynamicResource PgWorkspacePanelBodyTextStyle}"
                       Text="Review and commit your changes." />
        </StackPanel>

        <StackPanel>
            <StackPanel Style="{DynamicResource PgWorkspacePanelChangeSummaryPanelStyle}">
                <Border Style="{DynamicResource PgWorkspacePanelChangeIconBorderStyle}">
                    <TextBlock Style="{DynamicResource PgWorkspacePanelChangeIconTextStyle}"
                               Text="i" />
                </Border>
                <TextBlock Style="{DynamicResource PgWorkspacePanelHeaderTextStyle}"
                           Text="{Binding ChangeSummaryText}" />
            </StackPanel>

            <ItemsControl Margin="{DynamicResource PgWorkspacePanelContentMargin}"
                          ItemsSource="{Binding ChangePanelItems}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{DynamicResource PgWorkspacePanelChangeCardBorderStyle}">
                            <StackPanel>
                                <TextBlock Style="{DynamicResource PgWorkspacePanelCaptionTextStyle}"
                                           Text="{Binding Title}" />
                                <TextBlock Margin="{DynamicResource PgWorkspacePanelInlineButtonMargin}"
                                           Style="{DynamicResource PgWorkspacePanelBodyTextStyle}"
                                           Text="{Binding Description}" />
                                <Button Style="{DynamicResource PgWorkspacePanelLinkButtonStyle}"
                                        Content="Go to row"
                                        Click="HandleGoToRowClick" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </DockPanel>
</UserControl>
