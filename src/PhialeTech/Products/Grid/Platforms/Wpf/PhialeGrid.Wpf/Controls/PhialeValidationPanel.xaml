<UserControl x:Class="PhialeTech.PhialeGrid.Wpf.Controls.PhialeValidationPanel"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:grid="clr-namespace:PhialeTech.PhialeGrid.Wpf.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="360"
             d:DesignWidth="280"
             Loaded="HandleValidationPanelLoaded">
    <DockPanel LastChildFill="True">
        <TextBlock DockPanel.Dock="Bottom"
                   Margin="{DynamicResource PgWorkspacePanelSectionMargin}"
                   Style="{DynamicResource PgWorkspacePanelBodyTextStyle}"
                   Text="Fix the issue to clear the error." />

        <StackPanel>
            <StackPanel Style="{DynamicResource PgWorkspacePanelValidationIssueSummaryPanelStyle}">
                <Border Style="{DynamicResource PgWorkspacePanelValidationIssueIconBorderStyle}">
                    <TextBlock Style="{DynamicResource PgWorkspacePanelValidationIssueIconTextStyle}"
                               Text="!" />
                </Border>
                <TextBlock Style="{DynamicResource PgWorkspacePanelHeaderTextStyle}"
                           Text="{Binding ValidationIssueSummaryText}" />
            </StackPanel>

            <ItemsControl Margin="{DynamicResource PgWorkspacePanelContentMargin}"
                          ItemsSource="{Binding ValidationIssueItems}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{DynamicResource PgWorkspacePanelValidationIssueCardBorderStyle}">
                            <StackPanel>
                                <TextBlock Style="{DynamicResource PgWorkspacePanelCaptionTextStyle}"
                                           Text="{Binding Title}" />
                                <TextBlock Margin="{DynamicResource PgWorkspacePanelInlineButtonMargin}"
                                           Style="{DynamicResource PgWorkspacePanelBodyTextStyle}"
                                           Text="{Binding Message}" />
                                <Button Style="{DynamicResource PgWorkspacePanelLinkButtonStyle}"
                                        Content="Go to cell"
                                        Click="HandleGoToCellClick" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </DockPanel>
</UserControl>
