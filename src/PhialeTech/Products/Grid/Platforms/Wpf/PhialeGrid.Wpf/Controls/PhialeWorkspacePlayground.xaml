<UserControl
    x:Class="PhialeTech.PhialeGrid.Wpf.Controls.PhialeWorkspacePlayground"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PhialeTech.PhialeGrid.Wpf.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="48"
    d:DesignWidth="420"
    mc:Ignorable="d">
    <Border Style="{DynamicResource PgWorkspacePlaygroundBorderStyle}">
        <ScrollViewer
            Style="{DynamicResource PgWorkspacePlaygroundScrollViewerStyle}"
            HorizontalScrollBarVisibility="{Binding HorizontalScrollBarVisibility, ElementName=Root}"
            VerticalScrollBarVisibility="{Binding VerticalScrollBarVisibility, ElementName=Root}">
            <ContentPresenter
                x:Name="PlaygroundContentPresenter"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top" />
        </ScrollViewer>
    </Border>
</UserControl>
