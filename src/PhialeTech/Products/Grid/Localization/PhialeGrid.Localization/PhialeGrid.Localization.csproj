<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <Nullable>disable</Nullable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);1591;1573;1587</NoWarn>
    <PackageId>PhialeTech.Grid.Localization</PackageId>
    <AssemblyName>PhialeTech.Grid.Localization</AssemblyName>
    <RootNamespace>PhialeGrid.Localization</RootNamespace>
    <Description>External language file loading for PhialeGrid UI text.</Description>
  </PropertyGroup>

  <ItemGroup>
    <None Include="Languages\*.lang">
      <Link>PhialeGrid.Localization\Languages\%(Filename)%(Extension)</Link>
      <TargetPath>PhialeGrid.Localization\Languages\%(Filename)%(Extension)</TargetPath>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
    </None>
  </ItemGroup>

</Project>
