<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <Nullable>disable</Nullable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);1591;1573;1587</NoWarn>
    <PackageId>PhialeTech.YamlApp.Infrastructure</PackageId>
    <AssemblyName>PhialeTech.YamlApp.Infrastructure</AssemblyName>
    <RootNamespace>PhialeTech.YamlApp.Infrastructure</RootNamespace>
    <Description>Infrastructure services for loading and externalizing PhialeTech YamlApp definitions.</Description>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\Abstractions\PhialeTech.YamlApp.Abstractions\PhialeTech.YamlApp.Abstractions.csproj" />
    <ProjectReference Include="..\..\Definitions\PhialeTech.YamlApp.Definitions\PhialeTech.YamlApp.Definitions.csproj" />
    <ProjectReference Include="..\..\Core\PhialeTech.YamlApp.Core\PhialeTech.YamlApp.Core.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="YamlDotNet" Version="16.3.0" />
  </ItemGroup>
</Project>
