<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net48;net8.0-windows10.0.19041.0</TargetFrameworks>
    <UseWPF>true</UseWPF>
    <EnableDefaultPageItems>false</EnableDefaultPageItems>
    <AppendTargetFrameworkToOutputPath>true</AppendTargetFrameworkToOutputPath>
    <Nullable>disable</Nullable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);1591;1573;1587</NoWarn>
    <PackageId>PhialeTech.ActiveLayerSelector.Wpf</PackageId>
    <AssemblyName>PhialeTech.ActiveLayerSelector.Wpf</AssemblyName>
    <RootNamespace>PhialeTech.ActiveLayerSelector.Wpf</RootNamespace>
    <Description>WPF host for the Active Layer Selector component.</Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\Core\PhialeTech.ActiveLayerSelector\PhialeTech.ActiveLayerSelector.csproj" />
    <ProjectReference Include="..\..\..\..\..\Shared\PhialeTech.Styles.Wpf\PhialeTech.Styles.Wpf.csproj" />
  </ItemGroup>
  <ItemGroup>
    <Page Include="Controls\ActiveLayerSelector.xaml">
      <Generator>MSBuild:Compile</Generator>
      <SubType>Designer</SubType>
    </Page>
  </ItemGroup>
  <ItemGroup>
    <Content Include="..\..\..\Core\PhialeTech.ActiveLayerSelector\Languages\*.lang" Link="PhialeTech.ActiveLayerSelector\Languages\%(Filename)%(Extension)">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Include="Assets\Icons\*.svg" />
  </ItemGroup>
</Project>