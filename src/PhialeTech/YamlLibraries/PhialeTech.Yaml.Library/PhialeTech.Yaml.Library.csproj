<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <AssemblyName>PhialeTech.Yaml.Library</AssemblyName>
    <RootNamespace>PhialeTech.Yaml.Library</RootNamespace>
    <Description>Platform-neutral YAML definition library for PhialeTech forms.</Description>
    <Nullable>disable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <EmbeddedResource Include="Definitions\**\*.yaml" />
    <EmbeddedResource Include="Localization\**\*.yaml" />
  </ItemGroup>

  <ItemGroup>
    <None Include="Readme.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>
