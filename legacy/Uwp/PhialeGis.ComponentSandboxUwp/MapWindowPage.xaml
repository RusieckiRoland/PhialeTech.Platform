<Page
    x:Class="PhialeGis.ComponentSandboxUwp.MapWindowPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Custom="using:PhialeGis.Library.UwpUi.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="240" />
        </Grid.RowDefinitions>

        <Custom:PhialeDrawBoxUwp
            x:Name="Map2"
            Grid.Row="0"
            GisInteractionManager="{Binding GisInteractionManager}"
            HorizontalScrollBarVisible="Collapsed"
            VerticalScrollBarVisible="Collapsed" />

        <Custom:PhialeDslEditor
            Grid.Row="1"
            GisInteractionManager="{Binding GisInteractionManager}"
            TargetDraw="{Binding ElementName=Map2, Path=CompositionAdapter}" />
    </Grid>
</Page>
