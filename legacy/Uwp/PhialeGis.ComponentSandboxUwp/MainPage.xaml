<Page
    x:Class="PhialeGis.ComponentSandboxUwp.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Custom="using:PhialeGis.Library.UwpUi.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:PhialeGis.ComponentSandboxUwp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.15*" />
            <ColumnDefinition Width="0.7*" />
            <ColumnDefinition Width="0.15*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.05*" />
            <RowDefinition Height="0.60*" />
            <RowDefinition Height="0.30*" />
            <RowDefinition Height="0.05*" />
        </Grid.RowDefinitions>

        <!--  Panel z przyciskami; Spacing zapobiega nachodzeniu  -->
        <StackPanel
            Grid.Row="1"
            Grid.Column="2"
            VerticalAlignment="Top"
            Orientation="Vertical"
            Spacing="8">
            <Button
                Width="125"
                Height="50"
                Padding="10"
                Command="{Binding ChangeViewAction}"
                Content="Show shape" />
            <Button
                Width="125"
                Height="50"
                Padding="10"
                Command="{Binding ImportLayer}"
                Content="Import layer" />
            <Button
                Width="125"
                Height="50"
                Padding="10"
                Command="{Binding OpenSecondWindow}"
                Content="Open second map" />
        </StackPanel>

        <Custom:PhialeDrawBoxUwp
            x:Name="Map"
            Grid.Row="1"
            Grid.Column="1"
            Margin="0,11,0,42"
            GisInteractionManager="{Binding GisInteractionManager}"
            HorizontalScrollBarVisible="Visible"
            VerticalScrollBarVisible="Visible" />

        <Custom:PhialeDslEditor
            Grid.Row="2"
            Grid.Column="1"
            BorderBrush="red"
            BorderThickness="2"
            GisInteractionManager="{Binding GisInteractionManager}"
            TargetDraw="{Binding ElementName=Map, Path=CompositionAdapter}" />
    </Grid>
</Page>
