<Window x:Class="PhialeTech.GisStudio.Mock.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:grid="clr-namespace:PhialeTech.PhialeGrid.Wpf.Controls;assembly=PhialeTech.Grid.Wpf"
        xmlns:local="clr-namespace:PhialeTech.GisStudio.Mock.Wpf"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:selector="clr-namespace:PhialeTech.ActiveLayerSelector.Wpf.Controls;assembly=PhialeTech.ActiveLayerSelector.Wpf"
        mc:Ignorable="d"
        Title="{Binding AppTitle}"
        Width="1680"
        Height="980"
        MinWidth="1380"
        MinHeight="860"
        Background="{DynamicResource GisMock.WindowBackgroundBrush}"
        FontFamily="Bahnschrift"
        PreviewKeyDown="HandleWindowPreviewKeyDown">
    <Window.Resources>
        <DataTemplate x:Key="NavigationDrawerContentTemplate">
            <Grid Margin="16,16,16,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Nawigacja"
                               Style="{StaticResource GisMock.CardTitleTextStyle}" />
                    <TextBlock Margin="0,6,0,0"
                               Text="{Binding AppDrawerTitle}"
                               Style="{StaticResource Text.Secondary}" />
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              Margin="0,18,0,18"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Workspace"
                                   Style="{StaticResource Text.Secondary}" />

                        <ToggleButton Margin="0,12,0,8"
                                      Click="HandleNavigationItemClick"
                                      PreviewMouseLeftButtonDown="HandleNavigationItemPointerDown"
                                      HorizontalContentAlignment="Stretch"
                                      Style="{StaticResource GisMock.NavToggleButtonStyle}"
                                      IsChecked="{Binding IsHomeSelected, Mode=TwoWay}"
                                      ToolTip="Start Workspace">
                            <StackPanel>
                                <TextBlock Text="Start Workspace"
                                           Style="{StaticResource GisMock.CardTitleTextStyle}" />
                                <TextBlock Margin="0,2,0,0"
                                           Text="Hub startowy dla map, danych i procesów"
                                           Style="{StaticResource Text.Secondary}" />
                            </StackPanel>
                        </ToggleButton>

                        <ToggleButton Click="HandleNavigationItemClick"
                                      PreviewMouseLeftButtonDown="HandleNavigationItemPointerDown"
                                      HorizontalContentAlignment="Stretch"
                                      Style="{StaticResource GisMock.NavToggleButtonStyle}"
                                      IsChecked="{Binding IsStudioSelected, Mode=TwoWay}"
                                      ToolTip="Studio GIS">
                            <StackPanel>
                                <TextBlock Text="Studio GIS"
                                           Style="{StaticResource GisMock.CardTitleTextStyle}" />
                                <TextBlock Margin="0,2,0,0"
                                           Text="Dokumenty mapowe, edycja i analiza"
                                           Style="{StaticResource Text.Secondary}" />
                            </StackPanel>
                        </ToggleButton>

                        <ToggleButton Click="HandleNavigationItemClick"
                                      PreviewMouseLeftButtonDown="HandleNavigationItemPointerDown"
                                      HorizontalContentAlignment="Stretch"
                                      Style="{StaticResource GisMock.NavToggleButtonStyle}"
                                      IsChecked="{Binding IsCatalogSelected, Mode=TwoWay}"
                                      ToolTip="Katalog Danych">
                            <StackPanel>
                                <TextBlock Text="Katalog Danych"
                                           Style="{StaticResource GisMock.CardTitleTextStyle}" />
                                <TextBlock Margin="0,2,0,0"
                                           Text="Połączenia, importy i źródła"
                                           Style="{StaticResource Text.Secondary}" />
                            </StackPanel>
                        </ToggleButton>

                        <ToggleButton Click="HandleNavigationItemClick"
                                      PreviewMouseLeftButtonDown="HandleNavigationItemPointerDown"
                                      HorizontalContentAlignment="Stretch"
                                      Style="{StaticResource GisMock.NavToggleButtonStyle}"
                                      IsChecked="{Binding IsBusinessSelected, Mode=TwoWay}"
                                      ToolTip="Procesy Biznesowe">
                            <StackPanel>
                                <TextBlock Text="Procesy Biznesowe"
                                           Style="{StaticResource GisMock.CardTitleTextStyle}" />
                                <TextBlock Margin="0,2,0,0"
                                           Text="Kolejki pracy, formularze i sprawy"
                                           Style="{StaticResource Text.Secondary}" />
                            </StackPanel>
                        </ToggleButton>

                        <ToggleButton Click="HandleNavigationItemClick"
                                      PreviewMouseLeftButtonDown="HandleNavigationItemPointerDown"
                                      HorizontalContentAlignment="Stretch"
                                      Style="{StaticResource GisMock.NavToggleButtonStyle}"
                                      IsChecked="{Binding IsReportsSelected, Mode=TwoWay}"
                                      ToolTip="Raporty i Eksport">
                            <StackPanel>
                                <TextBlock Text="Raporty i Eksport"
                                           Style="{StaticResource GisMock.CardTitleTextStyle}" />
                                <TextBlock Margin="0,2,0,0"
                                           Text="Wydruki, PDF i publikacje"
                                           Style="{StaticResource Text.Secondary}" />
                            </StackPanel>
                        </ToggleButton>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Style="{StaticResource GisMock.FloatingCardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding AppDrawerTitle}"
                                   Style="{StaticResource GisMock.CardTitleTextStyle}" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="{Binding AppDrawerSubtitle}"
                                   Style="{StaticResource GisMock.CardBodyTextStyle}" />
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>
    </Window.Resources>
    <Grid ClipToBounds="True">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="56" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="64" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border x:Name="LeftRailHost"
              Grid.Row="1"
              Grid.Column="0"
              Width="56"
              Background="{DynamicResource GisMock.RailBackgroundBrush}"
              BorderBrush="{DynamicResource GisMock.TopBarBorderBrush}"
              BorderThickness="0,0,1,0"
              Panel.ZIndex="20">
            <Grid Margin="4,12,4,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ToggleButton Width="48"
                              Height="48"
                              MinWidth="48"
                              MinHeight="48"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Top"
                              Style="{StaticResource GisMock.IconToggleButtonStyle}"
                              IsChecked="{Binding IsAppDrawerOpen, Mode=TwoWay}"
                              ToolTip="Otwórz lub zamknij drawer">
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               FontSize="16"
                               Text="&#xE700;" />
                </ToggleButton>

                <StackPanel Grid.Row="1"
                            Margin="0,18,0,18">
                    <ToggleButton Width="48"
                                  Height="48"
                                  Padding="0"
                                  Click="HandleNavigationItemClick"
                                  PreviewMouseLeftButtonDown="HandleNavigationItemPointerDown"
                                  HorizontalContentAlignment="Center"
                                  Style="{StaticResource GisMock.IconToggleButtonStyle}"
                                  IsChecked="{Binding IsHomeSelected, Mode=TwoWay}"
                                  ToolTip="Start Workspace">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   FontSize="16"
                                   Text="&#xE80F;" />
                    </ToggleButton>

                    <ToggleButton Width="48"
                                  Height="48"
                                  Padding="0"
                                  Click="HandleNavigationItemClick"
                                  PreviewMouseLeftButtonDown="HandleNavigationItemPointerDown"
                                  HorizontalContentAlignment="Center"
                                  Style="{StaticResource GisMock.IconToggleButtonStyle}"
                                  IsChecked="{Binding IsStudioSelected, Mode=TwoWay}"
                                  ToolTip="Studio GIS">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   FontSize="16"
                                   Text="&#xE81E;" />
                    </ToggleButton>

                    <ToggleButton Width="48"
                                  Height="48"
                                  Padding="0"
                                  Click="HandleNavigationItemClick"
                                  PreviewMouseLeftButtonDown="HandleNavigationItemPointerDown"
                                  HorizontalContentAlignment="Center"
                                  Style="{StaticResource GisMock.IconToggleButtonStyle}"
                                  IsChecked="{Binding IsCatalogSelected, Mode=TwoWay}"
                                  ToolTip="Katalog Danych">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   FontSize="16"
                                   Text="&#xE14C;" />
                    </ToggleButton>

                    <ToggleButton Width="48"
                                  Height="48"
                                  Padding="0"
                                  Click="HandleNavigationItemClick"
                                  PreviewMouseLeftButtonDown="HandleNavigationItemPointerDown"
                                  HorizontalContentAlignment="Center"
                                  Style="{StaticResource GisMock.IconToggleButtonStyle}"
                                  IsChecked="{Binding IsBusinessSelected, Mode=TwoWay}"
                                  ToolTip="Procesy Biznesowe">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   FontSize="16"
                                   Text="&#xE821;" />
                    </ToggleButton>

                    <ToggleButton Width="48"
                                  Height="48"
                                  Padding="0"
                                  Click="HandleNavigationItemClick"
                                  PreviewMouseLeftButtonDown="HandleNavigationItemPointerDown"
                                  HorizontalContentAlignment="Center"
                                  Style="{StaticResource GisMock.IconToggleButtonStyle}"
                                  IsChecked="{Binding IsReportsSelected, Mode=TwoWay}"
                                  ToolTip="Raporty i Eksport">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   FontSize="16"
                                   Text="&#xE9D2;" />
                    </ToggleButton>
                </StackPanel>

                <Button Grid.Row="2"
                        Width="48"
                        Height="48"
                        MinWidth="48"
                        MinHeight="48"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Style="{StaticResource GisMock.IconButtonStyle}"
                        ToolTip="Ustawienia">
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               FontSize="16"
                               Text="&#xE713;" />
                </Button>
            </Grid>
        </Border>

        <Border x:Name="PushDrawerHost"
                Grid.Row="1"
                Grid.Column="1"
                Width="0"
                HorizontalAlignment="Left"
                ClipToBounds="True"
                Visibility="{Binding IsPushDrawerMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                Background="{DynamicResource GisMock.RailBackgroundBrush}"
                BorderBrush="{DynamicResource GisMock.TopBarBorderBrush}"
                BorderThickness="0,0,1,0"
                Panel.ZIndex="10">
            <ContentControl Content="{Binding}"
                            ContentTemplate="{StaticResource NavigationDrawerContentTemplate}" />
        </Border>

        <Canvas x:Name="OverlayDrawerLayer"
                Grid.Row="1"
                Grid.Column="1"
                Grid.ColumnSpan="2"
                ClipToBounds="True"
                Visibility="{Binding IsOverlayDrawerMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                Panel.ZIndex="15">
            <Border x:Name="OverlayDrawerHost"
                    Width="240"
                    Height="{Binding ActualHeight, ElementName=OverlayDrawerLayer}"
                    Canvas.Left="0"
                    Canvas.Top="0"
                    Background="{DynamicResource GisMock.RailBackgroundBrush}"
                    BorderBrush="{DynamicResource GisMock.TopBarBorderBrush}"
                    BorderThickness="0,0,1,0">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="OverlayDrawerTransform" />
                </Border.RenderTransform>
                <ContentControl Content="{Binding}"
                                ContentTemplate="{StaticResource NavigationDrawerContentTemplate}" />
            </Border>
        </Canvas>

        <Border Grid.Row="0"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Panel.ZIndex="30"
                Background="{DynamicResource GisMock.TopBarBackgroundBrush}"
                BorderBrush="{DynamicResource GisMock.TopBarBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="16,12,24,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Width="40"
                        Height="40"
                        Style="{StaticResource GisMock.BrandBadgeBorderStyle}">
                    <TextBlock Text="PG"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource Brush.Text.Inverse}"
                               FontFamily="Bahnschrift SemiBold"
                               FontSize="16" />
                </Border>

                <StackPanel Grid.Column="1"
                            Margin="14,0,0,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding SelectedSectionTitle}"
                               Style="{StaticResource GisMock.SectionTitleTextStyle}" />
                    <TextBlock Margin="0,4,0,0"
                               Text="{Binding SelectedSectionSubtitle}"
                               Style="{StaticResource Text.Secondary}" />
                </StackPanel>

                <Border Grid.Column="3"
                        Style="{StaticResource GisMock.BadgeBorderStyle}"
                        Margin="0,0,14,0"
                        VerticalAlignment="Center">
                    <TextBlock Text="desktop demo"
                               Foreground="{DynamicResource GisMock.BadgeTextBrush}"
                               FontSize="12"
                               FontFamily="Bahnschrift SemiBold" />
                </Border>

                <StackPanel Grid.Column="4"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsStudioSelected, Converter={StaticResource BooleanToVisibilityConverter}}"
                                VerticalAlignment="Center">
                        <ToggleButton Style="{StaticResource GisMock.SegmentToggleButtonStyle}"
                                      IsChecked="{Binding IsAppDrawerOpen, Mode=TwoWay}"
                                      Content="Explorer" />
                        <ToggleButton Style="{StaticResource GisMock.SegmentToggleButtonStyle}"
                                      IsChecked="{Binding SelectedMapDocument.IsInspectorOpen, Mode=TwoWay}"
                                      IsEnabled="{Binding HasSelectedMapDocument}"
                                      Content="Panel" />
                        <ToggleButton Style="{StaticResource GisMock.SegmentToggleButtonStyle}"
                                      IsChecked="{Binding SelectedMapDocument.IsDslOpen, Mode=TwoWay}"
                                      IsEnabled="{Binding HasSelectedMapDocument}"
                                      Content="DSL" />
                        <ToggleButton Style="{StaticResource GisMock.SegmentToggleButtonStyle}"
                                      IsChecked="{Binding SelectedMapDocument.IsAttributeTableMaximized, Mode=TwoWay}"
                                      IsEnabled="{Binding HasSelectedMapDocument}"
                                      Content="Tabela" />
                        <Border Style="{StaticResource GisMock.BadgeBorderStyle}"
                                Margin="8,0,8,0"
                                Visibility="{Binding HasSelectedMapDocument, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{Binding SelectedMapDocument.ActiveLayerName}"
                                       Foreground="{DynamicResource GisMock.BadgeTextBrush}"
                                       FontSize="11" />
                        </Border>
                        <Border Style="{StaticResource GisMock.BadgeBorderStyle}"
                                Margin="0,0,14,0"
                                Visibility="{Binding HasSelectedMapDocument, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{Binding SelectedMapDocument.ActiveGeometryType}"
                                       Foreground="{DynamicResource GisMock.BadgeTextBrush}"
                                       FontSize="11" />
                        </Border>
                        <Button Style="{StaticResource GisMock.SecondaryHeroButtonStyle}"
                                Margin="0,0,10,0"
                                Content="Duplikuj"
                                IsEnabled="{Binding HasSelectedMapDocument}"
                                Click="HandleDuplicateMapClick" />
                        <Button Style="{StaticResource GisMock.SecondaryHeroButtonStyle}"
                                Margin="0,0,14,0"
                                Content="{Binding SelectedMapDocument.ViewportWindowButtonText}"
                                IsEnabled="{Binding HasSelectedMapDocument}"
                                Click="HandleDetachMapClick" />
                    </StackPanel>

                    <ToggleButton Style="{StaticResource GisMock.SegmentToggleButtonStyle}"
                                  IsChecked="{Binding IsDayThemeSelected, Mode=TwoWay}"
                                  Content="Dzień" />
                    <ToggleButton Style="{StaticResource GisMock.SegmentToggleButtonStyle}"
                                  IsChecked="{Binding IsNightThemeSelected, Mode=TwoWay}"
                                  Margin="0,0,14,0"
                                  Content="Noc" />
                    <Button Style="{StaticResource GisMock.SecondaryHeroButtonStyle}"
                            Margin="0,0,10,0"
                            Content="Nowy proces" />
                    <Button Style="{StaticResource GisMock.PrimaryHeroButtonStyle}"
                            Content="Nowa mapa"
                            Click="HandleCreateMapClick" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="WorkspaceHost"
              Grid.Row="1"
              Grid.Column="2"
              Margin="24,22,24,24">
            <ScrollViewer x:Name="HomeWorkspaceView"
                          VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding IsHomeSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <Border Style="{StaticResource GisMock.SurfaceCardBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,28,0">
                                <TextBlock Text="Workspace startowy dla analityka GIS i użytkownika biznesowego"
                                           Style="{StaticResource GisMock.PageTitleTextStyle}" />
                                <TextBlock Margin="0,12,0,0"
                                           Text="Lekki shell inspirowany Felt, ale zorganizowany jak aplikacja desktopowa: mapy, dane, procesy i raporty w jednym miejscu."
                                           Style="{StaticResource GisMock.PageLeadTextStyle}" />
                                <WrapPanel Margin="0,22,0,0">
                                    <Button Style="{StaticResource GisMock.PrimaryHeroButtonStyle}"
                                            Margin="0,0,10,10"
                                            Content="Przejdź do Studio GIS" />
                                    <Button Style="{StaticResource GisMock.SecondaryHeroButtonStyle}"
                                            Margin="0,0,10,10"
                                            Content="Dodaj źródło danych" />
                                    <Button Style="{StaticResource GisMock.SecondaryHeroButtonStyle}"
                                            Margin="0,0,10,10"
                                            Content="Otwórz case biznesowy" />
                                </WrapPanel>
                            </StackPanel>

                            <Grid Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Style="{StaticResource GisMock.PlaceholderBorderStyle}" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Mapa robocza: Region północny"
                                                   Style="{StaticResource GisMock.CardTitleTextStyle}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="WMS + warstwy operacyjne + analiza zmian"
                                                   Style="{StaticResource GisMock.CardBodyTextStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="1" Style="{StaticResource GisMock.PlaceholderBorderStyle}" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Kolejka operacyjna"
                                                   Style="{StaticResource GisMock.CardTitleTextStyle}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="12 zadań do weryfikacji terenowej, 4 oczekują na decyzję"
                                                   Style="{StaticResource GisMock.CardBodyTextStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="2" Style="{StaticResource GisMock.PlaceholderBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Raport poranny"
                                                   Style="{StaticResource GisMock.CardTitleTextStyle}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="Eksport PDF, zestawienie zmian i podsumowanie produkcyjne"
                                                   Style="{StaticResource GisMock.CardBodyTextStyle}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <Grid Margin="0,22,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource GisMock.SurfaceCardBorderStyle}" Margin="0,0,16,0">
                            <StackPanel>
                                <TextBlock Text="Ostatnie mapy i workspace"
                                           Style="{StaticResource GisMock.SectionTitleTextStyle}" />
                                <Border Style="{StaticResource GisMock.ListRowBorderStyle}" Margin="0,14,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Monitoring sieci wodnej" Style="{StaticResource GisMock.CardTitleTextStyle}" />
                                            <TextBlock Text="ostatnio: 11 minut temu" Style="{StaticResource Text.Secondary}" />
                                        </StackPanel>
                                        <Border Grid.Column="1" Style="{StaticResource GisMock.BadgeBorderStyle}">
                                            <TextBlock Text="GIS" Foreground="{DynamicResource GisMock.BadgeTextBrush}" FontSize="11" />
                                        </Border>
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource GisMock.ListRowBorderStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Analiza awarii energetycznych" Style="{StaticResource GisMock.CardTitleTextStyle}" />
                                            <TextBlock Text="ostatnio: dzisiaj 08:10" Style="{StaticResource Text.Secondary}" />
                                        </StackPanel>
                                        <Border Grid.Column="1" Style="{StaticResource GisMock.BadgeBorderStyle}">
                                            <TextBlock Text="OPS" Foreground="{DynamicResource GisMock.BadgeTextBrush}" FontSize="11" />
                                        </Border>
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource GisMock.ListRowBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Podglad wydruku - raport tygodniowy" Style="{StaticResource GisMock.CardTitleTextStyle}" />
                                        <TextBlock Text="ostatnio: wczoraj 17:42" Style="{StaticResource Text.Secondary}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource GisMock.SurfaceCardBorderStyle}" Margin="0,0,16,0">
                            <StackPanel>
                                <TextBlock Text="Źródła danych"
                                           Style="{StaticResource GisMock.SectionTitleTextStyle}" />
                                <TextBlock Margin="0,10,0,0"
                                           Text="Tu ma być prosty punkt wejścia do plików, baz i usług."
                                           Style="{StaticResource GisMock.CardBodyTextStyle}" />
                                <Border Style="{StaticResource GisMock.PlaceholderBorderStyle}" Margin="0,16,0,10">
                                    <TextBlock Text="TU BĘDZIE KATALOG: WMS / SHP / GML / PostGIS / GeoTIFF"
                                               Style="{StaticResource GisMock.CardTitleTextStyle}" />
                                </Border>
                                <Button Style="{StaticResource GisMock.SecondaryHeroButtonStyle}"
                                        Content="Nowe połączenie" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource GisMock.SurfaceCardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Moduly biznesowe"
                                           Style="{StaticResource GisMock.SectionTitleTextStyle}" />
                                <TextBlock Margin="0,10,0,0"
                                           Text="GIS nie jest osobnym światem. Użytkownik musi przejść z mapy do sprawy, formularza, procesu i raportu."
                                           Style="{StaticResource GisMock.CardBodyTextStyle}" />
                                <Border Style="{StaticResource GisMock.PlaceholderBorderStyle}" Margin="0,16,0,10">
                                    <StackPanel>
                                        <TextBlock Text="Karta sprawy / formularz klienta" Style="{StaticResource GisMock.CardTitleTextStyle}" />
                                        <TextBlock Margin="0,6,0,0" Text="Tu będzie zwykła aplikacyjna karta robocza." Style="{StaticResource GisMock.CardBodyTextStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource GisMock.PlaceholderBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Kolejka zadań i akceptacji" Style="{StaticResource GisMock.CardTitleTextStyle}" />
                                        <TextBlock Margin="0,6,0,0" Text="Tu będzie standardowy workflow biznesowy." Style="{StaticResource GisMock.CardBodyTextStyle}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <Grid x:Name="StudioWorkspaceView"
                  Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="320" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="460" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="360" />
                </Grid.ColumnDefinitions>

                <WrapPanel Grid.ColumnSpan="3" Margin="0,0,0,16">
                    <ToggleButton Style="{StaticResource GisMock.DocumentToggleButtonStyle}" IsChecked="True" Content="Mapa główna" />
                    <ToggleButton Style="{StaticResource GisMock.DocumentToggleButtonStyle}" Content="Paper layout A3" />
                    <ToggleButton Style="{StaticResource GisMock.DocumentToggleButtonStyle}" Content="Porównanie monitor 2" />
                </WrapPanel>

                <Border Grid.Row="1"
                        Grid.Column="0"
                        Style="{StaticResource GisMock.SurfaceCardBorderStyle}"
                        Margin="0,0,16,16">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top">
                            <TextBlock Text="Explorer warstw"
                                       Style="{StaticResource GisMock.SectionTitleTextStyle}" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="Aktywna warstwa steruje kontekstem rysowania, gridem i inspectorem."
                                       Style="{StaticResource GisMock.CardBodyTextStyle}" />
                            <Border Style="{StaticResource GisMock.BadgeBorderStyle}"
                                    Margin="0,14,0,14"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="{Binding ActiveLayerCapabilitiesText}"
                                           Foreground="{DynamicResource GisMock.BadgeTextBrush}"
                                           FontSize="11" />
                            </Border>
                            <selector:ActiveLayerSelector x:Name="StudioLayerSelector"
                                                          State="{Binding ActiveLayerSelectorState}"
                                                          LanguageCode="pl"
                                                          InitialVisibleItemCount="6"
                                                          HorizontalAlignment="Stretch"
                                                          VerticalAlignment="Top" />
                        </StackPanel>

                        <StackPanel DockPanel.Dock="Bottom"
                                    Margin="0,18,0,0">
                            <TextBlock Text="Katalog danych"
                                       Style="{StaticResource GisMock.SectionTitleTextStyle}" />
                            <ItemsControl Margin="0,12,0,0"
                                          ItemsSource="{Binding CatalogItems}">
