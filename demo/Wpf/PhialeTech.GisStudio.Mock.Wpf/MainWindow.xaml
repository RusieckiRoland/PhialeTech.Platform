                        <ColumnDefinition Width="0.95*" />
                        <ColumnDefinition Width="0.8*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource GisMock.SurfaceCardBorderStyle}"
                            Margin="0,0,16,0">
                        <StackPanel>
                            <TextBlock Text="Raporty gotowe do publikacji"
                                       Style="{StaticResource GisMock.SectionTitleTextStyle}" />
                            <Border Style="{StaticResource GisMock.ListRowBorderStyle}"
                                    Margin="0,14,0,0">
                                <StackPanel>
                                    <TextBlock Text="Raport zmian sieci wodnej - dzisiaj 09:40"
                                               Style="{StaticResource GisMock.CardTitleTextStyle}" />
                                    <TextBlock Text="PDF + legenda + mapa poglądowa"
                                               Style="{StaticResource Text.Secondary}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource GisMock.ListRowBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="Zestawienie obiektów wymagających inspekcji"
                                               Style="{StaticResource GisMock.CardTitleTextStyle}" />
                                    <TextBlock Text="CSV + XLSX + paczka map"
                                               Style="{StaticResource Text.Secondary}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource GisMock.ListRowBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="Raport SLA dla procesów terenowych"
                                               Style="{StaticResource GisMock.CardTitleTextStyle}" />
                                    <TextBlock Text="Dashboard + PDF dla kierownika"
                                               Style="{StaticResource Text.Secondary}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="1"
                                Margin="0,0,16,0">
                        <Border Style="{StaticResource GisMock.SurfaceCardBorderStyle}"
                                Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Generator wydruków"
                                           Style="{StaticResource GisMock.SectionTitleTextStyle}" />
                                <TextBlock Margin="0,8,0,0"
                                           Text="{Binding PrintSummaryText}"
                                           Style="{StaticResource GisMock.CardBodyTextStyle}" />
                                <WrapPanel Margin="0,16,0,0">
                                    <Button Style="{StaticResource GisMock.ToolChipButtonStyle}"
                                            Content="Nowy PDF" />
                                    <Button Style="{StaticResource GisMock.ToolChipButtonStyle}"
                                            Content="Eksport XLSX" />
                                    <Button Style="{StaticResource GisMock.ToolChipButtonStyle}"
                                            Content="Publikuj" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource GisMock.SurfaceCardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Ostatnie akcje"
                                           Style="{StaticResource GisMock.SectionTitleTextStyle}" />
                                <ItemsControl Margin="0,14,0,0"
                                              ItemsSource="{Binding RecentActionItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource GisMock.ListRowBorderStyle}">
                                                <TextBlock Text="{Binding}"
                                                           Style="{StaticResource GisMock.CardBodyTextStyle}" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Border Grid.Column="2"
                            Style="{StaticResource GisMock.SurfaceCardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Publikacje"
                                       Style="{StaticResource GisMock.SectionTitleTextStyle}" />
                            <Border Style="{StaticResource GisMock.PlaceholderBorderStyle}"
                                    Margin="0,16,0,10">
                                <TextBlock Text="TU BĘDZIE: status publikacji web / portal / kolejka eksportów"
                                           Style="{StaticResource GisMock.CardTitleTextStyle}" />
                            </Border>
                            <Border Style="{StaticResource GisMock.BadgeBorderStyle}"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="3 raporty oczekują na publikację"
                                           Foreground="{DynamicResource GisMock.BadgeTextBrush}"
                                           FontSize="11" />
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
