<UserControl x:Class="PhialeTech.GisStudio.Mock.Wpf.MapDocumentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:grid="clr-namespace:PhialeTech.PhialeGrid.Wpf.Controls;assembly=PhialeTech.Grid.Wpf"
             xmlns:local="clr-namespace:PhialeTech.GisStudio.Mock.Wpf"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="900"
             d:DesignWidth="1400">
    <Grid>
        <Grid Visibility="{Binding IsDocumentLayoutVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="320" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource GisMock.SurfaceCardBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="{Binding Title}"
                                   Style="{StaticResource GisMock.SectionTitleTextStyle}" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding DetachedStateText}"
                                   Style="{StaticResource GisMock.CardBodyTextStyle}" />
                    </StackPanel>

                    <WrapPanel Grid.Column="1"
                               VerticalAlignment="Center">
                        <Border Style="{StaticResource GisMock.BadgeBorderStyle}"
                                Margin="0,0,8,0">
                            <TextBlock Text="{Binding ActiveLayerName}"
                                       Foreground="{DynamicResource GisMock.BadgeTextBrush}"
                                       FontSize="11" />
                        </Border>
                        <Border Style="{StaticResource GisMock.BadgeBorderStyle}"
                                Margin="0,0,8,0">
                            <TextBlock Text="{Binding ActiveLayerSource}"
                                       Foreground="{DynamicResource GisMock.BadgeTextBrush}"
                                       FontSize="11" />
                        </Border>
                        <Border Style="{StaticResource GisMock.BadgeBorderStyle}">
                            <TextBlock Text="{Binding ActiveGeometryType}"
                                       Foreground="{DynamicResource GisMock.BadgeTextBrush}"
                                       FontSize="11" />
                        </Border>
                    </WrapPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1"
                  Margin="0,16,0,0">
                <Grid>
                    <local:MapViewportView Visibility="{Binding IsViewportAttached, Converter={StaticResource BooleanToVisibilityConverter}}" />

                    <Grid Visibility="{Binding IsDetachedDataWorkspaceVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="0.95*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Margin="0,0,16,0"
                                Style="{StaticResource GisMock.SurfaceCardBorderStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel>
                                    <TextBlock Text="{Binding ObjectInspectorTitle}"
                                               Style="{StaticResource GisMock.SectionTitleTextStyle}" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="{Binding ObjectInspectorText}"
                                               Style="{StaticResource GisMock.CardBodyTextStyle}" />
                                </StackPanel>

                                <Grid Grid.Row="1"
                                      Margin="0,18,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="1*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Margin="0,0,10,0"
                                            Style="{StaticResource GisMock.PlaceholderBorderStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Aktywny obiekt"
                                                       Style="{StaticResource GisMock.CardTitleTextStyle}" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Text="Id, geometria, status, relacje z procesem, historia zmian i akcje biznesowe."
                                                       Style="{StaticResource GisMock.CardBodyTextStyle}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1"
                                            Margin="10,0,0,0"
                                            Style="{StaticResource GisMock.PlaceholderBorderStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Powiazania biznesowe"
                                                       Style="{StaticResource GisMock.CardTitleTextStyle}" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Text="Sprawy, formularze, zalaczniki, SLA, decyzje i komentarze operatora."
                                                       Style="{StaticResource GisMock.CardBodyTextStyle}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Grid Grid.Row="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Selection / identify / query results"
                                               Style="{StaticResource GisMock.CardTitleTextStyle}" />

                                    <ItemsControl Grid.Row="1"
                                                  Margin="0,12,0,0"
                                                  ItemsSource="{Binding RecentActionItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource GisMock.ListRowBorderStyle}">
                                                    <TextBlock Text="{Binding}"
                                                               Style="{StaticResource GisMock.CardBodyTextStyle}" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Grid>
                        </Border>

                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="1*" />
                                <RowDefinition Height="0.95*" />
                            </Grid.RowDefinitions>

                            <Border Margin="0,0,0,16"
                                    Style="{StaticResource GisMock.SurfaceCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="{Binding LayerPropertiesTitle}"
                                               Style="{StaticResource GisMock.SectionTitleTextStyle}" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="{Binding LayerPropertiesText}"
                                               Style="{StaticResource GisMock.CardBodyTextStyle}" />
                                    <Border Margin="0,18,0,14"
                                            Style="{StaticResource GisMock.PlaceholderBorderStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Layer properties"
                                                       Style="{StaticResource GisMock.CardTitleTextStyle}" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Text="Symbolika, etykiety, zakres skali, definicja warstwy i diagnostyka zrodla."
                                                       Style="{StaticResource GisMock.CardBodyTextStyle}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource GisMock.ListRowBorderStyle}">
                                        <TextBlock Text="Widocznosc / label engine / definicja / filtr / skala"
                                                   Style="{StaticResource GisMock.CardBodyTextStyle}" />
                                    </Border>
                                    <Border Style="{StaticResource GisMock.ListRowBorderStyle}">
                                        <TextBlock Text="WMS / SHP / PostGIS / GML / parametry sesji i cache"
                                                   Style="{StaticResource GisMock.CardBodyTextStyle}" />
                                    </Border>
                                    <Border Style="{StaticResource GisMock.ListRowBorderStyle}">
                                        <TextBlock Text="Uprawnienia edycji / snapping / walidacja / wersjonowanie"
                                                   Style="{StaticResource GisMock.CardBodyTextStyle}" />
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1"
                                    Style="{StaticResource GisMock.SurfaceCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="Results / diagnostics / jobs"
                                               Style="{StaticResource GisMock.SectionTitleTextStyle}" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="Tu trafia wynik analizy, importu GML, log parsera DSL oraz status kolejek."
                                               Style="{StaticResource GisMock.CardBodyTextStyle}" />
                                    <Border Margin="0,18,0,14"
                                            Style="{StaticResource GisMock.PlaceholderBorderStyle}">
                                        <TextBlock Text="Panel wynikow"
                                                   Style="{StaticResource GisMock.CardTitleTextStyle}" />
                                    </Border>
                                    <ItemsControl ItemsSource="{Binding RecentActionItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource GisMock.ListRowBorderStyle}">
                                                    <TextBlock Text="{Binding}"
                                                               Style="{StaticResource GisMock.CardBodyTextStyle}" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>

                <Grid x:Name="InspectorDrawerHost"
                      Width="384"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Stretch">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="InspectorDrawerTransform" />
                    </Grid.RenderTransform>
                    <ToggleButton Width="24"
                                  Height="104"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Top"
                                  Margin="0,24,0,0"
                                  Style="{StaticResource GisMock.SegmentToggleButtonStyle}"
                                  IsChecked="{Binding IsInspectorOpen, Mode=TwoWay}"
                                  Content="&lt;" />
                    <Border Width="360"
                            Margin="24,0,0,0"
                            HorizontalAlignment="Right"
                            Style="{StaticResource GisMock.FloatingCardBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock Text="{Binding DrawerHeadline}"
                                           Style="{StaticResource GisMock.SectionTitleTextStyle}" />
                                <TextBlock Margin="0,4,0,0"
                                           Text="{Binding ActiveLayerPath}"
                                           Style="{StaticResource Text.Secondary}" />
                            </StackPanel>

                            <WrapPanel Grid.Row="1"
                                       Margin="0,16,0,14">
                                <ToggleButton Style="{StaticResource GisMock.SegmentToggleButtonStyle}"
                                              IsChecked="{Binding IsStyleInspectorSelected, Mode=TwoWay}"
                                              Content="Styl" />
                                <ToggleButton Style="{StaticResource GisMock.SegmentToggleButtonStyle}"
                                              IsChecked="{Binding IsDataInspectorSelected, Mode=TwoWay}"
                                              Content="Dane" />
                                <ToggleButton Style="{StaticResource GisMock.SegmentToggleButtonStyle}"
                                              IsChecked="{Binding IsPrintInspectorSelected, Mode=TwoWay}"
                                              Content="Druk" />
                            </WrapPanel>

                            <ScrollViewer Grid.Row="2"
                                          VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <StackPanel Visibility="{Binding IsStyleInspectorSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="Widocznosc etykiet"
                                                   Style="{StaticResource GisMock.CardTitleTextStyle}" />
                                        <CheckBox Margin="0,8,0,0"
                                                  IsChecked="{Binding ShowLabels, Mode=TwoWay}"
                                                  Content="Pokaz etykiety warstwy" />
                                        <CheckBox Margin="0,6,0,0"
                                                  IsChecked="{Binding UseScaleVisibility, Mode=TwoWay}"
                                                  Content="Uwzglednij zakres skali" />
                                        <CheckBox Margin="0,6,0,0"
                                                  IsChecked="{Binding LockLayerEditing, Mode=TwoWay}"
                                                  Content="Zablokuj edycje tej warstwy" />
                                        <TextBlock Margin="0,18,0,0"
                                                   Text="Przezroczystosc"
                                                   Style="{StaticResource GisMock.CardTitleTextStyle}" />
                                        <Slider Margin="0,8,0,0"
                                                Minimum="0"
                                                Maximum="100"
                                                Value="{Binding LayerOpacity, Mode=TwoWay}" />
                                        <Border Style="{StaticResource GisMock.BadgeBorderStyle}"
                                                Margin="0,8,0,0"
                                                HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding LayerOpacityText}"
                                                       Foreground="{DynamicResource GisMock.BadgeTextBrush}"
                                                       FontSize="11" />
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Visibility="{Binding IsDataInspectorSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="Definicja warstwy"
                                                   Style="{StaticResource GisMock.CardTitleTextStyle}" />
                                        <TextBox Margin="0,8,0,0"
                                                 Text="{Binding DefinitionQueryText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <WrapPanel Margin="0,16,0,0">
                                            <Button Style="{StaticResource GisMock.ToolChipButtonStyle}"
                                                    Content="Zoom do warstwy" />
                                            <Button Style="{StaticResource GisMock.ToolChipButtonStyle}"
                                                    Content="Odswiez" />
                                            <Button Style="{StaticResource GisMock.ToolChipButtonStyle}"
                                                    Content="Otworz zrodlo" />
                                        </WrapPanel>
                                        <TextBlock Margin="0,18,0,0"
                                                   Text="{Binding DataStatusText}"
                                                   Style="{StaticResource GisMock.CardBodyTextStyle}" />
                                    </StackPanel>

                                    <StackPanel Visibility="{Binding IsPrintInspectorSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="Format"
                                                   Style="{StaticResource GisMock.CardTitleTextStyle}" />
                                        <ComboBox Margin="0,8,0,0"
                                                  ItemsSource="{Binding AvailablePaperFormats}"
                                                  SelectedItem="{Binding SelectedPaperFormat, Mode=TwoWay}" />
                                        <TextBlock Margin="0,16,0,0"
                                                   Text="Skala"
                                                   Style="{StaticResource GisMock.CardTitleTextStyle}" />
                                        <ComboBox Margin="0,8,0,0"
                                                  ItemsSource="{Binding AvailableScales}"
                                                  SelectedItem="{Binding SelectedScale, Mode=TwoWay}" />
                                        <CheckBox Margin="0,18,0,0"
                                                  IsChecked="{Binding IncludeLegend, Mode=TwoWay}"
                                                  Content="Dodaj legende" />
                                        <CheckBox Margin="0,6,0,0"
                                                  IsChecked="{Binding IncludeNorthArrow, Mode=TwoWay}"
                                                  Content="Dodaj north arrow" />
                                        <CheckBox Margin="0,6,0,0"
                                                  IsChecked="{Binding IncludeOverviewMap, Mode=TwoWay}"
                                                  Content="Dodaj mape przegladkowa" />
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <Border Grid.Row="2"
                    Margin="0,16,0,0"
                    Style="{StaticResource GisMock.SurfaceCardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Tabela atrybutow"
                                       Style="{StaticResource GisMock.SectionTitleTextStyle}" />
                            <TextBlock Margin="0,6,0,0"
                                       Text="{Binding RecordSummaryText}"
                                       Style="{StaticResource GisMock.CardBodyTextStyle}" />
                        </StackPanel>

                        <WrapPanel Grid.Column="1">
                            <Button Style="{StaticResource GisMock.ToolChipButtonStyle}"
                                    Content="Filtr" />
                            <Button Style="{StaticResource GisMock.ToolChipButtonStyle}"
                                    Content="Sortowanie" />
                            <Button Style="{StaticResource GisMock.ToolChipButtonStyle}"
                                    Content="Eksport" />
                            <ToggleButton Style="{StaticResource GisMock.SegmentToggleButtonStyle}"
                                          IsChecked="{Binding IsAttributeTableMaximized, Mode=TwoWay}"
                                          Content="Pelny ekran" />
                        </WrapPanel>
                    </Grid>

                    <grid:PhialeGrid x:Name="CompactAttributeGrid"
                                     Grid.Row="1"
                                     ItemsSource="{Binding GridRecords}"
                                     Columns="{Binding GridColumns}"
                                     Summaries="{Binding GridSummaries}"
                                     IsGridReadOnly="{Binding IsGridReadOnly}"
                                     IsNightMode="{Binding IsNightMode}"
                                     LanguageCode="pl" />
                </Grid>
            </Border>
        </Grid>

        <Border Visibility="{Binding IsAttributeTableOnlyVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                Style="{StaticResource GisMock.SurfaceCardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Tabela atrybutow - pelny ekran dokumentu"
                                   Style="{StaticResource GisMock.SectionTitleTextStyle}" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding RecordSummaryText}"
                                   Style="{StaticResource GisMock.CardBodyTextStyle}" />
                    </StackPanel>

                    <ToggleButton Grid.Column="1"
                                  Style="{StaticResource GisMock.SegmentToggleButtonStyle}"
                                  IsChecked="{Binding IsAttributeTableMaximized, Mode=TwoWay}"
                                  Content="Przywroc" />
                </Grid>

                <grid:PhialeGrid x:Name="FullAttributeGrid"
                                 Grid.Row="1"
                                 ItemsSource="{Binding GridRecords}"
                                 Columns="{Binding GridColumns}"
                                 Summaries="{Binding GridSummaries}"
                                 IsGridReadOnly="{Binding IsGridReadOnly}"
                                 IsNightMode="{Binding IsNightMode}"
                                 LanguageCode="pl" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
