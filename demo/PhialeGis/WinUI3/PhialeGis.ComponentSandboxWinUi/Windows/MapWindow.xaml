            VerticalScrollBarVisible="Visible" />

        <!--<Custom:PhialeDslEditor
            Grid.Row="1"
            GisInteractionManager="{Binding GisInteractionManager}"
            TargetDraw="{Binding ElementName=Map2, Path=CompositionAdapter}" />-->
    </Grid>
</Page>
